---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";

const { transparent = false } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

// Helper to check if a path is active
const isActive = (path: string) => {
  const target = path.replace(/\/$/, "") || "/";
  return pathname === target;
};

const isParentActive = (parentPath: string) => pathname.startsWith(parentPath);
---

<nav class="navbar" id="navbar">
  <div class="navbar__content container">
    <div class="navbar__brand">
      <a href="/" class="navbar__logo">
        <Image
          src={logo}
          alt="Cuaderno Digital Logo"
          height={48}
          quality="max"
        />
      </a>
    </div>

    <button class="navbar__toggle" id="navToggle" aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </button>

    <ul class="navbar__menu" id="navMenu">
      <li class={`navbar__item navbar__item--has-dropdown ${isActive("/") ? "active" : ""}`}>
        <a href="/"
          >Tecnología
          <svg
            width="10"
            height="10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            ><path d="m6 9 6 6 6-6"></path>
          </svg>
        </a>
        <ul class="navbar__dropdown">
          <li>
            <a href="/#sensores">Ecosistema de Sensores</a>
          </li>
          <li>
            <a href="/#gestion">Gestión Virtual & GIS</a>
          </li>
          <li>
            <a href="/#asistente">Asistente IA Agrario</a>
          </li>
        </ul>
      </li>

      <li class={`navbar__item navbar__item--has-dropdown ${isParentActive("/soluciones") ? "active" : ""}`}>
        <a href="/soluciones"
          >Soluciones
          <svg
            width="10"
            height="10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            ><path d="m6 9 6 6 6-6"></path>
          </svg>
        </a>
        <ul class="navbar__dropdown">
          <li>
            <a href="/soluciones/agricultores" class={isActive("/soluciones/agricultores") ? "active-sub" : ""}>Para Agricultores</a>
          </li>
          <li>
            <a href="/soluciones/tecnicos" class={isActive("/soluciones/tecnicos") ? "active-sub" : ""}>Para Técnicos & Asesores</a>
          </li>
        </ul>
      </li>

      <li class={`navbar__item navbar__item--has-dropdown ${isParentActive("/herramientas") ? "active" : ""}`}>
        <a href="/herramientas"
          >Servicios
          <svg
            width="10"
            height="10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            ><path d="m6 9 6 6 6-6"></path>
          </svg>
        </a>
        <ul class="navbar__dropdown">
          <li>
            <a href="/herramientas/prescripcion" class={isActive("/herramientas/prescripcion") ? "active-sub" : ""}>Prescripción Digital</a>
          </li>
          <li>
            <a href="/herramientas/estiercoles" class={isActive("/herramientas/estiercoles") ? "active-sub" : ""}>Gestión de Estiércoles</a>
          </li>
          <li>
            <a href="/herramientas/trazabilidad" class={isActive("/herramientas/trazabilidad") ? "active-sub" : ""}>Trazabilidad GPS DARP</a>
          </li>
          <li>
              <a href="/herramientas/asesoramiento" class={isActive("/herramientas/asesoramiento") ? "active-sub" : ""}>Asesoramiento Estratégico</a>
          </li>
        </ul>
      </li>

      <li class={`navbar__item navbar__item--has-dropdown ${isParentActive("/cuaderno") ? "active" : ""}`}>
        <a href="/cuaderno"
          >Cuaderno
          <svg
            width="10"
            height="10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            ><path d="m6 9 6 6 6-6"></path>
          </svg>
        </a>
        <ul class="navbar__dropdown">
          <li>
            <a href="/cuaderno/guia-pac-ecorregimenes" class={isActive("/cuaderno/guia-pac-ecorregimenes") ? "active-sub" : ""}>Guía Ecorregímenes 2024</a>
          </li>
          <li>
            <a href="/cuaderno/informacion-comunidades" class={isActive("/cuaderno/informacion-comunidades") ? "active-sub" : ""}>Directorio CUE/SIEX</a>
          </li>
        </ul>
      </li>

      <li class={`navbar__item navbar__item--has-dropdown ${isParentActive("/ayudas") ? "active" : ""}`}>
        <a href="/ayudas"
          >Ayudas
          <svg
            width="10"
            height="10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            ><path d="m6 9 6 6 6-6"></path>
          </svg>
        </a>
        <ul class="navbar__dropdown">
          <li><a href="/ayudas/kit-digital" class={isActive("/ayudas/kit-digital") ? "active-sub" : ""}>Kit Digital</a></li>
          <li><a href="/ayudas/digitalizacion" class={isActive("/ayudas/digitalizacion") ? "active-sub" : ""}>Ayudas Digitalización</a></li>
          <li><a href="/contacto" class={isActive("/contacto") ? "active-sub" : ""}>Soporte y Contacto</a></li>
        </ul>
      </li>

      <li class={`navbar__item ${isActive("/blog") ? "active" : ""}`}><a href="/blog">Blog</a></li>
      <li class={`navbar__item ${isActive("/contacto") ? "active" : ""}`}><a href="/contacto">Contacto</a></li>
      <li class={`navbar__item navbar__item--has-dropdown ${isParentActive("/sensores") || isActive("/guia-sensores") ? "active" : ""}`}>
        <a href="/guia-sensores"
          >Sensores
          <svg
            width="10"
            height="10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            ><path d="m6 9 6 6 6-6"></path>
          </svg>
        </a>
        <ul class="navbar__dropdown">
          <li>
            <a href="/sensores/suelo" class={isActive("/sensores/suelo") ? "active-sub" : ""}>Sensores de Suelo y Raíz</a>
          </li>
          <li>
            <a href="/sensores/planta" class={isActive("/sensores/planta") ? "active-sub" : ""}>Fisiología de Planta (Hoja y Fruto)</a>
          </li>
          <li>
            <a href="/sensores/clima" class={isActive("/sensores/clima") ? "active-sub" : ""}>Monitorización Meteorológica</a>
          </li>
        </ul>
      </li>
    </ul>
  </div>
</nav>

<script>
  document.addEventListener("astro:page-load", () => {
    const toggle = document.getElementById("navToggle");
    const menu = document.getElementById("navMenu");
    if (toggle && menu) {
      toggle.addEventListener("click", () => {
        menu.classList.toggle("navbar__menu--open");
        toggle.classList.toggle("navbar__toggle--active");
      });
    }

    const nav = document.getElementById("navbar");
    window.addEventListener("scroll", () => {
      if (window.scrollY > 40) {
        nav?.classList.add("navbar--scrolled");
      } else {
        nav?.classList.remove("navbar--scrolled");
      }
    });
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 90px !important;
    background: #0B1A14 !important;
    z-index: 1000;
    display: flex;
    align-items: center;
    transition: none !important;
    box-sizing: border-box;
    border: none !important;
    border-bottom: none !important;
  }

  /* RESETS AGRESIVOS PARA ELIMINAR CUALQUIER SUBRAYADO */
  .navbar a, 
  .navbar__item a,
  .navbar__item.active a,
  .navbar__menu a {
    text-decoration: none !important;
    border: none !important;
    border-bottom: none !important;
    box-shadow: none !important;
    outline: none !important;
  }

  .navbar--scrolled {
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }

  .navbar__content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .navbar__brand {
    display: flex;
    align-items: center;
  }

  .navbar__logo img {
    height: 44px;
    width: auto;
  }

  .navbar__menu {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .navbar__item {
    position: relative;
  }

  .navbar__item > a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    font-size: 0.95rem;
    font-weight: 600;
    transition: var(--transition);
    color: #FFFFFF;
    text-decoration: none !important;
    border: none !important;
  }

  /* Active/Hover States */
  .navbar__item > a:hover {
    color: var(--color-turquoise) !important;
    text-decoration: none !important;
  }

  .navbar__item.active > a {
    color: #1AFFFF !important;
    text-decoration: none !important;
    border-bottom: 2px solid #1AFFFF !important;
    padding-bottom: 6px;
  }

  .navbar__dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 280px;
    background: var(--color-white);
    padding: 12px;
    border-radius: 12px;
    box-shadow: var(--shadow-xl);
    border: 1px solid var(--color-gray-100);
    margin-top: 0;
  }

  .navbar__item--has-dropdown:hover .navbar__dropdown {
    display: block;
    animation: fadeIn 0.2s ease;
  }

  .navbar__dropdown li a {
    display: block;
    padding: 10px 16px;
    font-size: 0.9rem;
    color: var(--color-gray-700);
    border-radius: 8px;
    text-decoration: none !important;
    border: none !important;
  }

  .navbar__dropdown li a:hover,
  .navbar__dropdown li a.active-sub {
    background: var(--color-gray-50);
    color: var(--color-turquoise);
  }

  .navbar__toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .navbar__toggle span {
    background: #FFFFFF;
    width: 25px;
    height: 2px;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 1024px) {
    .navbar {
      background: var(--color-white) !important;
      height: auto !important;
      padding: 12px 0;
    }
    .navbar__toggle { display: flex; }
    .navbar__item > a { 
      color: var(--color-gray-700) !important;
      text-decoration: none !important;
    }
    .navbar__toggle span { background: var(--color-gray-700); }
    .navbar__menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: var(--color-white);
      padding: 24px;
      box-shadow: var(--shadow-xl);
      border-top: 1px solid var(--color-gray-100);
    }
    .navbar__menu--open { display: flex; }
    .navbar__dropdown {
      position: static;
      box-shadow: none;
      border: none;
      background: var(--color-gray-50);
      margin-top: 10px;
      display: block;
    }
  }
</style>

<style is:global>
  /* FORZADO GLOBAL PARA EL MENÚ */
  .navbar__item a, 
  .navbar__item.active a,
  .navbar__menu a,
  .navbar__logo,
  .navbar__logo img {
    text-decoration: none !important;
    border-bottom: none !important;
    border: none !important;
    box-shadow: none !important;
    outline: none !important;
  }

  .navbar__item a::before,
  .navbar__item a::after {
    display: none !important;
    content: none !important;
    border: none !important;
  }
</style>
