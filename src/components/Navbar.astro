---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";

const { transparent = false } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

// Helper to check if a path is active
const isActive = (path: string) => {
  const target = path.replace(/\/$/, "") || "/";
  return pathname === target;
};

const isParentActive = (parentPath: string) => pathname.startsWith(parentPath);
---

<nav class="navbar" id="navbar">
  <div class="navbar__content container">
    <div class="navbar__brand">
      <a href="/" class="navbar__logo">
        <Image
          src={logo}
          alt="Cuaderno Digital Logo"
          height={48}
          quality="max"
        />
      </a>
    </div>

    <div class="navbar__center-title">
      <a href="/">Smart Agro</a>
    </div>

    <div class="navbar__right-actions">
      <a href="/admin/login" class="admin-access-btn" aria-label="Admin Panel">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
      </a>

      <button class="navbar__toggle" id="navToggle" aria-label="Abrir menú">
        <span></span><span></span><span></span>
      </button>
    </div>

    <ul class="navbar__menu" id="navMenu">
      <li class={`navbar__item navbar__item--has-dropdown navbar__item--tech ${isActive("/") ? "active" : ""}`}>
        <div class="navbar__item-row">
            <a href="/">Tecnología</a>
            <button class="dropdown-trigger" aria-label="Toggle submenu">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"></path></svg>
            </button>
        </div>
        <ul class="navbar__dropdown">
          <li>
            <a href="/#sensores">Ecosistema de Sensores</a>
          </li>
          <li>
            <a href="/#gestion">Gestión Virtual & GIS</a>
          </li>
          <li>
            <a href="/#asistente">Asistente IA Agrario</a>
          </li>
        </ul>
      </li>

      <li class={`navbar__item navbar__item--has-dropdown ${isParentActive("/soluciones") ? "active" : ""}`}>
        <div class="navbar__item-row">
            <a href="/soluciones">Soluciones</a>
            <button class="dropdown-trigger" aria-label="Toggle submenu">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"></path></svg>
            </button>
        </div>
        <ul class="navbar__dropdown">
          <li>
            <a href="/soluciones/agricultores" class={isActive("/soluciones/agricultores") ? "active-sub" : ""}>Para Agricultores</a>
          </li>
          <li>
            <a href="/soluciones/tecnicos" class={isActive("/soluciones/tecnicos") ? "active-sub" : ""}>Para Técnicos & Asesores</a>
          </li>
        </ul>
      </li>

      <li class={`navbar__item navbar__item--has-dropdown ${isParentActive("/sensores") || isActive("/guia-sensores") ? "active" : ""}`}>
        <div class="navbar__item-row">
            <a href="/guia-sensores">Sensores</a>
            <button class="dropdown-trigger" aria-label="Toggle submenu">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"></path></svg>
            </button>
        </div>
        <ul class="navbar__dropdown">
          <li>
            <a href="/sensores/suelo" class={isActive("/sensores/suelo") ? "active-sub" : ""}>Sensores de Suelo y Raíz</a>
          </li>
          <li>
            <a href="/sensores/planta" class={isActive("/sensores/planta") ? "active-sub" : ""}>Fisiología de Planta (Hoja y Fruto)</a>
          </li>
          <li>
            <a href="/sensores/clima" class={isActive("/sensores/clima") ? "active-sub" : ""}>Monitorización Meteorológica</a>
          </li>
        </ul>
      </li>

      <li class={`navbar__item navbar__item--has-dropdown ${isParentActive("/herramientas") ? "active" : ""}`}>
        <div class="navbar__item-row">
            <a href="/herramientas">Servicios</a>
            <button class="dropdown-trigger" aria-label="Toggle submenu">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"></path></svg>
            </button>
        </div>
        <ul class="navbar__dropdown">
          <li>
            <a href="/herramientas/prescripcion" class={isActive("/herramientas/prescripcion") ? "active-sub" : ""}>Prescripción Digital</a>
          </li>
          <li>
            <a href="/herramientas/estiercoles" class={isActive("/herramientas/estiercoles") ? "active-sub" : ""}>Gestión de Estiércoles</a>
          </li>
          <li>
            <a href="/herramientas/trazabilidad" class={isActive("/herramientas/trazabilidad") ? "active-sub" : ""}>Trazabilidad GPS DARP</a>
          </li>
          <li>
              <a href="/herramientas/asesoramiento" class={isActive("/herramientas/asesoramiento") ? "active-sub" : ""}>Asesoramiento Estratégico</a>
          </li>
        </ul>
      </li>

      <li class={`navbar__item navbar__item--has-dropdown ${isParentActive("/cuaderno") ? "active" : ""}`}>
        <div class="navbar__item-row">
            <a href="/cuaderno">Cuaderno</a>
            <button class="dropdown-trigger" aria-label="Toggle submenu">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"></path></svg>
            </button>
        </div>
        <ul class="navbar__dropdown">
          <li>
            <a href="/cuaderno/guia-pac-ecorregimenes" class={isActive("/cuaderno/guia-pac-ecorregimenes") ? "active-sub" : ""}>Guía Ecorregímenes 2024</a>
          </li>
          <li>
            <a href="/cuaderno/informacion-comunidades" class={isActive("/cuaderno/informacion-comunidades") ? "active-sub" : ""}>Directorio CUE/SIEX</a>
          </li>
        </ul>
      </li>


      <li class={`navbar__item ${isActive("/blog") ? "active" : ""}`}><a href="/blog">Blog</a></li>
      <li class={`navbar__item ${isActive("/contacto") ? "active" : ""}`}><a href="/contacto">Contacto</a></li>
      <li class="navbar__item navbar__item--access">
        <a href="https://smartfenixagro.com/login?next=%2F" class="access-link">
          Acceder a SmartAgro
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  // Usar un flag para evitar duplicar listeners con transition:persist
  if (!(window as any).__navbarInitialized) {
    (window as any).__navbarInitialized = true;

    function closeMenu() {
      const menu = document.getElementById("navMenu");
      const toggle = document.getElementById("navToggle");
      menu?.classList.remove("navbar__menu--open");
      toggle?.classList.remove("navbar__toggle--active");
      document.body.style.overflow = "";
      document.body.classList.remove("menu-is-open");
      // Limpiar TODOS los dropdowns abiertos
      document.querySelectorAll('.dropdown--open').forEach(el => {
        el.classList.remove('dropdown--open');
      });
    }

    // Delegación de eventos para todo el menú
    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (!t) return;

      // === HAMBURGER TOGGLE ===
      const toggleBtn = t.closest('#navToggle');
      if (toggleBtn) {
        const menu = document.getElementById("navMenu");
        const isOpen = menu?.classList.toggle("navbar__menu--open");
        toggleBtn.classList.toggle("navbar__toggle--active");
        
        if (isOpen) {
            document.body.style.overflow = "hidden";
            document.body.classList.add("menu-is-open");
        } else {
            document.body.style.overflow = "";
            document.body.classList.remove("menu-is-open");
            document.querySelectorAll('.dropdown--open').forEach(el => {
                el.classList.remove('dropdown--open');
            });
        }
        return;
      }

      // === MOBILE: Click en un ítem con dropdown ===
      // Solo aplica en móvil (≤1024px)
      if (window.innerWidth <= 1024) {
        const parentItem = t.closest('.navbar__item--has-dropdown');
        
        // Skip Tecnología — no tiene dropdown en móvil
        if (parentItem && parentItem.classList.contains('navbar__item--tech')) {
          // Dejar que el clic en el <a> navegue normalmente
          const clickedLink = t.closest('.navbar__item-row > a');
          if (clickedLink) {
            setTimeout(closeMenu, 100);
          }
          return;
        }

        if (parentItem) {
          const clickedLink = t.closest('.navbar__item-row > a');
          const isAlreadyOpen = parentItem.classList.contains('dropdown--open');
          
          // Si el dropdown NO está abierto → abrirlo (no navegar)
          if (!isAlreadyOpen) {
            e.preventDefault();
            // Cerrar otros
            document.querySelectorAll('.navbar__item--has-dropdown').forEach(item => {
              if (item !== parentItem) item.classList.remove('dropdown--open');
            });
            parentItem.classList.add('dropdown--open');
            return;
          }
          
          // Si el dropdown YA está abierto:
          if (clickedLink) {
            // Click en el texto → navegar y cerrar menú
            setTimeout(closeMenu, 100);
            return;
          } else {
            // Click en flecha/fondo → cerrar dropdown
            parentItem.classList.remove('dropdown--open');
            return;
          }
        }

        // Click en un sub-enlace del dropdown → navegar y cerrar
        const subLink = t.closest('.navbar__dropdown a');
        if (subLink) {
          setTimeout(closeMenu, 100);
          return;
        }

        // Click en Blog/Contacto (sin dropdown) → navegar y cerrar
        const directLink = t.closest('#navMenu > .navbar__item:not(.navbar__item--has-dropdown) a');
        if (directLink) {
          setTimeout(closeMenu, 100);
          return;
        }
      }
    });

    // Scroll: navbar shadow
    window.addEventListener("scroll", () => {
      const nav = document.getElementById("navbar");
      if (window.scrollY > 40) {
        nav?.classList.add("navbar--scrolled");
      } else {
        nav?.classList.remove("navbar--scrolled");
      }
    });
  }

  // Limpiar estado al cargar nueva página (View Transitions)
  document.addEventListener("astro:page-load", () => {
    const menu = document.getElementById("navMenu");
    const toggle = document.getElementById("navToggle");
    menu?.classList.remove("navbar__menu--open");
    toggle?.classList.remove("navbar__toggle--active");
    document.body.style.overflow = "";
    document.querySelectorAll('.dropdown--open').forEach(el => {
      el.classList.remove('dropdown--open');
    });
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 80px;
    background: #0B1A14;
    z-index: 1000;
    display: flex;
    align-items: center;
    transition: background 0.3s ease;
  }

  /* RESETS AGRESIVOS PARA ELIMINAR CUALQUIER SUBRAYADO */
  .navbar a, 
  .navbar__item a,
  .navbar__item.active a,
  .navbar__menu a {
    text-decoration: none !important;
    border: none !important;
    border-bottom: none !important;
    box-shadow: none !important;
    outline: none !important;
  }

  .navbar--scrolled {
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }

  .navbar__content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .navbar__brand {
    display: flex;
    align-items: center;
    order: 1;
  }

  .navbar__menu {
    display: flex;
    align-items: center;
    gap: 12px;
    order: 2;
    margin-left: auto;
    flex-wrap: nowrap !important;
    flex-shrink: 0;
  }

  .navbar__right-actions {
    display: flex;
    align-items: center;
    gap: 15px;
    order: 3;
    margin-left: 25px;
  }

  .admin-access-btn {
    color: rgba(255,255,255,0.25);
    display: flex;
    align-items: center;
    transition: all 0.3s ease;
  }

  .admin-access-btn:hover {
    color: var(--color-turquoise);
    transform: scale(1.1);
  }

  .navbar__logo img {
    height: 44px;
    width: auto;
  }

  .navbar__center-title {
    display: none;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .navbar__center-title a {
    color: white !important;
    font-weight: 850;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    text-decoration: none !important;
  }

  .navbar__item {
    position: relative;
  }

  .navbar__item-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .dropdown-trigger {
    display: none; /* Solo en móvil */
    background: none;
    border: none;
    color: #FFFFFF;
    padding: 8px;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .navbar__item > .navbar__item-row a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    font-size: 0.95rem;
    font-weight: 600;
    transition: var(--transition);
    color: #FFFFFF;
  }

  /* Blog, Contacto — enlaces directos sin dropdown */
  .navbar__item:not(.navbar__item--has-dropdown):not(.navbar__item--access) > a {
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    font-size: 0.95rem;
    font-weight: 600;
    color: #FFFFFF;
    transition: var(--transition);
  }
  .navbar__item:not(.navbar__item--has-dropdown):not(.navbar__item--access) > a:hover {
    color: var(--color-turquoise);
  }

  .navbar__dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 280px;
    background: var(--color-white);
    padding: 12px;
    border-radius: 12px;
    box-shadow: var(--shadow-xl);
    border: 1px solid var(--color-gray-100);
    margin-top: 0;
  }

  /* Solo en dispositivos con ratón real — NUNCA en móvil táctil */
  @media (hover: hover) {
    .navbar__item--has-dropdown:hover .navbar__dropdown {
      display: block;
      animation: fadeIn 0.2s ease;
    }
  }

  .navbar__dropdown li a {
    display: block;
    padding: 10px 16px;
    font-size: 0.9rem;
    color: var(--color-gray-700);
    border-radius: 8px;
    text-decoration: none !important;
    border: none !important;
  }

  .navbar__dropdown li a:hover,
  .navbar__dropdown li a.active-sub {
    background: var(--color-gray-50);
    color: var(--color-turquoise);
  }

  .navbar__toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .navbar__toggle span {
    background: #FFFFFF;
    width: 25px;
    height: 2px;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 1024px) {
    /* === NAVBAR BAR === */
    .navbar {
      position: fixed !important;
      background: #0B1A14 !important;
      height: 60px !important;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 10000;
    }
    .navbar__brand {
      padding-left: 0;
      flex: 0 0 auto;
    }
    .navbar__center-title {
      display: none !important; /* Hide to prevent collision on mobile */
    }
    .navbar__right-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-left: auto;
      flex: 0 0 auto;
    }
    .admin-access-btn {
      color: rgba(255,255,255,0.7);
      display: flex;
      align-items: center;
      margin-right: 4px;
    }
    .admin-access-btn:hover {
      color: var(--color-turquoise);
    }
    .navbar__logo img {
      height: 32px !important;
    }

    /* === HAMBURGER TOGGLE === */
    .navbar__toggle { 
      display: flex;
      padding-right: 15px;
      gap: 5px;
    }
    .navbar__toggle span { 
      width: 22px;
      height: 2px;
      display: block;
      transition: transform 0.3s ease, opacity 0.3s ease;
    }
    .navbar__toggle--active span:first-child { 
      transform: translateY(7px) rotate(45deg); 
    }
    .navbar__toggle--active span:nth-child(2) { 
      opacity: 0; 
    }
    .navbar__toggle--active span:last-child { 
      transform: translateY(-7px) rotate(-45deg); 
    }

    /* === FULL-SCREEN SLIDE-IN MENU === */
    .navbar__menu {
      display: flex !important;
      flex-direction: column !important;
      align-items: stretch !important;
      position: fixed !important;
      top: 60px !important;
      left: 0 !important;
      right: 0 !important;
      bottom: 0 !important;
      width: 100% !important;
      height: auto !important;
      min-height: calc(100dvh - 60px) !important;
      background: #0B1A14 !important;
      padding: 0 !important;
      margin: 0 !important;
      gap: 0 !important;
      overflow-y: auto !important;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior: contain;
      z-index: 9999 !important;
      list-style: none !important;
      transform: translateX(100%);
      visibility: hidden;
      pointer-events: none;
      transition: transform 0.3s ease, visibility 0.3s;
      text-align: left !important; /* Force left alignment against global container rules */
    }
    .navbar__menu--open { 
      transform: translateX(0) !important;
      visibility: visible !important;
      pointer-events: all !important;
    }

    /* === EACH MENU ITEM (full width, stacked) === */
    .navbar__item {
      width: 100% !important;
      display: block !important;
      position: static !important;
    }

    /* === ITEM ROW (label + arrow) === */
    .navbar__item-row {
      display: flex !important;
      width: 100% !important;
      align-items: center !important;
      justify-content: space-between !important;
      padding: 0 24px !important;
      border-bottom: 1px solid rgba(255,255,255,0.08) !important;
    }
    .navbar__item-row a { 
      display: block !important;
      font-size: 1.15rem !important;
      font-weight: 600 !important;
      padding: 18px 0 !important;
      color: #FFFFFF !important;
      /* NO flex:1 → deja espacio libre en la fila para abrir el dropdown al tocarlo */
    }
    /* Toda la fila es táctil para abrir dropdown */
    .navbar__item-row {
      cursor: pointer;
    }

    /* === DROPDOWN ARROW BUTTON === */
    .dropdown-trigger {
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      width: 48px !important;
      height: 48px !important;
      padding: 0 !important;
      background: none !important;
      border: none !important;
      color: rgba(255,255,255,0.5) !important;
      cursor: pointer !important;
    }
    .dropdown-trigger svg {
      transition: transform 0.3s ease !important;
    }
    .navbar__item--has-dropdown.dropdown--open .dropdown-trigger svg {
      transform: rotate(180deg) !important;
    }
    .navbar__item--has-dropdown.dropdown--open .dropdown-trigger {
      color: var(--color-turquoise) !important;
    }

    /* === DROPDOWN SUBMENU — RESET EVERY DESKTOP PROP === */
    .navbar__dropdown {
      display: none !important;
      position: static !important;
      top: auto !important;
      left: auto !important;
      min-width: 0 !important;
      width: 100% !important;
      background: rgba(255,255,255,0.04) !important;
      padding: 0 !important;
      margin: 0 !important;
      border-radius: 0 !important;
      border: none !important;
      box-shadow: none !important;
      list-style: none !important;
      visibility: visible !important;
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
    .navbar__item--has-dropdown.dropdown--open .navbar__dropdown {
      display: block !important;
    }
    /* Kill desktop hover behavior */
    .navbar__item--has-dropdown:hover .navbar__dropdown {
      display: none !important;
    }
    .navbar__item--has-dropdown.dropdown--open:hover .navbar__dropdown {
      display: block !important;
    }

    /* === TECNOLOGÍA: sin submenu en móvil === */
    .navbar__item--tech .navbar__dropdown,
    .navbar__item--tech .dropdown-trigger {
      display: none !important;
    }
    .navbar__item--tech .navbar__item-row {
      cursor: default !important;
    }

    /* === DROPDOWN LINKS === */
    .navbar__dropdown li {
      list-style: none !important;
    }
    .navbar__dropdown li a {
      display: block !important;
      padding: 14px 24px 14px 44px !important;
      font-size: 1rem !important;
      font-weight: 400 !important;
      color: rgba(255,255,255,0.75) !important;
      border-bottom: 1px solid rgba(255,255,255,0.04) !important;
      border-radius: 0 !important;
      background: none !important;
    }

    /* === ITEMS WITHOUT DROPDOWNS (Blog, Contacto) === */
    .navbar__item:not(.navbar__item--has-dropdown):not(.navbar__item--access) > a {
      display: block !important;
      font-size: 1.15rem !important;
      font-weight: 600 !important;
      padding: 18px 24px !important;
      color: #FFFFFF !important;
      border-bottom: 1px solid rgba(255,255,255,0.08) !important;
    }

    /* === ACCEDER LINK === */
    .navbar__item--access {
      margin-top: 16px !important;
      padding: 0 24px !important;
    }
    .navbar__item--access .access-link {
      display: block !important;
      text-align: left !important;
      padding: 16px 24px !important;
      font-size: 1rem !important;
      border: 1px solid var(--color-turquoise) !important;
      border-radius: 8px !important;
      text-decoration: none !important;
      min-width: auto !important;
    }
  }

  /* BLOQUEO DE SCROLL EN BODY CUANDO MENU ESTÁ ABIERTO */
  :global(body.menu-is-open) {
    overflow: hidden !important;
    position: fixed !important;
    width: 100% !important;
    height: 100dvh !important;
  }

  /* ESTILO ÚNICO ACCEDER SMARTAGRO */
  .access-link {
    display: inline-block !important;
    min-width: 175px !important;
    white-space: nowrap !important;
    color: var(--color-turquoise) !important;
    position: relative;
    font-weight: 700 !important;
    padding: 8px 16px !important;
    text-decoration: underline !important;
    text-underline-offset: 6px !important;
    text-decoration-thickness: 2px !important;
    transition: all 0.3s ease !important;
  }

  .access-link:hover {
    text-underline-offset: 8px !important;
    text-decoration-thickness: 3px !important;
  }
</style>

<style is:global>
  /* FORZADO GLOBAL PARA EL MENÚ */
  .navbar__item a, 
  .navbar__item.active a,
  .navbar__menu a,
  .navbar__logo,
  .navbar__logo img {
    text-decoration: none !important;
    border-bottom: none !important;
    border: none !important;
    box-shadow: none !important;
    outline: none !important;
  }

  .navbar__item a::before,
  .navbar__item a::after {
    display: none !important;
    content: none !important;
    border: none !important;
  }
</style>
