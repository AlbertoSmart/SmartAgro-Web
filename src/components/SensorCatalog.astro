---
const sensors = [
    {
        name: "Sensor Suelo Temp/Hum",
        specs: "Monitorización precisa de la temperatura y humedad radicular.",
        image: "/images/sensores/SensorTemperaturaHumedadSuelo.png",
        category: "Suelo",
        href: "/sensores/suelo-humedad-temp"
    },
    {
        name: "Sensor pH de Suelo",
        specs: "Control electroquímico del potencial de hidrógeno edáfico.",
        image: "/images/sensores/SensorphTemperaturaSuelo.png",
        category: "Suelo",
        href: "/sensores/suelo-ph"
    },
    {
        name: "Sensor de pH Alta Precisión",
        specs: "Medición ultra-precisa para aplicaciones críticas en suelo y agua.",
        image: "/images/sensores/SensorDePhAltaPrecision.png",
        category: "Suelo/Agua",
        href: "/sensores/suelo-ph-precision"
    },
    {
        name: "Sensor CO2 Suelo",
        specs: "Monitoreo de la respiración del suelo y actividad microbiana.",
        image: "/images/sensores/SensorCO2.png",
        category: "Suelo",
        href: "/sensores/suelo-co2"
    },
    {
        name: "Sensor Oxígeno Suelo",
        specs: "Medición de permeabilidad y salud radicular.",
        image: "/images/sensores/SensorOxigenoSuelo.png",
        category: "Suelo",
        href: "/sensores/suelo-oxigeno"
    },
    {
        name: "Sensor Suelo 8 en 1",
        specs: "NPK, Fósforo, PH, EC, Temp, Hum, Salinidad.",
        image: "/images/sensores/SensorSuelo8en1.png",
        category: "Suelo",
        href: "/sensores/suelo-8en1"
    },
    {
        name: "Sensor Tubular Multicapa",
        specs: "Perfil vertical de temperatura y humedad en múltiples profundidades.",
        image: "/images/sensores/SensorTubularHumeadytemperaturaEnDistintasCapas.png",
        category: "Suelo",
        href: "/sensores/suelo-tubular"
    },
    {
        name: "Dendrómetro de Tronco",
        specs: "Medición de variaciones micro-métricas del diámetro del tronco.",
        image: "/images/sensores/DendometroTronco.png",
        category: "Planta",
        href: "/sensores/planta-dendrometro-tronco"
    },
    {
        name: "Dendrómetro de Fruto",
        specs: "Crecimiento del fruto en tiempo real para optimización de cosecha.",
        image: "/images/sensores/dendometroFruto2.png",
        category: "Planta",
        href: "/sensores/planta-dendrometro-fruto"
    },
    {
        name: "Sensor de Hoja Temp/Hum",
        specs: "Monitorización de humectación foliar para prevención de plagas.",
        image: "/images/sensores/SensorHojaChinosTemperaturayHumedad.png",
        category: "Planta",
        href: "/sensores/planta-hoja-humectacion"
    },
    {
        name: "Sensor Temperatura Hoja",
        specs: "Medición directa del estrés térmico en el follaje.",
        image: "/images/sensores/SensorHojaChinosTemperaturayHumedad.png", // Reuse image as specifically mentioned for Temp/Hum leaf
        category: "Planta",
        href: "/sensores/planta-temp-hoja"
    },
    {
        name: "Estación Meteorológica",
        specs: "Viento, lluvia, radiación UV y presión atmosférica.",
        image: "/images/sensores/EstacionMeteorologica.png",
        category: "Clima",
        href: "/sensores/clima-estacion"
    },
    {
        name: "Sensor Nivel de Agua",
        specs: "Presión hidrostática para control de depósitos y canales.",
        image: "/images/sensores/SensorNivelAgua.png",
        category: "Riego",
        href: "/sensores/agua-nivel"
    }
];
---

<section class="sensor-catalog section-padding" id="sensores">
    <div class="container">
        <div class="sensor-catalog__header text-center">
            <span class="sensor-catalog__pretitle"
                >Ecosistema Hardware</span
            >
            <h2 class="section-title">Sensores para cada rincón de tu finca</h2>
            <p class="section-subtitle">
                Una gama completa de dispositivos de alta precisión diseñados
                para digitalizar y optimizar cada parámetro crítico de tu
                explotación.
            </p>
        </div>

        <div class="sensor-catalog__grid">
            {
                sensors.map((sensor) => (
                    <a href={sensor.href} class="sensor-card glass">
                        <div class="sensor-card__badge">{sensor.category}</div>
                        <div class="sensor-card__image">
                            <img src={sensor.image} alt={sensor.name} loading="lazy" />
                        </div>
                        <h3 class="sensor-card__name">{sensor.name}</h3>
                        <p class="sensor-card__specs">{sensor.specs}</p>
                    </a>
                ))
            }
        </div>
    </div>
</section>

<style>
    .sensor-catalog {
        background: var(--color-dark);
        color: var(--color-white);
        position: relative;
        overflow: hidden;
    }

    .sensor-catalog__header {
        margin-bottom: 60px;
    }

    .sensor-catalog__header .section-title {
        color: var(--color-white);
    }

    .sensor-catalog__grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 24px;
    }

    .sensor-card {
        padding: 32px;
        border-radius: var(--border-radius-md);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: var(--transition);
        position: relative;
        text-align: center;
        text-decoration: none;
        display: block;
    }

    .sensor-card:hover {
        background: rgba(255, 255, 255, 0.1);
        transform: translateY(-5px);
        border-color: #FFFFFF;
    }

    .sensor-card__badge {
        position: absolute;
        top: 16px;
        right: 16px;
        font-size: 0.7rem;
        padding: 4px 10px;
        background: rgba(255, 255, 255, 0.8);
        color: #000000;
        border-radius: 20px;
        font-weight: 700;
        text-transform: uppercase;
        z-index: 2;
    }

    .sensor-card__image {
        width: 100%;
        height: 160px;
        margin-bottom: 24px;
        border-radius: var(--border-radius-sm);
        overflow: hidden;
        background: rgba(0, 0, 0, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .sensor-card__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .sensor-card:hover .sensor-card__image img {
        transform: scale(1.1);
    }

    .sensor-card__name {
        font-size: 1.25rem;
        margin-bottom: 8px;
        color: var(--color-white);
    }

    .sensor-card__specs {
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.4;
    }

    @media (max-width: 768px) {
        .sensor-catalog__grid {
            grid-template-columns: 1fr;
        }
    }
</style>
