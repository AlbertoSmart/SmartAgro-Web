---
const sensors = [
    {
        name: "Sensor Suelo Temp/Hum",
        specs: "Monitorización de precisión radicular.",
        image: "/images/sensores/SensorTemperaturaHumedadSuelo.png",
        category: "Suelo",
        href: "/sensores/suelo-humedad-temp"
    },
    {
        name: "Sensor pH de Suelo",
        specs: "Control electroquímico edáfico.",
        image: "/images/sensores/SensorphTemperaturaSuelo.png",
        category: "Suelo",
        href: "/sensores/suelo-ph"
    },
    {
        name: "Sensor de pH Alta Precisión",
        specs: "Medición crítica en suelo y agua.",
        image: "/images/sensores/SensorDePhAltaPrecision.png",
        category: "Suelo",
        href: "/sensores/suelo-ph-precision"
    },
    {
        name: "Sensor CO2 Suelo",
        specs: "Respiración y actividad microbiana.",
        image: "/images/sensores/SensorCO2.png",
        category: "Suelo",
        href: "/sensores/suelo-co2"
    },
    {
        name: "Sensor Oxígeno Suelo",
        specs: "Permeabilidad y salud radicular.",
        image: "/images/sensores/SensorOxigenoSuelo.png",
        category: "Suelo",
        href: "/sensores/suelo-oxigeno"
    },
    {
        name: "Sensor Suelo 8 en 1",
        specs: "Analítica completa de nutrientes.",
        image: "/images/sensores/SensorSuelo8en1.png",
        category: "Suelo",
        href: "/sensores/suelo-8en1"
    },
    {
        name: "Sensor Tubular Multicapa",
        specs: "Perfil vertical multi-profundidad.",
        image: "/images/sensores/SensorTubularHumeadytemperaturaEnDistintasCapas.png",
        category: "Suelo",
        href: "/sensores/suelo-tubular"
    },
    {
        name: "Dendrómetro de Tronco",
        specs: "Variaciones micro-métricas de tronco.",
        image: "/images/sensores/DendometroTronco.png",
        category: "Planta",
        href: "/sensores/planta-dendrometro-tronco"
    },
    {
        name: "Dendrómetro de Fruto",
        specs: "Crecimiento de fruto en tiempo real.",
        image: "/images/sensores/dendometroFruto2.png",
