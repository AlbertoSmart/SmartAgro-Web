        category: "Planta",
        href: "/sensores/planta-hoja-humectacion"
    },
    {
        name: "Sensor Temperatura Hoja",
        specs: "Estrés térmico directo en follaje.",
        image: "/images/sensores/SensorHojaChinosTemperaturayHumedad.png",
        category: "Planta",
        href: "/sensores/planta-temp-hoja"
    },
    {
