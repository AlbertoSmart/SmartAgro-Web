        image: "/images/sensores/SensorNivelAgua.png",
        category: "Clima",
        href: "/sensores/agua-nivel"
    }
];

const categories = [
    { title: "Monitorización de Suelo", key: "Suelo" },
    { title: "Fisiología Vegetal", key: "Planta" },
    { title: "Clima e Hidrología", key: "Clima" }
];
---

<section class="sensor-catalog section-padding" id="sensores">
    <div class="container overflow-visible">
        <div class="sensor-catalog__header">
            <div class="header-main feature-card animated">
                <span class="catalog-badge">Precisión loRaWAN & 4G</span>
                <h2 class="balanced-title">Hardware de Precisión</h2>
                <p class="balanced-subtitle">Monitorización continua que transforma datos en decisiones rentables.</p>
            </div>
        </div>

        {categories.map((cat, idx) => {
            const filteredSensors = sensors.filter(s => s.category.includes(cat.key));
            const duration = filteredSensors.length * 8; // 8 segundos por item para velocidad constante
            return (
                <div class="fluid-category" data-category={cat.key}>
                    <div class="category-header-row">
                        <div class="category-label">
                            <span class="category-idx">0{idx + 1}</span>
                            <h3>{cat.title}</h3>
                        </div>
                        <div class="slider-nav">
                            <button class="nav-arrow prev" aria-label="Anterior">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5m0 0l7 7m-7-7l7-7"/></svg>
                            </button>
                            <button class="nav-arrow next" aria-label="Siguiente">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m0 0l-7-7m7 7l-7 7"/></svg>
                            </button>
                        </div>
                    </div>

                    <div class="slider-outer-fluid">
                        <div class="slider-track-fluid" id={`track-${idx}`} style={`animation-duration: ${duration}s`}>
                            {/* Triplicamos el contenido para el bucle infinito continuo e invisible */}
                            {[...filteredSensors, ...filteredSensors, ...filteredSensors].map((sensor) => (
                                <div class="slider-item-balanced">
                                    <a href={sensor.href} class="balanced-card">
                                        <div class="card-image-wrap">
                                            <img src={sensor.image} alt={sensor.name} loading="lazy" />
                                        </div>
                                        <div class="card-info">
                                            <h4>{sensor.name}</h4>
                                            <p>{sensor.specs}</p>
                                        </div>
                                    </a>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            );
        })}
    </div>
</section>

<style>
    .sensor-catalog {
        background: #FFFFFF;
        padding: 100px 0;
        overflow: hidden;
    }

    

    .header-main.feature-card {
        background: #FFFFFF;
        border: 1px solid #E9EEF2;
        border-radius: 20px;
        padding: 32px 28px;
        box-shadow: 0 14px 32px rgba(11, 26, 20, 0.07);
    }

    .header-main.animated {
        animation: fade-up 0.7s ease both;
    }

    @keyframes fade-up {
        from {
            opacity: 0;
            transform: translateY(14px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .catalog-badge {
        display: inline-block;
        padding: 5px 12px;
        background: rgba(11, 26, 20, 0.05);
        color: #0B1A14;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 18px;
    }

    .balanced-title {
        font-size: 2.8rem;
        font-weight: 900;
        color: #0B1A14;
        margin-bottom: 15px;
        letter-spacing: -0.02em;
    }

    .balanced-subtitle {
        font-size: 1.15rem;
        color: #666;
        line-height: 1.5;
        max-width: 600px;
    }

    .fluid-category {
        margin-bottom: 90px;
    }

    .fluid-category:last-child {
        margin-bottom: 0;
    }

    .category-header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 15px;
        border-bottom: 1px solid #F0F0F0;
    }

    .category-label {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .category-idx {
        font-size: 0.8rem;
        font-weight: 800;
        color: var(--color-turquoise);
        font-family: monospace;
    }

    .category-label h3 {
        font-size: 1.6rem;
        font-weight: 800;
        color: #0B1A14;
        letter-spacing: -0.01em;
    }

    .slider-nav {
        display: flex;
        gap: 10px;
    }

    .nav-arrow {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: 1px solid #EEE;
        background: #FFF;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        color: #0B1A14;
    }

    .nav-arrow:hover {
        background: #0B1A14;
        border-color: #0B1A14;
        color: #FFF;
        transform: scale(1.05);
    }

    .slider-outer-fluid {
        position: relative;
        width: 100%;
    }

    .slider-track-fluid {
        display: flex;
        gap: 30px;
        width: max-content;
        animation: scroll-fluid 30s linear infinite;
        will-change: transform;
    }

    .slider-track-fluid:hover {
        animation-play-state: paused;
    }

    @keyframes scroll-fluid {
        0% { transform: translateX(0); }
        100% { transform: translateX(calc(-33.333% - 13.333px)); } /* 13.333px es el gap ajustado al triplicado */
    }

    /* Cooldown interactivo */
    .slider-track-fluid.is-paused-by-user {
        animation-play-state: paused !important;
    }

    .slider-item-balanced {
        flex: 0 0 360px;
    }

    .balanced-card {
        text-decoration: none;
        display: block;
        background: #FFF;
        border: 1px solid #F0F0F0;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
        height: 100%;
    }

    .balanced-card:hover {
        border-color: var(--color-turquoise);
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
    }

    .card-image-wrap {
        width: 100%;
        height: 180px;
        background: #F9F9F9;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px;
    }

    .card-image-wrap img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        transition: transform 0.6s ease;
    }

    .balanced-card:hover .card-image-wrap img {
        transform: scale(1.1);
    }

    .card-info {
        padding: 25px;
    }

    .card-info h4 {
        font-size: 1.25rem;
        font-weight: 800;
        color: #0B1A14;
        margin-bottom: 8px;
    }

    .card-info p {
        font-size: 0.95rem;
        color: #666;
        line-height: 1.5;
    }

    @media (max-width: 768px) {
        .slider-track-fluid { gap: 15px; }
        .slider-item-balanced { flex: 0 0 170px; }
        .balanced-card { border-radius: 12px; }
        .card-image-wrap { height: 110px; padding: 15px; }
        .card-info { padding: 12px; }
        .card-info h4 { font-size: 0.9rem; margin-bottom: 4px; }
        .card-info p { font-size: 0.75rem; line-height: 1.3; }
        .balanced-title { font-size: 1.8rem; }
        .category-label h3 { font-size: 1.2rem; }
        .sensor-catalog { padding: 60px 0; }
        .fluid-category { margin-bottom: 50px; }
        .fluid-category:last-child { margin-bottom: 0; }
    }
</style>

<script>
    function setupFluidSlider() {
        const sections = document.querySelectorAll('.fluid-category');
        
        sections.forEach((section, idx) => {
            const track = section.querySelector('.slider-track-fluid') as HTMLElement;
            const prevBtn = section.querySelector('.nav-arrow.prev');
            const nextBtn = section.querySelector('.nav-arrow.next');
            
            if (!track || !prevBtn || !nextBtn) return;
            const card = track.querySelector('.slider-item-balanced') as HTMLElement;
            if (!card) return;

            let currentDelay = 0;
            let pauseTimeout: any = null;
            // Obtenemos la duración calculada del atributo (o recalculamos)
            const durationStyle = window.getComputedStyle(track).animationDuration;
            const durationVal = parseFloat(durationStyle) || 30;

            const shiftAnimation = (direction: number) => {
                const gap = parseFloat(window.getComputedStyle(track).gap) || 30;
                const stepPixels = card.offsetWidth + gap; 
                const trackWidth = track.scrollWidth / 3; 
                const timeShift = (stepPixels / trackWidth) * durationVal;
                
                currentDelay += (direction * timeShift);
                track.style.animationDelay = `${currentDelay}s`;

                // Cooldown de 1s
                track.classList.add('is-paused-by-user');
                if (pauseTimeout) clearTimeout(pauseTimeout);
                pauseTimeout = setTimeout(() => {
                    track.classList.remove('is-paused-by-user');
                }, 1000);
            };

            nextBtn.addEventListener('click', () => shiftAnimation(-1));
            prevBtn.addEventListener('click', () => shiftAnimation(1));
        });
    }

    document.addEventListener('astro:page-load', setupFluidSlider);
</script>

