<style>
  .topbar {
    position: relative;
    z-index: 1001;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    background: #0B1A14;
  }

  .topbar__content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 24px;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .topbar__left,
  .topbar__right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .topbar__divider {
    opacity: 0.2;
  }

  .topbar__item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: inherit;
    transition: var(--transition);
  }

  .topbar__item:hover {
    color: var(--color-turquoise);
  }

  .topbar__social {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .topbar__social a {
    color: inherit;
    transition: var(--transition);
  }

  .topbar__social a:hover {
    color: var(--color-white);
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .topbar {
      display: none;
    }
  }
</style>
