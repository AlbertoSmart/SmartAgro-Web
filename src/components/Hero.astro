---
---

<section class="hero" id="hero" transition:persist="home-hero">
  <div
    class="hero__bg hero-bg"
    aria-hidden="true"
    transition:persist="home-hero-bg"
  ></div>
  <div
    class="hero__overlay hero-overlay"
    aria-hidden="true"
    transition:persist="home-hero-overlay"
  ></div>
  <div class="hero__content container">
    <div class="hero__text">
      <h1 class="hero__title">
        Gestión de Finca y Cuaderno de Campo Digital con Datos Reales
      </h1>
      <p class="hero__subtitle">
        Optimización de insumos en tiempo real y cumplimiento normativo SIEX
        mediante sensores de precisión y mapas GIS.
      </p>
      <div class="hero__actions">
        <a href="/contacto" class="btn btn--turquoise">
          Solicitar Demo Gratuita
        </a>
      </div>
    </div>

    <div class="hero__image">
      <img
        src="https://images.pexels.com/photos/2933243/pexels-photo-2933243.jpeg?auto=compress&cs=tinysrgb&w=800&h=800&fit=crop"
        alt="Agricultor real trabajando en su finca"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: #0B1A14;
    color: #FFFFFF;
    padding: 160px 0 100px;
    isolation: isolate;
  }

  .hero__bg,
  .hero__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__bg {
    z-index: 0;
    background: url("/images/imagenportada.jpg") center 46% / cover no-repeat;
    transform: scale(1);
  }

  .hero__overlay {
    background: rgba(11, 26, 20, 0.78);
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .hero__title {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    line-height: 1.15;
    font-weight: 800;
    margin-bottom: 24px;
    letter-spacing: -0.03em;
    color: #FFFFFF;
  }

  .hero__subtitle {
    font-size: 1.2rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 40px;
    max-width: 520px;
  }

  .hero__actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn--outline-white {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--border-radius-md);
    cursor: pointer;
    transition: var(--transition);
    background: transparent;
    color: #FFFFFF;
    border: 2px solid rgba(255, 255, 255, 0.3);
  }

  .btn--outline-white:hover {
    background: #FFFFFF;
    color: #0B1A14;
    border-color: #FFFFFF;
    transform: translateY(-3px) scale(1.02);
    box-shadow: var(--shadow-lg);
  }

  .hero__image {
    display: flex;
    justify-content: flex-end;
  }

  .hero__image img {
    width: 100%;
    max-width: 400px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 16px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
  }

  @media (max-width: 900px) {
    .hero__content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
    }
    .hero__subtitle {
      margin-left: auto;
      margin-right: auto;
    }
    .hero__actions {
      justify-content: center;
    }
    .hero__image {
      justify-content: center;
    }
    .hero__image img {
      max-width: 300px;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 120px 0 60px;
    }
    .hero__actions {
      flex-direction: column;
      width: 100%;
    }
    .hero__actions .btn,
    .hero__actions .btn--outline-white {
      width: 100%;
      justify-content: center;
    }
    .hero__image img {
      max-width: 100%;
    }
  }
</style>
