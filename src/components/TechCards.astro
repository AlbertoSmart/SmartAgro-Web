---
const techCards = [
  {
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="#1DB99A" stroke-width="2"><path d="M24 6C13 6 4 14 4 24c0 6 3 11 8 14"/><path d="M24 6c11 0 20 8 20 18 0 6-3 11-8 14"/><circle cx="24" cy="24" r="6"/><path d="M24 18v-6M24 36v-6M18 24h-6M36 24h-6"/></svg>`,
    title: "Sinergias Agrotech",
    text: "Integramos soluciones líderes como el autoguiado RTK de FieldBee y los modelos preventivos de plagas de IPMwise directamente en tu plataforma.",
  },
  {
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="#1DB99A" stroke-width="2"><rect x="14" y="4" width="20" height="40" rx="3"/><line x1="14" y1="12" x2="34" y2="12"/><line x1="14" y1="36" x2="34" y2="36"/><circle cx="24" cy="40" r="2"/><path d="M8 18l-4 4 4 4"/><path d="M40 18l4 4-4 4"/></svg>`,
    title: "Aval de Ingeniería Oficial",
    text: "En alianza con el Consejo de Ingenieros Agrónomos, ofrecemos auditorías legales, peritajes ante administraciones y certificaciones PAC de máxima validez.",
  },
  {
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="#1DB99A" stroke-width="2"><rect x="4" y="8" width="40" height="32" rx="2"/><path d="M4 16h40"/><circle cx="16" cy="28" r="5"/><path d="M22 24l8-2 6 6 4-4"/><rect x="26" y="30" width="12" height="6" rx="1"/></svg>`,
    title: "Formación e Información",
    text: "Accede a nuestra hemeroteca técnica con guías sobre el SIEX, manuales de ecorregímenes y artículos exclusivos de expertos sobre el sector agrario.",
  },
];
---

<section class="tech section-padding" id="tech">
  <div class="container">
    <div class="tech__cards">
      {
        techCards.map((tc) => (
          <article class="tech-card card">
            <div class="tech-card__icon">
              <Fragment set:html={tc.icon} />
            </div>
            <h3 class="tech-card__title">{tc.title}</h3>
            <p class="tech-card__text">{tc.text}</p>
          </article>
        ))
      }
    </div>

    <!-- Leaf Silhouette -->
    <div class="tech__leaf">
      <svg viewBox="0 0 200 300" fill="none" opacity="0.06">
        <path
          d="M100 290 C40 240 10 160 10 100 C10 40 50 10 100 10 C150 10 190 40 190 100 C190 160 160 240 100 290Z"
          fill="#1DB99A"></path>
        <line
          x1="100"
          y1="290"
          x2="100"
          y2="80"
          stroke="#1DB99A"
          stroke-width="3"></line>
        <path
          d="M100 180 C80 160 60 150 40 140"
          stroke="#1DB99A"
          stroke-width="2"
          fill="none"></path>
        <path
          d="M100 140 C120 120 140 110 160 100"
          stroke="#1DB99A"
          stroke-width="2"
          fill="none"></path>
      </svg>
    </div>

    <div class="tech__intro">
      <h2 class="section-title section-title--with-line">
        Tecnología al servicio del agricultor profesional
      </h2>
      <p class="tech__intro-text">
        Más que tecnología, entregamos certidumbre técnica. Nuestro ecosistema integra la captura de datos en tiempo real con el asesoramiento de ingenieros expertos para que la digitalización no sea solo una obligación legal, sino tu mayor ventaja competitiva. Desde la telemetría RAW hasta la firma del Cuaderno SIEX, controlamos todo el ciclo tecnológico de tu explotación.
      </p>
    </div>
  </div>
</section>

<style>
  .tech {
    background: var(--color-white);
    position: relative;
    overflow: hidden;
  }

  .tech__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-bottom: 60px;
  }

  .tech-card {
    padding: 32px 24px;
    text-align: center;
    border: 1px solid var(--color-gray-200);
    position: relative;
    z-index: 2;
  }

  .tech-card__icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 18px;
  }

  .tech-card__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .tech-card__title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-charcoal);
    margin-bottom: 12px;
  }

  .tech-card__text {
    font-size: 0.92rem;
    color: var(--color-gray-500);
    line-height: 1.65;
  }

  .tech__leaf {
    position: absolute;
    right: -40px;
    bottom: 0;
    width: 280px;
    height: 400px;
    pointer-events: none;
    z-index: 1;
  }

  .tech__leaf svg {
    width: 100%;
    height: 100%;
  }

  .tech__intro {
    position: relative;
    z-index: 2;
    max-width: 800px;
  }

  .tech__intro-text {
    font-size: 1rem;
    color: var(--color-gray-500);
    line-height: 1.75;
    margin-top: 24px;
  }

  @media (max-width: 768px) {
    .tech__cards {
      grid-template-columns: 1fr;
    }
    .tech__leaf {
      display: none;
    }
  }
</style>
