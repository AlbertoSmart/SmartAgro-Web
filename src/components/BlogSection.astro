---
const blogPosts = [
  {
    id: "ia-campo-asesoramiento",
    image: "https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&q=80&w=800",
    category: "Inteligencia Artificial",
    title: "IA aplicada al campo: El futuro del asesoramiento",
    excerpt:
      "Cómo AgroAI está transformando la manera en que los agricultores interactúan con sus datos de telemetría de suelo y clima.",
  },
  {
    id: "ecorregimenes-siex-2026",
    image: "https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&q=80&w=800",
    category: "Normativa",
    title: "Ecorregímenes y SIEX: Guía de cumplimiento 2026",
    excerpt:
      "Analizamos las claves para certificar tus prácticas agrarias y asegurar la tramitación de las ayudas de la PAC sin errores.",
  },
  {
    id: "dendrometria-latido-arboles",
    image: "https://images.unsplash.com/photo-1523348837708-15d4a09cfac2?auto=format&fit=crop&q=80&w=800",
    category: "Tecnología",
    title: "Dendrometría: Escuchando el latido de tus árboles",
    excerpt:
      "La guía definitiva para entender el crecimiento del tronco y optimizar el riego deficitario controlado en leñosos.",
  },
];
---

<section class="blog section-padding" id="blog">
  <div class="container">
    <div class="blog__header">
      <h2 class="section-title">Nuestras últimas publicaciones</h2>
      <p class="section-subtitle">
        Mantente al día con las últimas novedades del sector agrario, normativas
        y actualizaciones de nuestro Ecosistema Digital Agrario.
      </p>
    </div>

    <div class="blog__grid">
      {
        blogPosts.map((post) => (
          <article class="blog-card card">
            <div class="blog-card__image">
              <img src={post.image} alt={post.title} loading="lazy" />
            </div>
            <div class="blog-card__body">
              <span class="blog-card__category">{post.category}</span>
              <h3 class="blog-card__title">{post.title}</h3>
              <p class="blog-card__excerpt">{post.excerpt}</p>
              <a href={`/blog/${post.id}`} class="blog-card__link">
                Leer más
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .blog {
    background: var(--color-gray-50);
  }

  .blog__header {
    margin-bottom: 48px;
    text-align: center;
  }

  .blog__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .blog-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    display: flex;
    flex-direction: column;
    transition: var(--transition);
  }

  .blog-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-turquoise);
  }

  .blog-card__image {
    height: 200px;
    overflow: hidden;
  }

  .blog-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .blog-card:hover .blog-card__image img {
    transform: scale(1.05);
  }

  .blog-card__body {
    padding: 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .blog-card__category {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-turquoise-dark);
    background: var(--color-gray-100);
    padding: 3px 10px;
    border-radius: 3px;
    margin-bottom: 12px;
    align-self: flex-start;
  }

  .blog-card__title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-charcoal);
    line-height: 1.4;
    margin-bottom: 10px;
  }

  .blog-card__excerpt {
    font-size: 0.88rem;
    color: var(--color-gray-500);
    line-height: 1.6;
    margin-bottom: 16px;
    flex: 1;
  }

  .blog-card__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-turquoise-dark);
    transition: var(--transition);
  }

  .blog-card__link:hover {
    gap: 10px;
    color: var(--color-turquoise);
  }

  @media (max-width: 1024px) {
    .blog__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .blog__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
