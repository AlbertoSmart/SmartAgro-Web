---
interface Sensor {
  name: string;
  specs: string;
  image: string;
  category: string;
  href: string;
}

interface Props {
  sensors: Sensor[];
  title: string;
}

const { sensors, title } = Astro.props;
---

<div class="carousel-container section-padding">
  <div class="container">
    <h3 class="carousel-title">{title}</h3>
    <div class="carousel-wrapper">
      <div class="carousel-track">
        {[...sensors, ...sensors].map((sensor) => (
          <a href={sensor.href} class="sensor-card-mini glass">
            <div class="sensor-card-mini__badge">{sensor.category}</div>
            <div class="sensor-card-mini__image">
              <img src={sensor.image} alt={sensor.name} loading="lazy" />
            </div>
            <div class="sensor-card-mini__content">
              <h4 class="sensor-card-mini__name">{sensor.name}</h4>
              <p class="sensor-card-mini__specs">{sensor.specs}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .carousel-title {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 48px;
    color: #000000;
    text-align: left;
    position: relative;
    padding-bottom: 16px;
    letter-spacing: -0.03em;
  }

  .carousel-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 60px;
    height: 4px;
    background: var(--color-turquoise);
    border-radius: 2px;
  }

  .carousel-wrapper {
    overflow: hidden;
    padding: 40px 0;
    position: relative;
  }

  .carousel-track {
    display: flex;
    gap: 32px;
    width: max-content;
    animation: scroll 70s linear infinite;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 16px)); }
  }

  .sensor-card-mini {
    width: 360px;
    flex-shrink: 0;
    padding: 40px;
    border-radius: 24px;
    background: #FFFFFF;
    border: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.03);
    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    text-decoration: none;
    color: #000000;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .sensor-card-mini:hover {
    transform: translateY(-12px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
    border-color: var(--color-turquoise);
  }

  .sensor-card-mini__badge {
    align-self: flex-start;
    font-size: 0.7rem;
    padding: 6px 14px;
    background: #F8F9FA;
    border: 1px solid #EEEEEE;
    color: #888888;
    border-radius: 30px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .sensor-card-mini__image {
    width: 100%;
    height: 200px;
    border-radius: 12px;
    overflow: hidden;
    background: #F8F9FA;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sensor-card-mini__image img {
    width: 80%;
    height: 80%;
    object-fit: contain;
    transition: transform 0.5s ease;
  }

  .sensor-card-mini:hover .sensor-card-mini__image img {
    transform: scale(1.1);
  }

  .sensor-card-mini__name {
    font-size: 1.4rem;
    font-weight: 800;
    margin-bottom: 4px;
    letter-spacing: -0.02em;
  }

  .sensor-card-mini__specs {
    font-size: 1rem;
    color: #666666;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
