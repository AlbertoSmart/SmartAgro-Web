---
interface Sensor {
  name: string;
  specs: string;
  image: string;
  category: string;
  href: string;
}

interface Props {
  sensors: Sensor[];
  title: string;
}

const { sensors, title } = Astro.props;
---

<div class="carousel-container section-padding">
  <div class="container">
    <div class="carousel-header">
      <h3 class="carousel-title">{title}</h3>
      <div class="carousel-arrows">
        <button class="arrow-btn prev-btn" aria-label="Anterior">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button class="arrow-btn next-btn" aria-label="Siguiente">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-9-6"/></svg>
        </button>
      </div>
    </div>
    <div class="carousel-wrapper">
      <div class="carousel-track" style={`animation-duration: ${sensors.length * 8}s`}>
        {[...sensors, ...sensors].map((sensor) => (
          <a href={sensor.href} class="sensor-card-mini glass">
            <div class="sensor-card-mini__badge">{sensor.category}</div>
            <div class="sensor-card-mini__image">
              <img src={sensor.image} alt={sensor.name} loading="lazy" />
            </div>
            <div class="sensor-card-mini__content">
              <h4 class="sensor-card-mini__name">{sensor.name}</h4>
              <p class="sensor-card-mini__specs">{sensor.specs}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .carousel-title {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 48px;
    color: #000000;
    text-align: left;
    position: relative;
    padding-bottom: 16px;
    letter-spacing: -0.03em;
  }

  .carousel-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 60px;
    height: 4px;
    background: var(--color-turquoise);
    border-radius: 2px;
  }

  .carousel-wrapper {
    overflow: hidden;
    padding: 40px 0;
    position: relative;
  }

  .carousel-track {
    display: flex;
    gap: 32px;
    width: max-content;
    animation: scroll 30s linear infinite;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 16px)); }
  }

  .sensor-card-mini {
    width: 360px;
    flex-shrink: 0;
    padding: 40px;
    border-radius: 24px;
    background: #FFFFFF;
    border: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.03);
    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    text-decoration: none;
    color: #000000;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .sensor-card-mini:hover {
    transform: translateY(-12px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
    border-color: var(--color-turquoise);
  }

  .sensor-card-mini__badge {
    align-self: flex-start;
    font-size: 0.7rem;
    padding: 6px 14px;
    background: #F8F9FA;
    border: 1px solid #EEEEEE;
    color: #888888;
    border-radius: 30px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .sensor-card-mini__image {
    width: 100%;
    height: 200px;
    border-radius: 12px;
    overflow: hidden;
    background: #F8F9FA;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sensor-card-mini__image img {
    width: 80%;
    height: 80%;
    object-fit: contain;
    transition: transform 0.5s ease;
  }

  .sensor-card-mini:hover .sensor-card-mini__image img {
    transform: scale(1.1);
  }

  .sensor-card-mini__name {
    font-size: 1.4rem;
    font-weight: 800;
    margin-bottom: 4px;
    letter-spacing: -0.02em;
  }

  .sensor-card-mini__specs {
    font-size: 1rem;
    color: #666666;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* NUEVOS ESTILOS PARA FLECHAS (SIN TOCAR LO ANTERIOR) */
  .carousel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 48px;
  }

  .carousel-header .carousel-title {
    margin-bottom: 0;
  }

  .carousel-arrows {
    display: flex;
    gap: 12px;
  }

  .arrow-btn {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: #FFFFFF;
    border: 1px solid #EEEEEE;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    color: #000000;
  }

  .arrow-btn:hover {
    background: var(--color-turquoise);
    color: #FFFFFF;
    border-color: var(--color-turquoise);
    transform: scale(1.1);
  }

  .carousel-track.manual-only {
    animation: none !important;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }

  /* Cooldown interactivo */
  .carousel-track.is-paused-by-user {
    animation-play-state: paused !important;
  }
</style>

<script>
  function initManualCarousel() {
    const containers = document.querySelectorAll('.carousel-container');
    
    containers.forEach(container => {
      if ((container as HTMLElement).dataset.manualCarouselReady === 'true') return;

      const track = container.querySelector('.carousel-track') as HTMLElement;
      const prevBtn = container.querySelector('.prev-btn');
      const nextBtn = container.querySelector('.next-btn');
      
      if (!track || !prevBtn || !nextBtn) return;
      (container as HTMLElement).dataset.manualCarouselReady = 'true';

      const itemCount = track.children.length / 2; // Están duplicados
      const duration = itemCount * 8; // Sincronizado: 8s por item
      let currentDelay = 0; 
      let pauseTimeout: any = null;

      const shiftAnimation = (direction: number) => {
        const trackWidth = track.scrollWidth / 2;
        const stepPixels = 360 + 32; 
        
        // Calculamos cuánto tiempo de la animación representan esos píxeles
        const timeShift = (stepPixels / trackWidth) * duration;
        
        // Ajustamos el delay para "adelantar" o "retrasar" la fase de la animación
        currentDelay += (direction * timeShift);
        
        track.style.animationDelay = `${currentDelay}s`;

        // Lógica de Cooldown (1s de pausa)
        track.classList.add('is-paused-by-user');
        if (pauseTimeout) clearTimeout(pauseTimeout);
        pauseTimeout = setTimeout(() => {
          track.classList.remove('is-paused-by-user');
        }, 1000);
      };

      nextBtn.addEventListener('click', () => shiftAnimation(-1));
      prevBtn.addEventListener('click', () => shiftAnimation(1));
    });
  }

  document.addEventListener('DOMContentLoaded', initManualCarousel);
  document.addEventListener('astro:page-load', initManualCarousel);
</script>
