<section class="virtual-mgmt section-padding" id="gestion">
    <div class="container">
        <div class="virtual-mgmt__grid">
            <div class="virtual-mgmt__visual">
                <div class="map-mockup glass">
                    <img src="/images/gemelo-digital.jpg" alt="Gemelo Digital" class="map-mockup__image" />
                </div>
            </div>

            <div class="virtual-mgmt__content">
                <span class="intro__label">Gemelo Digital de tu Explotación</span>
                <h2 class="section-title">
                    Tu Gemelo Digital: Trazabilidad Total SIGPAC
                </h2>
                <p class="intro__text">
                    Gestiona tus parcelas SIGPAC sobre un mapa GIS de alta
                    precisión. Dibuja tuberías, arquetas y sectores de riego, y
                    vincula cada sensor a una ubicación exacta para tener
                    trazabilidad total de cada recurso aplicado en tu explotación.
                </p>

                <div class="mgmt-features">
                    <div class="mgmt-item">
                        <div class="mgmt-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                        </div>
                        <div class="mgmt-text">
                            <strong>Parcelas SIGPAC Georreferenciadas</strong>
                            <p>
                                Importa y gestiona tus parcelas SIGPAC con
                                coordenadas exactas. Vincula sensores, riegos y
                                tratamientos a cada recinto catastral.
                            </p>
                        </div>
                    </div>
                    <div class="mgmt-item">
                        <div class="mgmt-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 13 1-1 4 4-5 2v-3Z"/><path d="M17.13 15.36c.33-.2.64-.4.93-.61a10 10 0 1 0-1.22-1.22c.2-.29.4-.6.61-.93"/><path d="M16 12h-4"/><path d="M11 10.5 9 12"/><path d="M12.5 8 11 9"/><path d="m5 18 1-1"/><path d="M18 5.4c.1-.4.2-.8.2-1.2h-13c0 .4.1.8.2 1.2"/><path d="m11 11-1.3 2.6c-.2.4-.7.6-1.1.4l-.1-.1c-.4-.2-.6-.7-.4-1.1L9.4 10.3c.2-.4.7-.6 1.1-.4l.1.1c.4.2.6.7.4 1.1Z"/></svg>
                        </div>
                        <div class="mgmt-text">
                            <strong>Infraestructura de Riego Digital</strong>
                            <p>
                                Dibuja tuberías principales, ramales, arquetas
                                y sectores de riego sobre el mapa para controlar
                                cada gota de agua con evidencia documental.
                            </p>
                        </div>
                    </div>
                    <div class="mgmt-item">
                        <div class="mgmt-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20v-8"/><path d="M6 12a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1V20a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2v-8Z"/><path d="M12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/><path d="M7.5 11.5a4.5 4.5 0 0 1 9 0"/><path d="M12 7V3"/><path d="m10 5 2-2 2 2"/></svg>
                        </div>
                        <div class="mgmt-text">
                            <strong>Trazabilidad de Insumos</strong>
                            <p>
                                Cada sensor vinculado a su ubicación exacta
                                genera registros automáticos que respaldan
                                legalmente tus aplicaciones ante el SIEX.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .virtual-mgmt {
        background: var(--color-white);
    }

    .virtual-mgmt__grid {
        display: grid;
        grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
        gap: clamp(32px, 4vw, 56px);
        align-items: center;
    }

    .virtual-mgmt__visual {
        position: relative;
        display: flex;
        align-self: stretch;
    }

    .map-mockup__image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .map-mockup {
        width: 100%;
        min-height: 560px;
        background: #1a1a2e;
        border-radius: var(--border-radius-lg);
        overflow: hidden;
        position: relative;
        box-shadow: var(--shadow-xl);
        border: 1px solid rgba(0, 0, 0, 0.1);
    }

    .map-mockup__overlay {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(
                rgba(255, 255, 255, 0.05) 1px,
                transparent 1px
            ),
            linear-gradient(
                90deg,
                rgba(255, 255, 255, 0.05) 1px,
                transparent 1px
            );
        background-size: 40px 40px, 40px 40px;
    }

    .map-point {
        position: absolute;
        width: 12px;
        height: 12px;
        background: var(--color-turquoise);
        border-radius: 50%;
        box-shadow: 0 0 15px var(--color-turquoise);
    }

    .map-point span {
        position: absolute;
        top: 50%;
        left: 20px;
        transform: translateY(-50%);
        white-space: nowrap;
        background: rgba(0, 0, 0, 0.6);
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 0.7rem;
        color: white;
        backdrop-filter: blur(4px);
    }

    .map-lines {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    .mgmt-features {
        display: flex;
        flex-direction: column;
        gap: 32px;
        margin-top: 40px;
    }

    .mgmt-item {
        display: flex;
        gap: 20px;
    }

    .mgmt-icon {
        width: 54px;
        height: 54px;
        min-width: 54px;
        background: var(--color-gray-50);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-turquoise);
        padding: 12px;
        transition: var(--transition);
        border: 1px solid var(--color-gray-100);
    }

    .mgmt-icon svg {
        width: 100%;
        height: 100%;
        stroke-width: 2;
    }

    .mgmt-item:hover .mgmt-icon {
        background: var(--color-turquoise);
        color: var(--color-white);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(15, 181, 174, 0.2);
    }

    .mgmt-text strong {
        display: block;
        font-size: 1.1rem;
        color: var(--color-gray-900);
        margin-bottom: 4px;
    }

    .mgmt-text p {
        font-size: 0.95rem;
        color: var(--color-gray-500);
        line-height: 1.5;
    }

    @media (max-width: 1024px) {
        .virtual-mgmt__grid {
            display: flex;
            flex-direction: column;
            gap: 30px;
        }
        
        /* Flatten the content container to place the visual in between */
        .virtual-mgmt__content {
            display: contents;
        }
        
        /* Give specific order to children so the image is inserted */
        .virtual-mgmt__content > .intro__label { order: 1; }
        .virtual-mgmt__content > .section-title { order: 2; }
        .virtual-mgmt__content > .intro__text { order: 3; margin-bottom: 20px; }
        .virtual-mgmt__visual { order: 4; width: 100%; margin: 10px 0; }
        .virtual-mgmt__content > .mgmt-features { order: 5; margin-top: 10px; }
        
        /* Make sure the map scales correctly */
        .map-mockup {
            aspect-ratio: 16/9;
            min-height: 0;
        }
    }
</style>
