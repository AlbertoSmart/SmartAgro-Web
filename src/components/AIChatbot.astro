---
// AIChatbot.astro
---

<div class="ai-chat-wrapper" transition:persist="chatbot-ui">
  <div class="ai-chat-bubble" id="aiBubble">
    <div class="ai-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
    </div>
    <span class="bubble-text">Experto PAC</span>
  </div>

  <div class="ai-chat-window" id="aiChatWindow">
    <div class="chat-header">
      <div class="header-info">
        <div class="header-avatar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
          <div class="status-dot"></div>
        </div>
        <div>
          <h3>AgroAI Asistente</h3>
          <span>Experto en SIEX & PAC</span>
        </div>
      </div>
      <button class="close-chat" id="closeChat">&times;</button>
    </div>

    <div class="chat-messages" id="chatMessages">
      <div class="message incoming">
        <p>Buenas, ¿qué tal? Cuéntame qué necesitas y te echo una mano.</p>
      </div>
    </div>

    <div class="chat-suggestions">
      <button class="suggest-btn" data-q="¿Qué es el SIEX?">¿Qué es el SIEX?</button>
      <button class="suggest-btn" data-q="Ecorregímenes 2024">Ecorregímenes 2024</button>
      <button class="suggest-btn" data-q="¿Es obligatorio el cuaderno?">¿Es obligatorio el cuaderno?</button>
    </div>

    <div class="chat-input-area">
      <input type="text" placeholder="Escribe tu duda aquí..." id="chatInput" />
      <button class="send-btn" id="sendBtn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
      </button>
    </div>
  </div>
</div>

<style is:global>
  .ai-chat-bubble {
    position: fixed;
    bottom: 85px;
    right: 30px;
    background: #0B1A14;
    color: white;
    padding: 12px 24px;
    border-radius: 50px;
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: grab;
    z-index: 1000;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2), 0 0 15px rgba(29, 185, 154, 0.3);
    border: 1px solid rgba(29, 185, 154, 0.5);
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), background 0.3s;
    user-select: none;
    touch-action: none;
  }

  .ai-chat-bubble:active {
    cursor: grabbing;
  }

  .ai-chat-bubble.dragging {
    transform: scale(1.1);
    box-shadow: 0 25px 50px rgba(0,0,0,0.4), 0 0 30px rgba(29, 185, 154, 0.5);
    transition: none;
  }

  .ai-chat-bubble.settling {
    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.5);
  }

  .ai-chat-bubble:hover {
    transform: translateY(-5px) scale(1.05);
    background: #142d23;
  }

  .ai-icon {
    color: var(--color-turquoise, #1DB99A);
  }

  .bubble-text {
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* Chat Window */
  .ai-chat-window {
    position: fixed;
    /* Posicionamiento dinámico vía JS */
    bottom: 100px;
    right: 30px;
    width: 380px;
    height: 520px;
    max-height: 80vh;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px);
    border-radius: 12px;
    z-index: 2000;
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    border: 1px solid rgba(0,0,0,0.05);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px) scale(0.98);
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    pointer-events: none;
    overflow: hidden;
  }

  .ai-chat-window.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
    pointer-events: all;
  }

  .chat-header {
    padding: 24px;
    background: linear-gradient(135deg, #0B1A14 0%, #17362B 100%);
    color: white;
    border-radius: 12px 12px 0 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    position: relative;
    z-index: 10;
  }

  .header-info {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .header-avatar {
    width: 44px;
    height: 44px;
    background: rgba(29, 185, 154, 0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-turquoise);
    position: relative;
    border: 1px solid rgba(29, 185, 154, 0.3);
  }

  .status-dot {
    width: 12px;
    height: 12px;
    background: #2ECC71;
    border-radius: 50%;
    border: 2px solid #0B1A14;
    position: absolute;
    bottom: -2px;
    right: -2px;
  }

  .chat-header h3 {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 800;
    color: #ffffff !important;
    letter-spacing: -0.01em;
  }

  .chat-header span {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.7);
    font-weight: 500;
  }

  .close-chat {
    background: none;
    border: none;
    color: white;
    font-size: 1.8rem;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.3s;
  }

  .close-chat:hover { opacity: 1; }

  .chat-messages {
    flex-grow: 1;
    padding: 24px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
    overscroll-behavior: contain;
  }

  .message {
    max-width: 85%;
    padding: 16px 20px;
    font-size: 0.95rem;
    line-height: 1.6;
    box-shadow: 0 4px 15px rgba(0,0,0,0.04);
    white-space: pre-wrap;
  }

  .message-label {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 8px;
    letter-spacing: 0.05em;
  }

  .message.incoming {
    background: white;
    color: #1e293b;
    align-self: flex-start;
    border-radius: 20px 20px 20px 4px;
    border: 1px solid #e2e8f0;
    white-space: pre-wrap;
  }

  .message.incoming .message-label {
    color: #1DB99A;
  }

  .message.outgoing {
    background: #1DB99A;
    color: white;
    align-self: flex-end;
    font-weight: 600;
    border-radius: 20px 20px 4px 20px;
    box-shadow: 0 4px 15px rgba(29, 185, 154, 0.2);
  }

  .message.outgoing .message-label {
    color: rgba(255,255,255,0.8);
  }

  .chat-suggestions {
    padding: 0 24px 16px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .suggest-btn {
    background: rgba(29, 185, 154, 0.06);
    border: 1px solid rgba(29, 185, 154, 0.2);
    padding: 10px 16px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #0f4d3f;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .suggest-btn:hover {
    background: var(--color-turquoise);
    color: white;
    border-color: var(--color-turquoise);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(29, 185, 154, 0.25);
  }

  .chat-input-area {
    padding: 20px 24px;
    border-top: 1px solid #f1f5f9;
    display: flex;
    gap: 12px;
  }

  .chat-input-area input {
    flex-grow: 1;
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    padding: 14px 18px;
    border-radius: 16px;
    outline: none;
    font-size: 0.95rem;
    transition: all 0.3s;
  }

  .chat-input-area input:focus {
    border-color: var(--color-turquoise);
    background: white;
    box-shadow: 0 0 0 3px rgba(29, 185, 154, 0.15);
  }

  .send-btn {
    background: var(--color-turquoise);
    color: white;
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 4px 15px rgba(29, 185, 154, 0.3);
  }

  .send-btn:hover {
    transform: scale(1.08) rotate(-5deg);
    background: #17a689;
    box-shadow: 0 6px 20px rgba(29, 185, 154, 0.4);
  }

  @media (max-width: 500px) {
    .ai-chat-bubble {
        bottom: 20px;
        right: 20px;
        padding: 10px;
        width: 48px;
        height: 48px;
        justify-content: center;
        border-radius: 50%;
    }
    .bubble-text { display: none; }
  }
  .message a.chat-link {
    color: #4da6ff !important;
    text-decoration: underline !important;
    font-weight: 500;
  }
  .message a.chat-link:hover {
    color: #80c1ff !important;
  }
</style>

<script>
  let chatHistory: { role: string, text: string }[] = [];
  let isAiWorking = false;
  let chatEventListenersBound = false;

  document.addEventListener('astro:page-load', () => {
    if (chatEventListenersBound) return; // Evitar duplicar listeners si el componente persiste
    chatEventListenersBound = true;
    const aiBubble = document.getElementById('aiBubble') as HTMLElement | null;
    const aiChatWindow = document.getElementById('aiChatWindow') as HTMLElement | null;
    const closeChat = document.getElementById('closeChat') as HTMLButtonElement | null;
    const chatInput = document.getElementById('chatInput') as HTMLInputElement | null;
    const sendBtn = document.getElementById('sendBtn') as HTMLButtonElement | null;
    const chatMessages = document.getElementById('chatMessages') as HTMLElement | null;
    const suggestBtns = document.querySelectorAll('.suggest-btn');

    const toggleChat = (force?: any) => {
      if (aiChatWindow && aiBubble) {
        const isActive = aiChatWindow.classList.contains('active');
        const nextState = typeof force === 'boolean' ? force : !isActive;
        
        if (nextState && !isActive) {
          const isMobile = window.innerWidth <= 600;
          
          if (isMobile) {
            aiChatWindow.style.left = '15px';
            aiChatWindow.style.right = '15px';
            aiChatWindow.style.width = 'calc(100% - 30px)';
            aiChatWindow.style.bottom = '15px';
            aiChatWindow.style.height = '55vh'; // Reducido de 70vh a 55vh a petición del usuario
          } else {
            // Posicionar la ventana sobre la burbuja
            const rect = aiBubble.getBoundingClientRect();
            const windowWidth = 380;
            const windowHeight = 520;
            
            let left = rect.right - windowWidth;
            let bottom = window.innerHeight - rect.top + 15;
            
            if (left < 20) left = 20;
            if (left + windowWidth > window.innerWidth - 20) left = window.innerWidth - windowWidth - 20;
            if (bottom + windowHeight > window.innerHeight - 20) {
              bottom = window.innerHeight - windowHeight - 20;
            }

            aiChatWindow.style.left = `${left}px`;
            aiChatWindow.style.bottom = `${bottom}px`;
            aiChatWindow.style.width = `${windowWidth}px`;
            aiChatWindow.style.height = `${windowHeight}px`;
            aiChatWindow.style.right = 'auto';
          }
        }
        
        if (nextState) {
          aiChatWindow.classList.add('active');
          setTimeout(() => chatInput?.focus(), 100);
        } else {
          aiChatWindow.classList.remove('active');
        }
      }
    };

    // Escuchar evento personalizado para abrir desde otros componentes
    document.addEventListener('open-agro-ai', () => toggleChat(true));

    // Lógica Draggable Nativa
    let isDragging = false;
    let startX: number, startY: number;
    let initialX: number, initialY: number;
    let dragHasMoved = false;

    const onStart = (e: MouseEvent | TouchEvent) => {
      if (!aiBubble) return;
      isDragging = true;
      dragHasMoved = false;
      
      const clientX = 'touches' in e ? e.touches[0].clientX : e.clientX;
      const clientY = 'touches' in e ? e.touches[0].clientY : e.clientY;
      
      const rect = aiBubble.getBoundingClientRect();
      startX = clientX;
      startY = clientY;
      initialX = rect.left;
      initialY = rect.top;
      
      aiBubble.classList.add('dragging');
      aiBubble.classList.remove('settling');
    };

    const onMove = (e: MouseEvent | TouchEvent) => {
      if (!isDragging || !aiBubble) return;
      
      const clientX = 'touches' in e ? e.touches[0].clientX : e.clientX;
      const clientY = 'touches' in e ? e.touches[0].clientY : e.clientY;
      
      const dx = clientX - startX;
      const dy = clientY - startY;
      
      if (Math.abs(dx) > 5 || Math.abs(dy) > 5) dragHasMoved = true;

      let newX = initialX + dx;
      let newY = initialY + dy;
      
      // Boundaries
      const rect = aiBubble.getBoundingClientRect();
      newX = Math.max(10, Math.min(window.innerWidth - rect.width - 10, newX));
      newY = Math.max(10, Math.min(window.innerHeight - rect.height - 10, newY));
      
      aiBubble.style.left = `${newX}px`;
      aiBubble.style.top = `${newY}px`;
      aiBubble.style.right = 'auto';
      aiBubble.style.bottom = 'auto';
    };

    const onEnd = () => {
      if (!isDragging || !aiBubble) return;
      isDragging = false;
      aiBubble.classList.remove('dragging');
      aiBubble.classList.add('settling');
      
      // Si el usuario solo hizo click, abrimos el chat
      if (!dragHasMoved) {
        toggleChat();
      }
    };

    aiBubble?.addEventListener('mousedown', onStart);
    aiBubble?.addEventListener('touchstart', onStart, { passive: true });
    window.addEventListener('mousemove', onMove);
    window.addEventListener('touchmove', onMove, { passive: false });
    window.addEventListener('mouseup', onEnd);
    window.addEventListener('touchend', onEnd);

    closeChat?.addEventListener('click', () => toggleChat(false));

  const appendMessageHTML = (text: string, type: string = 'incoming', isHTML: boolean = false) => {
    if (!chatMessages) return null;
    const msg = document.createElement('div');
    msg.className = `message ${type}`;

    // Añadir etiqueta de quién habla ("Tú" o "AgroAI")
    const label = document.createElement('div');
    label.className = 'message-label';
    // No añadimos label a la burbuja de "cargando..."
    if (!text.includes('animation: bounce')) {
      label.textContent = type === 'incoming' ? 'AgroAI' : 'Tú';
      msg.appendChild(label);
    }

    const content = document.createElement('div');
    content.className = 'message-content';
    if (isHTML) {
      content.innerHTML = text;
    } else {
      const p = document.createElement('p');
      p.textContent = text;
      content.appendChild(p);
    }
    msg.appendChild(content);
    chatMessages.appendChild(msg);

    // Sistema de scroll inteligente sin mover la pantalla del usuario
    if (type === 'incoming' && !text.includes('animation: bounce')) {
      setTimeout(() => {
        // En lugar de scrollIntoView (que causa que la web entera baje), scrolleamos el contenedor
        chatMessages.scrollTo({ 
          top: msg.offsetTop - 30, 
          behavior: 'smooth' 
        });
      }, 50);
    } else {
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }
    
    return msg;
  };

  const showLoading = () => {
    return appendMessageHTML(`
      <div style="display: flex; gap: 4px; padding: 4px 8px;">
        <span style="width: 6px; height: 6px; background: #64748b; border-radius: 50%; display: inline-block; animation: bounce 1s infinite alternate;"></span>
        <span style="width: 6px; height: 6px; background: #64748b; border-radius: 50%; display: inline-block; animation: bounce 1s infinite alternate; animation-delay: 0.2s"></span>
        <span style="width: 6px; height: 6px; background: #64748b; border-radius: 50%; display: inline-block; animation: bounce 1s infinite alternate; animation-delay: 0.4s"></span>
      </div>
    `, 'incoming', true);
  };

  const attemptSend = async (text: string) => {
    if (isAiWorking || !text.trim()) return;

    // Remove buttons from view to keep history clean (optional)
    const suggestionsContainer = document.querySelector('.chat-suggestions') as HTMLElement;
    if (suggestionsContainer) {
       suggestionsContainer.style.display = 'none';
    }

    // 1. Mostrar mensaje del usuario
    appendMessageHTML(text, 'outgoing');
    chatInput && (chatInput.value = '');
    isAiWorking = true;
    chatInput?.setAttribute('disabled', 'true');
    sendBtn?.setAttribute('disabled', 'true');

    // 2. Mostrar indicador de "Escribiendo..."
    const loadingBubble = showLoading();

    try {
      // 3. Llamada al Backend (API) de Astro donde está Gemini
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ message: text, chatHistory })
      });

      // Añadimos el mensaje del usuario al historial que tenemos guardado
      chatHistory.push({ role: 'user', text });

      loadingBubble?.remove();

      if (response.ok) {
        const data = await response.json();
        // Formateamos: saltos de línea, negritas, y enlaces markdown
        const formattedText = data.text
          .replace(/\n\n/g, '</p><p>')
          .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
          .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="chat-link">$1</a>');
        appendMessageHTML(`<p>${formattedText}</p>`, 'incoming', true);
        
        // Añadir repuesta de la IA al historial
        chatHistory.push({ role: 'model', text: data.text });
      } else {
        throw new Error('Server error');
      }
    } catch(err) {
      console.error("API error", err);
      loadingBubble?.remove();
      appendMessageHTML("Perdona, no he podido conectar ahora mismo. ¿Puedes intentarlo otra vez en un momento? Si sigue fallando, <a href='/contacto' style='color: var(--color-turquoise); text-decoration: underline;'>escríbenos directamente</a> y te atendemos.", 'incoming');
    } finally {
      isAiWorking = false;
      chatInput?.removeAttribute('disabled');
      sendBtn?.removeAttribute('disabled');
      chatInput?.focus();
    }
  };

  const handleSendBtnClick = () => {
    if (chatInput) {
      attemptSend(chatInput.value);
    }
  };

  sendBtn?.addEventListener('click', handleSendBtnClick);
  chatInput?.addEventListener('keypress', (e: KeyboardEvent) => {
    if (e.key === 'Enter') handleSendBtnClick();
  });

  suggestBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const q = btn.getAttribute('data-q');
      if (q) attemptSend(q);
    });
  });

    // Inject minimalist bounce animation into doc
    const style = document.createElement('style');
    style.innerHTML = `@keyframes bounce { to { transform: translateY(-4px); opacity: 0.5; } }`;
    document.head.appendChild(style);
  });
</script>
