---
---

<section class="technicians" id="technicians">
  <div class="technicians__bg">
    <!-- Floating icons -->
    <div class="technicians__icon technicians__icon--1">
      <svg viewBox="0 0 60 60" fill="none" stroke="white" stroke-width="1.5">
        <rect x="10" y="8" width="40" height="44" rx="3"></rect>
        <line x1="18" y1="20" x2="42" y2="20"></line>
        <line x1="18" y1="28" x2="42" y2="28"></line>
        <line x1="18" y1="36" x2="34" y2="36"></line>
        <path d="M34 44l6-6 6 6"></path>
      </svg>
    </div>
    <div class="technicians__icon technicians__icon--2">
      <svg viewBox="0 0 60 60" fill="none" stroke="white" stroke-width="1.5">
        <path d="M30 10L10 24v26h40V24L30 10z"></path>
        <rect x="22" y="32" width="16" height="18"></rect>
        <circle cx="30" cy="20" r="4"></circle>
      </svg>
    </div>
    <div class="technicians__icon technicians__icon--3">
      <svg viewBox="0 0 60 60" fill="none" stroke="white" stroke-width="1.5">
        <circle cx="30" cy="30" r="20"></circle>
        <path d="M22 30l6 6 12-12"></path>
      </svg>
    </div>
    <div class="technicians__icon technicians__icon--4">
      <svg viewBox="0 0 60 60" fill="none" stroke="white" stroke-width="1.5">
        <rect x="8" y="8" width="44" height="44" rx="4"></rect>
        <path d="M8 20h44"></path>
        <path d="M20 8v44"></path>
      </svg>
    </div>
    <div class="technicians__icon technicians__icon--5">
      <svg viewBox="0 0 60 60" fill="none" stroke="white" stroke-width="1.5">
        <path d="M30 8v20l12 10-12 10V28"></path>
        <circle cx="30" cy="8" r="4"></circle>
      </svg>
    </div>
    <div class="technicians__icon technicians__icon--6">
      <svg viewBox="0 0 60 60" fill="none" stroke="white" stroke-width="1.5">
        <rect x="10" y="14" width="40" height="32" rx="2"></rect>
        <path d="M10 22h40"></path>
        <circle cx="20" cy="34" r="4"></circle>
        <circle cx="30" cy="34" r="4"></circle>
        <circle cx="40" cy="34" r="4"></circle>
      </svg>
    </div>
  </div>

  <div class="technicians__content container">
    <h2 class="technicians__title">
      Cumplimiento Legal Sin Esfuerzo
    </h2>
    <p class="technicians__text">
      Generación automática de informes homologados para el SIEX, firma
      electrónica integrada y validación de dosis de fitosanitarios según el
      registro oficial del MAPA. Tu cuaderno de campo siempre actualizado,
      sin errores manuales y con toda la evidencia documental que necesitas
      para superar cualquier inspección.
    </p>
    <div class="technicians__cta">
      <a href="/contacto" class="btn btn--turquoise">Solicitar Demo Gratuita</a>
    </div>
  </div>
</section>

<style>
  .technicians {
    position: relative;
    background: #0B1A14;
    padding: 100px 0;
    overflow: hidden;
  }

  .technicians__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .technicians__icon {
    position: absolute;
    width: 70px;
    height: 70px;
    opacity: 0.2;
  }

  .technicians__icon--1 {
    top: 10%;
    left: 5%;
  }
  .technicians__icon--2 {
    top: 8%;
    right: 8%;
  }
  .technicians__icon--3 {
    bottom: 10%;
    left: 8%;
  }
  .technicians__icon--4 {
    top: 50%;
    left: 15%;
    transform: translateY(-50%);
  }
  .technicians__icon--5 {
    bottom: 12%;
    right: 5%;
  }
  .technicians__icon--6 {
    top: 50%;
    right: 12%;
    transform: translateY(-50%);
  }

  .technicians__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .technicians__title {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--color-white);
    line-height: 1.25;
    margin-bottom: 28px;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
  }

  .technicians__text {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.8;
    margin-bottom: 32px;
  }

  .technicians__cta {
    margin-top: 8px;
  }

  @media (max-width: 768px) {
    .technicians {
      padding: 60px 0;
    }
    .technicians__title {
      font-size: 1.6rem;
    }
    .technicians__icon {
      width: 45px;
      height: 45px;
    }
  }
</style>
