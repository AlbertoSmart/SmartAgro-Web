---
import Layout from "../layouts/Layout.astro";

interface Props {
  title: string;
  heading: string;
  description?: string;
  variant?:
    | "tools"
    | "news"
    | "contact"
    | "idi"
    | "ayudas"
    | "sinergias"
    | "legal"
    | "solutions"
    | "eventos";
  layoutType?: "suspended" | "mosaic" | "minimalist";
  image?: string;
  mosaicImages?: string[];
}

const {
  title,
  heading,
  description = "",
  variant = "legal",
  layoutType = "minimalist",
  mosaicImages = [],
  image,
} = Astro.props;

// Specific data/visuals for different layouts
const showMosaic = layoutType === "mosaic";
const showSuspended = layoutType === "suspended";
const showMinimalist = layoutType === "minimalist";
---

<Layout title={`${title}`} transparent={true} showNewsletter={true}>
  <main>
    <section class={`page-hero page-hero--${variant} page-hero--${layoutType}`}>
      <div class="container page-hero__container">
        {showSuspended && (
          <div class="hero-suspended">
            <div class="hero-suspended__content">
              <h1>{heading}</h1>
              <p>{description}</p>
            </div>
            {image && (
              <div class="hero-suspended__image">
                <img src={image} alt={heading} />
              </div>
            )}
          </div>
        )}

        {showMosaic && (
          <div class="hero-mosaic">
            <div class="hero-mosaic__content">
              <h1>{heading}</h1>
              <p>{description}</p>
            </div>
            <div class="hero-mosaic__images">
              <div class="m-img m-img--1" style={mosaicImages[0] ? `background-image: url(${mosaicImages[0]})` : 'background: rgba(15, 181, 174, 0.1); border: 1px dashed rgba(255,255,255,0.2);'}></div>
              <div class="m-img m-img--2" style={mosaicImages[1] ? `background-image: url(${mosaicImages[1]})` : 'background: rgba(0,0,0,0.3); border: 1px dashed rgba(255,255,255,0.15);'}>
                {!mosaicImages[1] && <div class="fallback-viz">01010110</div>}
              </div>
            </div>
          </div>
        )}

        {showMinimalist && (
          <div class="hero-minimalist">
             <h1 class="text-weight-heavy">{heading}</h1>
          </div>
        )}
      </div>
    </section>
    
    <section class="page-body">
      <div class="container">
        <slot />
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-hero {
    position: relative;
    height: auto;
    min-height: 220px;
    padding: 140px 0 30px; /* Minimalist vertical profile */
    color: #FFFFFF !important;
    overflow: hidden;
    display: flex;
    align-items: center; /* Center horizontally/vertically if needed, but container will be at bottom */
    background: var(--color-gray-900);
    z-index: 1; 
    margin-top: 0;
  }

  .page-hero__container {
    width: 100%;
    position: relative;
    z-index: 10;
    margin-top: auto;
  }

  /* Variant Colors */
  .page-hero--solutions { background: #0c4a6e; }
  .page-hero--tools { background: #134e4a; }
  .page-hero--news { background: #1e293b; }
  .page-hero--contact { background: #064e3b; }
  .page-hero--ayudas { background: #7c2d12; }
  .page-hero--eventos { background: #881337; }

  /* Breadcrumbs */
  .hero-breadcrumbs {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 800;
    opacity: 0.9; /* High contrast as requested */
    margin-bottom: 20px;
    color: #e2e8f0; /* Light gray for legibility */
  }

  /* 01. Suspended Layout (Servicios) */
  .hero-suspended {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    padding: 40px 0;
  }

  .hero-suspended__content h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 24px;
    color: #FFFFFF;
  }

  .hero-suspended__content p {
    font-size: 1.25rem;
    color: #f1f5f9;
    max-width: 500px;
    line-height: 1.6;
  }

  .hero-suspended__image {
    position: relative;
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-2xl);
    transform: translateY(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    max-width: 440px; /* Reduced to avoid overpowering the layout */
    margin-left: auto;
  }

  .hero-suspended__image img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/10; /* More horizontal and elegant */
    object-fit: cover;
  }

  .data-blob {
    display: flex;
    flex-direction: column;
  }

  .data-blob .label {
    font-size: 0.7rem;
    text-transform: uppercase;
    font-weight: 800;
    opacity: 0.5;
  }

  .data-blob .value {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-turquoise);
  }

  /* 02. Mosaic Layout (Soluciones) */
  .hero-mosaic {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    gap: 60px;
  }

  .hero-mosaic__content {
    flex: 1;
    max-width: 550px;
  }

  .hero-mosaic h1 {
    font-size: 3.2rem;
    font-weight: 950;
    margin-bottom: 20px;
    line-height: 0.95;
    color: #FFFFFF;
    text-shadow: 0 4px 15px rgba(0,0,0,0.3);
  }

  .hero-mosaic p {
    font-size: 1.15rem;
    opacity: 1; /* Maximum clarity */
    line-height: 1.6;
    max-width: 500px;
    color: #f1f5f9; /* Near white */
    text-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .hero-mosaic__images {
    position: relative;
    width: 320px;
    height: 180px;
  }

  .m-img {
    position: absolute;
    border-radius: 12px;
    background-size: cover;
    background-position: center;
    border: 2px solid rgba(255,255,255,0.1);
    box-shadow: var(--shadow-lg);
  }

  .m-img--1 {
    width: 200px;
    height: 140px;
    top: 0;
    left: 0;
    background-color: rgba(255,255,255,0.05);
  }

  .m-img--2 {
    width: 180px;
    height: 120px;
    bottom: -20px;
    right: 0;
    background-color: rgba(0,0,0,0.2);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .fallback-viz {
    font-family: monospace;
    font-size: 0.7rem;
    letter-spacing: 2px;
    opacity: 0.15;
    color: var(--color-turquoise);
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: 
      linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .fallback-viz::after {
    content: "ARCHIVE_REAL_RESOURCES";
    font-weight: 800;
    text-transform: uppercase;
  }

  /* 03. Minimalist Layout (Actualidad) */
  .hero-minimalist {
    padding-bottom: 20px;
  }

  .text-weight-heavy {
    font-size: 3.8rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    margin: 0;
    line-height: 0.95;
    color: #FFFFFF;
  }

  .minimalist-underline {
    width: 60px;
    height: 2px; /* Elegant 2px line as requested */
    background: var(--color-turquoise);
    margin-top: 28px;
  }

  .page-body {
    padding: 60px 0 80px;
  }

  .page-body :global(h2) {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 16px;
    margin-top: 48px;
  }

  .page-body :global(h2:first-child) {
    margin-top: 0;
  }

  .page-body :global(p) {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-gray-600);
    margin-bottom: 16px;
    max-width: 800px;
  }

  .page-body :global(.cards-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 28px;
    margin: 32px 0;
  }

  .page-body :global(.feature-card) {
    background: var(--color-white);
    border-radius: 12px;
    padding: 32px 28px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .page-body :global(.feature-card:hover) {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
  }

  .page-body :global(.feature-card__icon) {
    width: 52px;
    height: 52px;
    background: var(--color-turquoise);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
    color: white;
  }

  .page-body :global(.feature-card h3) {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 10px;
  }

  .page-body :global(.feature-card p) {
    font-size: 0.92rem;
    color: var(--color-gray-500);
    line-height: 1.6;
    margin-bottom: 0;
  }

  .page-body :global(.highlight-box) {
    background: var(--color-turquoise-dark);
    border-radius: 16px;
    padding: 40px 36px;
    color: white;
    margin: 40px 0;
  }

  .page-body :global(.highlight-box h3) {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: white;
  }

  .page-body :global(.highlight-box p) {
    color: rgba(255, 255, 255, 0.85);
    max-width: 700px;
    margin-bottom: 0;
  }

  .page-body :global(.cta-btn) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-green);
    color: white;
    padding: 14px 30px;
    border-radius: 30px;
    font-weight: 600;
    font-size: 0.95rem;
    margin-top: 20px;
    transition: background 0.2s ease;
  }

  .page-body :global(.cta-btn:hover) {
    background: var(--color-green-dark);
  }

  @media (max-width: 768px) {
    .page-hero__content h1 {
      font-size: 2rem;
    }
    .page-body {
      padding: 40px 0 60px;
    }
  }
</style>
