---
import Layout from "../layouts/Layout.astro";

interface Props {
  title: string;
  heading: string;
  description?: string;
  variant?:
    | "tools"
    | "news"
    | "contact"
    | "idi"
    | "ayudas"
    | "sinergias"
    | "legal"
    | "solutions"
    | "eventos";
  layoutType?: "suspended" | "mosaic" | "minimalist";
  image?: string;
  mosaicImages?: string[];
  heroBackground?: string;
  heroSectionClass?: string;
}

const {
  title,
  heading,
  description = "",
  variant = "legal",
  layoutType = "minimalist",
  mosaicImages = [],
  image,
  heroBackground,
  heroSectionClass = "",
} = Astro.props;

// Specific data/visuals for different layouts
const showMosaic = layoutType === "mosaic";
const showSuspended = layoutType === "suspended";
const showMinimalist = layoutType === "minimalist";
const pageHeroStyle =
  showMosaic && variant === "solutions" && heroBackground
    ? `background:
        linear-gradient(rgba(5,12,10,0.7), rgba(5,12,10,0.7)),
        url('${heroBackground}') center / cover no-repeat;`
    : undefined;
---

<Layout title={`${title}`} showNewsletter={true}>
  <main>
    <section class={`page-hero page-hero--${variant} page-hero--${layoutType} ${heroSectionClass}`.trim()} style={pageHeroStyle}>
      <div class="container page-hero__container">
        {showSuspended && (
          <div class={`hero-suspended ${heroSectionClass}`.trim()}>
            <div class="hero-suspended__content">
              <h1>{heading}</h1>
              <p>{description}</p>
            </div>
            {image && (
              <div class="hero-suspended__image">
                <img src={image} alt={heading} />
              </div>
            )}
          </div>
        )}

        {showMosaic && (
          <div class="hero-mosaic">
            <div class="hero-mosaic__content">
              <h1>{heading}</h1>
              <div class="hero-mosaic__desc-row">
                <p>{description}</p>
                <a href="#newsletter" class="btn btn--turquoise hero-cta">
                  Suscríbete ahora
                </a>
              </div>
            </div>
            <div class="hero-mosaic__images">
              <div class="m-img m-img--1" style={mosaicImages[0] ? `background-image: url(${mosaicImages[0]})` : 'background: rgba(15, 181, 174, 0.1); border: 1px dashed rgba(255,255,255,0.2);'}></div>
              <div class="m-img m-img--2" style={mosaicImages[1] ? `background-image: url(${mosaicImages[1]})` : 'background: rgba(0,0,0,0.3); border: 1px dashed rgba(255,255,255,0.15);'}>
                {!mosaicImages[1] && <div class="fallback-viz">01010110</div>}
              </div>
            </div>
          </div>
        )}

        {showMinimalist && (
          <div class={`hero-minimalist ${image ? "hero-minimalist--with-image" : ""}`.trim()}>
             <h1 class="text-weight-heavy">{heading}</h1>
             {image && (
              <div class="hero-minimalist__image">
                <img src={image} alt={heading} />
              </div>
             )}
          </div>
        )}
      </div>
    </section>
    
    <section class="page-body">
      <div class="container">
        <slot />
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const ctaBtn = document.querySelector('.hero-cta');
    if (ctaBtn) {
      ctaBtn.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector('#newsletter');
        if (!target) return;
        const offset = 80; // altura de la navbar fija
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: 'smooth' });
      });
    }
  });
</script>

<style>
  .page-hero {
    position: relative;
    height: auto;
    min-height: 220px;
    padding: 0px 0px 24px; /* Standardized for stable navbar */
    color: #FFFFFF !important;
    overflow: hidden;
    display: flex;
    align-items: center; 
    background: var(--color-slate-900);
    z-index: 1; 
    margin-top: 0;
  }

  .page-hero__container {
    width: 100%;
    position: relative;
    z-index: 10;
    margin-top: auto;
  }

  /* Variant Colors - Standardized for Consistency with "Esencia de Campo" */
  .page-hero--solutions { background-color: #0B1A14; }
  .page-hero--tools { background-color: #0B1A14; } 
  .page-hero--news { background-color: #0B1A14; }
  .page-hero--contact { background-color: #0B1A14; }
  .page-hero--ayudas { background-color: #0B1A14; }
  .page-hero--eventos { background-color: #0B1A14; }

  /* Breadcrumbs */
  .hero-breadcrumbs {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    font-weight: 700;
    opacity: 0.7; 
    margin-bottom: 24px;
    color: #FFFFFF; 
  }

  /* 01. Suspended Layout (Servicios) */
  .hero-suspended {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    position: relative;
    padding: 40px 0;
  }

  .hero-suspended__content h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    margin-bottom: 30px;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: #FFFFFF;
  }

  .hero-suspended__content p {
    font-size: 1.3rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 500px;
    line-height: 1.6;
    font-weight: 400;
  }

  .hero-suspended__image {
    position: relative;
    border-radius: 40px;
    overflow: hidden;
    box-shadow: 0 40px 100px -20px rgba(0,0,0,0.4);
    transform: translateY(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    max-width: 480px; 
    margin-left: auto;
  }

  .hero-suspended__image img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/10;
    object-fit: cover;
  }

  .hero-suspended--trazabilidad {
    grid-template-columns: 50% 42%;
    gap: 8%;
  }

  .hero-suspended--trazabilidad .hero-suspended__content {
    width: 100%;
    margin-right: 2%;
  }

  .hero-suspended--trazabilidad .hero-suspended__image {
    width: 100%;
    max-width: none;
    margin-left: 0;
    transform: none;
  }

  /* 02. Mosaic Layout (Soluciones) */
  .hero-mosaic {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    gap: 80px;
    position: relative;
    z-index: 1;
  }

  .hero-mosaic__content,
  .hero-mosaic__images {
    position: relative;
    z-index: 1;
  }

  .hero-mosaic h1 {
    font-size: clamp(1.5rem, 4vw, 12rem);
    font-weight: 700;
    margin-bottom: 30px;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: #FFFFFF;
  }

  .hero-mosaic p {
    font-size: 1.3rem;
    line-height: 1.6;
    max-width: 500px;
    color: rgba(255, 255, 255, 0.9);
  }

  /* CTA Button in Hero Mosaic */
  .hero-mosaic__desc-row {
    display: flex;
    align-items: center;
    gap: 32px;
    margin-top: 0;
  }

  .hero-mosaic__desc-row p {
    margin: 0;
    flex: 1;
  }

  .hero-cta {
    flex-shrink: 0;
    font-size: 1rem;
    font-weight: 700;
    padding: 16px 36px;
    border-radius: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    box-shadow: 0 8px 24px rgba(29, 185, 154, 0.35);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    white-space: nowrap;
  }

  .hero-cta:hover {
    background: var(--color-turquoise-dark) !important;
    color: white !important;
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 16px 36px rgba(29, 185, 154, 0.45);
  }

  /* 03. Minimalist Layout */
  .hero-minimalist {
    padding-bottom: 40px;
  }

  .hero-minimalist--with-image {
    display: grid;
    grid-template-columns: 50% 42%;
    gap: 8%;
    align-items: center;
  }

  .hero-minimalist__image {
    width: 100%;
    max-width: none;
    justify-self: stretch;
  }

  .hero-minimalist__image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .text-weight-heavy {
    font-size: clamp(3rem, 4vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    margin: 0;
    line-height: 1.1;
    color: #FFFFFF;
  }

  .page-body {
    padding: 100px 0 140px;
    background: #FFFFFF;
  }

  .page-body :global(h2) {
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--color-slate-900);
    margin-bottom: 32px;
    margin-top: 80px;
    letter-spacing: -0.02em;
  }

  .page-body :global(h2:first-child) {
    margin-top: 0;
  }

  .page-body :global(p) {
    font-size: 1.15rem;
    line-height: 1.75;
    color: var(--color-slate-700);
    margin-bottom: 24px;
    max-width: 800px;
  }

  .page-body :global(.cards-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 40px;
    margin: 60px 0;
  }

  .page-body :global(.feature-card) {
    background: #FFFFFF;
    border-radius: 24px;
    padding: 48px 40px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    border: 1px solid var(--color-gray-100);
    transition: all 0.3s ease;
  }

  .page-body :global(.feature-card:hover) {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
  }

  .page-body :global(.feature-card h3) {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-slate-900);
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }

  .page-body :global(.feature-card p) {
    font-size: 1.05rem;
    color: var(--color-slate-600);
    line-height: 1.6;
    margin-bottom: 0;
  }

  .page-body :global(.highlight-box) {
    background: linear-gradient(135deg, #0B1A14 0%, #163127 100%) !important;
    border-radius: 32px;
    padding: 80px 60px;
    color: white;
    margin: 100px 0 80px;
    border: 1px solid rgba(29, 185, 154, 0.4);
    box-shadow: 0 40px 120px rgba(0,0,0,0.15);
    text-align: center;
  }

  .page-body :global(.highlight-box h3) {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 20px;
    color: white;
    text-align: center;
  }

  .page-body :global(.highlight-box p) {
    color: rgba(255, 255, 255, 0.95);
    font-size: 1.2rem;
    max-width: 700px;
    margin: 0 auto 32px;
    text-align: center;
  }

  .page-body :global(.cta-btn) {
    display: inline-block;
    background: var(--color-turquoise);
    color: white;
    padding: 20px 48px;
    border-radius: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  .page-body :global(.cta-btn:hover) {
    color: white !important;
    background: var(--color-turquoise-dark);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(15, 181, 174, 0.3);
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 120px 0 40px;
    }

    .page-hero__content h1,
    .hero-suspended__content h1,
    .hero-mosaic h1,
    .hero-minimalist h1 {
      font-size: 2rem;
      text-align: center;
    }

    .hero-suspended__content p,
    .hero-mosaic p {
      text-align: center;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-minimalist--with-image {
      grid-template-columns: 1fr;
      gap: 20px;
      text-align: center;
    }

    .hero-minimalist__image {
      justify-self: center;
      width: min(100%, 240px);
    }

    /* Stack grid for Suspended (Servicios) */
    .hero-suspended {
      grid-template-columns: 1fr;
      gap: 40px;
      text-align: center;
    }

    .hero-suspended--trazabilidad {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .hero-suspended--trazabilidad .hero-suspended__content,
    .hero-suspended--trazabilidad .hero-suspended__image {
      width: 100%;
      margin: 0;
    }

    /* Stack flex for Mosaic (Soluciones) */
    .hero-mosaic {
      flex-direction: column;
      gap: 40px;
      text-align: center;
    }

    .hero-mosaic__desc-row {
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }

    .hero-cta {
      width: fit-content;
      margin: 0 auto;
    }

    .hero-suspended__image,
    .hero-mosaic__images {
      width: 100%;
      margin: 0 auto;
      order: 2; /* Put image/visuals below text */
    }

    .hero-suspended__content,
    .hero-mosaic__content {
      order: 1; /* Put text above image/visuals */
    }

    .page-body {
      padding: 40px 0 60px;
      text-align: center;
    }

    /* Center page body elements */
    .page-body :global(p) {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }

    .page-body :global(.cards-grid) {
      grid-template-columns: 1fr;
    }
  }
</style>
