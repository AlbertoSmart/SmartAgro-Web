---
import Layout from "../layouts/Layout.astro";

interface Props {
  title: string;
  heading: string;
  description?: string;
  variant?:
    | "tools"
    | "news"
    | "contact"
    | "idi"
    | "ayudas"
    | "sinergias"
    | "legal"
    | "solutions"
    | "eventos";
  layoutType?: "suspended" | "mosaic" | "minimalist";
  image?: string;
  mosaicImages?: string[];
}

const {
  title,
  heading,
  description = "",
  variant = "legal",
  layoutType = "minimalist",
  mosaicImages = [],
  image,
} = Astro.props;

// Specific data/visuals for different layouts
const showMosaic = layoutType === "mosaic";
const showSuspended = layoutType === "suspended";
const showMinimalist = layoutType === "minimalist";
---

<Layout title={`${title}`} showNewsletter={true}>
  <main>
    <section class={`page-hero page-hero--${variant} page-hero--${layoutType}`}>
      <div class="container page-hero__container">
        {showSuspended && (
          <div class="hero-suspended">
            <div class="hero-suspended__content">
              <h1>{heading}</h1>
              <p>{description}</p>
            </div>
            {image && (
              <div class="hero-suspended__image">
                <img src={image} alt={heading} />
              </div>
            )}
          </div>
        )}

        {showMosaic && (
          <div class="hero-mosaic">
            <div class="hero-mosaic__content">
              <h1>{heading}</h1>
              <p>{description}</p>
            </div>
            <div class="hero-mosaic__images">
              <div class="m-img m-img--1" style={mosaicImages[0] ? `background-image: url(${mosaicImages[0]})` : 'background: rgba(15, 181, 174, 0.1); border: 1px dashed rgba(255,255,255,0.2);'}></div>
              <div class="m-img m-img--2" style={mosaicImages[1] ? `background-image: url(${mosaicImages[1]})` : 'background: rgba(0,0,0,0.3); border: 1px dashed rgba(255,255,255,0.15);'}>
                {!mosaicImages[1] && <div class="fallback-viz">01010110</div>}
              </div>
            </div>
          </div>
        )}

        {showMinimalist && (
          <div class="hero-minimalist">
             <h1 class="text-weight-heavy">{heading}</h1>
          </div>
        )}
      </div>
    </section>
    
    <section class="page-body">
      <div class="container">
        <slot />
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-hero {
    position: relative;
    height: auto;
    min-height: 220px;
    padding: 160px 0 60px; /* Standardized for stable navbar */
    color: #FFFFFF !important;
    overflow: hidden;
    display: flex;
    align-items: center; 
    background: var(--color-slate-900);
    z-index: 1; 
    margin-top: 0;
  }

  .page-hero__container {
    width: 100%;
    position: relative;
    z-index: 10;
    margin-top: auto;
  }

  /* Variant Colors - Standardized for Consistency with "Esencia de Campo" */
  .page-hero--solutions { background: #0F1F1A !important; }
  .page-hero--tools { background: #0F1F1A !important; } 
  .page-hero--news { background: #0F1F1A !important; }
  .page-hero--contact { background: #0F1F1A !important; }
  .page-hero--ayudas { background: #0F1F1A !important; }
  .page-hero--eventos { background: #0F1F1A !important; }

  /* Breadcrumbs */
  .hero-breadcrumbs {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    font-weight: 700;
    opacity: 0.7; 
    margin-bottom: 24px;
    color: #FFFFFF; 
  }

  /* 01. Suspended Layout (Servicios) */
  .hero-suspended {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    position: relative;
    padding: 40px 0;
  }

  .hero-suspended__content h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    margin-bottom: 30px;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: #FFFFFF;
  }

  .hero-suspended__content p {
    font-size: 1.3rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 500px;
    line-height: 1.6;
    font-weight: 400;
  }

  .hero-suspended__image {
    position: relative;
    border-radius: 40px;
    overflow: hidden;
    box-shadow: 0 40px 100px -20px rgba(0,0,0,0.4);
    transform: translateY(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    max-width: 480px; 
    margin-left: auto;
  }

  .hero-suspended__image img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/10;
    object-fit: cover;
  }

  /* 02. Mosaic Layout (Soluciones) */
  .hero-mosaic {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    gap: 80px;
  }

  .hero-mosaic h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    margin-bottom: 30px;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: #FFFFFF;
  }

  .hero-mosaic p {
    font-size: 1.3rem;
    line-height: 1.6;
    max-width: 500px;
    color: rgba(255, 255, 255, 0.9);
  }

  /* 03. Minimalist Layout */
  .hero-minimalist {
    padding-bottom: 40px;
  }

  .text-weight-heavy {
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    margin: 0;
    line-height: 1.1;
    color: #FFFFFF;
  }

  .page-body {
    padding: 100px 0 140px;
    background: #FFFFFF;
  }

  .page-body :global(h2) {
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--color-slate-900);
    margin-bottom: 32px;
    margin-top: 80px;
    letter-spacing: -0.02em;
  }

  .page-body :global(h2:first-child) {
    margin-top: 0;
  }

  .page-body :global(p) {
    font-size: 1.15rem;
    line-height: 1.75;
    color: var(--color-slate-700);
    margin-bottom: 24px;
    max-width: 800px;
  }

  .page-body :global(.cards-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 40px;
    margin: 60px 0;
  }

  .page-body :global(.feature-card) {
    background: #FFFFFF;
    border-radius: 24px;
    padding: 48px 40px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    border: 1px solid var(--color-gray-100);
    transition: all 0.3s ease;
  }

  .page-body :global(.feature-card:hover) {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
  }

  .page-body :global(.feature-card h3) {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-slate-900);
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }

  .page-body :global(.feature-card p) {
    font-size: 1.05rem;
    color: var(--color-slate-600);
    line-height: 1.6;
    margin-bottom: 0;
  }

  .page-body :global(.highlight-box) {
    background: #0F1F1A !important;
    border-radius: 32px;
    padding: 80px 60px;
    color: white;
    margin: 80px 0;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .page-body :global(.highlight-box h3) {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 20px;
    color: white;
  }

  .page-body :global(.highlight-box p) {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.2rem;
    max-width: 700px;
    margin-bottom: 32px;
  }

  .page-body :global(.cta-btn) {
    display: inline-block;
    background: var(--color-turquoise);
    color: white;
    padding: 20px 48px;
    border-radius: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  .page-body :global(.cta-btn:hover) {
    background: var(--color-turquoise-dark);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(15, 181, 174, 0.3);
  }

  @media (max-width: 768px) {
    .page-hero__content h1 {
      font-size: 2rem;
    }
    .page-body {
      padding: 40px 0 60px;
    }
  }
</style>
