---
import Layout from "../../layouts/Layout.astro";
import { getPosts, deletePost } from "../../lib/blog";

// Check authentication
const auth = Astro.cookies.get("admin_auth");
if (!auth || auth.value !== "true") {
  return Astro.redirect("/admin/login");
}

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const idToDelete = data.get("delete-id")?.toString();
  if (idToDelete) {
    await deletePost(idToDelete);
  }
}

const posts = await getPosts();
---

<Layout title="Dashboard Admin – Smart Fenix" showNewsletter={false}>
  <main class="admin-dashboard">
    <div class="container wide">
      <header class="dashboard-header">
        <div>
          <h1>Panel de Control</h1>
          <p>Bienvenido, SmartFenix. Gestiona las publicaciones y categorías.</p>
        </div>
        <div class="header-actions">
          <a href="/admin/categorias" class="btn-secondary-admin">Gestionar Categorías</a>
          <a href="/admin/nuevo-post" class="btn-new">Crear Nueva Publicación</a>
        </div>
      </header>

      <section class="posts-list-section">
        <div class="table-wrapper card">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Fecha</th>
                <th>Título</th>
                <th>Categoría</th>
                <th class="text-right">Acciones</th>
              </tr>
            </thead>
            <tbody>
              {posts.map(post => (
                <tr>
                  <td class="date-cell">{post.date}</td>
                  <td class="title-cell"><strong>{post.title}</strong></td>
                  <td><span class="badge">{post.categoryName}</span></td>
                  <td class="text-right">
                    <div class="actions-group">
                      <a href={`/admin/editar-post/${post.id}`} class="btn-edit">Editar</a>
                      <form method="POST" style="display:inline">
                        <input type="hidden" name="delete-id" value={post.id} />
                        <button type="submit" class="btn-delete" onclick="return confirm('¿Seguro que quieres borrar este post?')">Borrar</button>
                      </form>
                    </div>
                  </td>
                </tr>
              ))}
              {posts.length === 0 && (
                <tr>
                  <td colspan="4" class="empty-state">No hay publicaciones disponibles.</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .admin-dashboard {
    background: #f8fafc;
    min-height: 100vh;
    padding: 120px 0 80px;
  }

  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
  }

  .dashboard-header h1 {
    font-size: 2.2rem;
    font-weight: 850;
    color: #0b1a14;
    margin-bottom: 8px;
  }

  .dashboard-header p {
    color: #64748b;
  }

  .header-actions {
    display: flex;
    gap: 15px;
  }

  .btn-new {
    background: var(--color-turquoise);
    color: white;
    padding: 14px 24px;
    border-radius: 12px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-new:hover {
    background: var(--color-turquoise-dark);
    transform: translateY(-2px);
  }

  .btn-secondary-admin {
    background: #FFFFFF;
    color: #0b1a14;
    border: 1px solid #e2e8f0;
    padding: 14px 24px;
    border-radius: 12px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-secondary-admin:hover {
    background: #f8fafc;
    border-color: #cbd5e1;
  }

  .actions-group {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
  }

  .btn-edit {
    display: inline-block;
    padding: 8px 16px;
    background: #f1f5f9;
    color: #475569;
    border-radius: 8px;
    font-weight: 700;
    text-decoration: none;
    font-size: 0.85rem;
    transition: all 0.2s ease;
  }

  .btn-edit:hover {
    background: #e2e8f0;
    color: #1e293b;
  }

  .admin-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  .admin-table th {
    padding: 20px;
    background: #f1f5f9;
    color: #475569;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .admin-table td {
    padding: 20px;
    border-bottom: 1px solid #f1f5f9;
    color: #1a1a1a;
  }

  .card {
    background: white;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.02);
    border: 1px solid #eef2f1;
    overflow: hidden;
  }

  .badge {
    padding: 4px 10px;
    background: rgba(29, 185, 154, 0.1);
    color: var(--color-turquoise);
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .text-right { text-align: right; }

  .btn-delete {
    background: #fee2e2;
    color: #b91c1c;
    border: none;
    padding: 8px 16px;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-delete:hover {
    background: #fecaca;
  }

  .date-cell { color: #64748b; font-size: 0.9rem; }

  .empty-state {
    padding: 60px !important;
    text-align: center;
    color: #94a3b8;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .admin-dashboard { padding: 90px 12px 40px; }
    .dashboard-header {
      flex-direction: column;
      align-items: stretch;
      gap: 20px;
      margin-bottom: 30px;
    }
    .dashboard-header h1 { font-size: 1.8rem; }
    .header-actions { flex-direction: column; gap: 10px; }
    .btn-new, .btn-secondary-admin { text-align: center; width: 100%; }

    /* Table mobile optimization */
    .admin-table th:nth-child(1),
    .admin-table td:nth-child(1) {
      display: none; /* Hide date on mobile */
    }
    .admin-table th:nth-child(3),
    .admin-table td:nth-child(3) {
      display: none; /* Hide category on small mobile */
    }
    .admin-table th, .admin-table td { padding: 15px 10px; font-size: 0.85rem; }
    .actions-group { gap: 6px; }
    .btn-edit, .btn-delete { padding: 6px 12px; font-size: 0.75rem; }
  }
</style>
