---
import Layout from "../../layouts/Layout.astro";

let error = "";
if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const user = data.get("username");
    const pass = data.get("password");

    if (user === "SmartFenix" && pass === "Seguridad01") {
      // Set a simple auth cookie
      Astro.cookies.set("admin_auth", "true", { path: "/", httpOnly: true, maxAge: 3600 * 24 });
      return Astro.redirect("/admin/dashboard");
    } else {
      error = "Usuario o contraseña incorrectos.";
    }
  } catch (e) {
    if (e instanceof Error) error = e.message;
  }
}
---

<Layout title="Admin Login – Smart Fenix" showNewsletter={false}>
  <main class="login-wrapper">
    <div class="container tiny-container">
      <div class="login-card">
        <header class="login-header">
          <span class="lock-icon">🔒</span>
          <h1>Acceso Administrador</h1>
          <p>Gestión del ecosistema digital</p>
        </header>

        <form method="POST" class="login-form">
          {error && <div class="error-msg">{error}</div>}
          
          <div class="field">
            <label for="username">Usuario</label>
            <input type="text" id="username" name="username" required placeholder="SmartFenix" />
          </div>

          <div class="field">
            <label for="password">Contraseña</label>
            <input type="password" id="password" name="password" required placeholder="••••••••" />
          </div>

          <button type="submit" class="btn-login">Entrar al Panel</button>
        </form>
      </div>
    </div>
  </main>
</Layout>

<style>
  .login-wrapper {
    background: #f8fafc;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 80px 20px;
  }

  .tiny-container {
    max-width: 440px;
    margin: 0 auto;
  }

  .login-card {
    background: white;
    padding: 50px;
    border-radius: 24px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.05);
    border: 1px solid #eef2f1;
  }

  .login-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .lock-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 15px;
  }

  .login-header h1 {
    font-size: 1.8rem;
    font-weight: 850;
    color: #0b1a14;
    margin-bottom: 8px;
  }

  .login-header p {
    color: #64748b;
    font-size: 0.95rem;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .field label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #334155;
    letter-spacing: 0.05em;
  }

  .field input {
    padding: 16px;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    font-size: 1rem;
    outline: none;
    transition: all 0.3s ease;
  }

  .field input:focus {
    border-color: var(--color-turquoise);
    box-shadow: 0 0 0 4px rgba(29, 185, 154, 0.1);
  }

  .btn-login {
    background: var(--color-turquoise);
    color: white;
    padding: 18px;
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 10px;
  }

  .btn-login:hover {
    background: var(--color-turquoise-dark);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(29, 185, 154, 0.2);
  }

  .error-msg {
    background: #fee2e2;
    color: #b91c1c;
    padding: 15px;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 600;
    text-align: center;
  }
</style>
