      padding-top: 80px;
  }
  .doc-links { list-style: none; padding: 0; }
  .doc-links li { margin-bottom: 20px; }
  .doc-links a { color: #2563eb; font-weight: 700; text-decoration: none; font-size: 1.1rem; }
  .doc-links a:hover { text-decoration: underline; }

  /* FEATURE CARD */
  .feature-card {
    background: white;
    border-radius: 20px;
    padding: 40px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    border: 1px solid #eef2f1;
    text-align: center;
    max-width: 500px;
    margin: 0 auto;
    margin-top: 25px;
  }

  .card-icon {
