    margin-top: 24px;
  }
  .cta-btn {
    background: #1DB99A;
    color: white;
    padding: 12px 32px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
    display: inline-block;
    transition: all 0.3s ease;
  }
  .cta-btn:hover {
    background: #0d9b85;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(29, 185, 154, 0.2);
  }

  @media (max-width: 900px) {
    .guide-layout { grid-template-columns: 1fr; gap: 40px; margin-top: 40px; }
    .guide-sidebar { display: none; }
    .container-guide { padding: 0 24px; }
    .section-title { font-size: 1.8rem; }
  }

  @media (max-width: 768px) {
    .guide-hero {
      padding: 16px 0 10px !important;
    }
    .guide-hero h1 {
