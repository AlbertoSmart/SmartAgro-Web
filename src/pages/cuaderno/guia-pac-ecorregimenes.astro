    margin-bottom: 24px;
  }

  /* IMAGES */
  .featured-img {
    max-width: 800px;
    width: 100%;
    display: block;
    margin: 0 auto 16px;
    border-radius: 20px;
    box-shadow: 0 30px 60px rgba(0,0,0,0.1);
