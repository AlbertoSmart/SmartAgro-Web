  /* LINKS */
  .link-highlight {
    color: #1DB99A;
    font-weight: 800;
    text-decoration: none;
    display: inline-block;
    padding: 12px 0;
    border-bottom: 2px solid transparent;
    transition: all 0.3s;
  }
  .link-highlight:hover { border-bottom-color: #1DB99A; }

  /* TABLE */
  .table-wrap {
