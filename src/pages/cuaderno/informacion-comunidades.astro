---

<Layout title="Directorio SIEX y CUE por Comunidad Autónoma">
  <main class="cue-directory">
    <!-- HERO SECTION -->
    <section class="expert-hero-solid">
      <div class="container">
        <h1>Directorio de CUE por Comunidad Autónoma</h1>
        <p>
          Recopilación exhaustiva de interfaces oficiales, modelos de autorización y canales de soporte técnico facilitados para el cumplimiento del SIEX nacional.
        </p>
      </div>
    </section>

    <!-- CONTENT WRAPPER -->
    <section class="directory-list-section">
      <div class="container-strict">
        <div class="search-bar-wrap">
          <input type="text" id="commSearch" placeholder="Busca tu Comunidad Autónoma..." />
        </div>

        <div class="communities-stack" id="commList">
          {communities.map((comm) => (
            <article class="editorial-row" data-name={comm.name.toLowerCase()}>
              <div class="editorial-row__flag">
                <div class="flag-container">
                  <img src={comm.flag} alt={`Bandera de ${comm.name}`} />
                </div>
              </div>
              <div class="editorial-row__content">
                <h2 class="row-title">CUE {comm.name}</h2>
                <div class="row-text">
                  {comm.content.map((p) => (
                    <p>{p}</p>
                  ))}
                </div>
                
                <div class="row-links">
                  {comm.links.map((link) => (
                    <a href={link.url} target="_blank" rel="noopener noreferrer" class="link-action">
                      {link.label} →
                    </a>
                  ))}
                </div>

                {comm.support && (
                  <div class="row-support">
                    <h3>Atención al Usuario:</h3>
                    <ul>
                      {comm.support.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const search = document.getElementById("commSearch") as HTMLInputElement;
    const entries = document.querySelectorAll(".editorial-row");

    if (search) {
      search.addEventListener("input", (e) => {
        const query = (e.target as HTMLInputElement).value.toLowerCase();
        entries.forEach((el) => {
          const name = el.getAttribute("data-name") || "";
          if (name.includes(query)) {
            (el as HTMLElement).style.display = "grid";
          } else {
            (el as HTMLElement).style.display = "none";
          }
        });
      });
    }
  });
</script>

<style>
  /* GLOBAL CONTAINER FOR ALIGNMENT */
  .container-strict {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 40px;
      width: 100%;
  }

  .cue-directory {
    background: #ffffff;
    min-height: 100vh;
  }

  /* HERO */
  .expert-hero-solid {
    padding: 20px 0 12px !important;
    background: #0b1a14 !important;
    color: white;
    text-align: center;
  }
  .expert-hero-solid h1 { font-size: 3.5rem; font-weight: 800; color: white !important; margin-bottom: 16px; }
  .expert-hero-solid .pre-title { font-size: 0.85rem; letter-spacing: 0.3em; color: var(--color-turquoise); font-weight: 700; margin-bottom: 20px; display: block; }
  .expert-hero-solid p { font-size: 1.25rem; color: rgba(255,255,255,0.7); max-width: 800px; margin: 0 auto; line-height: 1.6; }

  /* SEARCH */
  .directory-list-section {
      padding-bottom: 120px;
  }
  .search-bar-wrap {
      max-width: 600px;
      margin: 16px auto 80px;
      position: relative;
      z-index: 10;
  }
  .search-bar-wrap input {
      width: 100%;
      padding: 24px 32px;
      border-radius: 50px;
      border: 1px solid #e2e8f0;
      box-shadow: 10px 10px 40px rgba(0,0,0,0.05);
      font-size: 1.1rem;
      outline: none;
      background: white;
  }

  /* ROWS */
  .communities-stack {
      display: flex;
      flex-direction: column;
      gap: 100px;
  }

  /* THIS IS THE CRITICAL ALIGNMENT RULE */
  .editorial-row {
      display: grid;
      grid-template-columns: 320px 1fr; /* RIGID COLUMN WIDTH */
      gap: 80px;
      align-items: flex-start;
      border-bottom: 1px solid #f1f3f5;
      padding-bottom: 80px;
      width: 100%;
  }

  .editorial-row__flag {
      width: 320px; /* SAME AS GRID COLUMN */
  }

  .flag-container {
      width: 100%;
      aspect-ratio: 3 / 2; /* Force uniform shape */
      background: #f8fafc;
      box-shadow: 0 20px 50px rgba(0,0,0,0.15);
      border-radius: 4px;
      overflow: hidden;
      border: 1px solid rgba(0,0,0,0.05);
      display: flex;
      align-items: center;
      justify-content: center;
  }

  .flag-container img {
      width: 100%;
      height: 100%;
      object-fit: contain; /* Don't distort the flag */
      padding: 0; /* Align to the box edges */
      display: block;
  }

  .editorial-row__content {
      flex: 1;
  }

  .row-title {
      font-size: 2.2rem;
      font-weight: 850;
      margin-bottom: 24px;
      color: var(--color-turquoise-dark) !important;
      letter-spacing: -0.02em;
  }

  .row-text p {
      font-size: 1.1rem;
      color: #334155;
      line-height: 1.8;
      margin-bottom: 15px;
  }

  .row-links {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin: 32px 0;
  }

  .link-action {
      color: #2c3e7b;
      font-weight: 700;
      text-decoration: none;
      font-size: 1.15rem;
      transition: color 0.2s;
  }
  .link-action:hover {
      color: var(--color-turquoise);
      text-decoration: underline;
  }

  .row-support {
      background: #f8fafc;
      padding: 30px;
      border-radius: 12px;
      border: 1px solid #eef2f6;
  }
  .row-support h3 {
      font-size: 0.9rem;
      font-weight: 800;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 16px;
  }
  .row-support ul { list-style: none; padding: 0; }
  .row-support li {
      font-size: 1rem;
      color: #475569;
      margin-bottom: 10px;
      position: relative;
      padding-left: 20px;
  }
  .row-support li::before {
      content: "→";
      position: absolute;
      left: 0;
      color: var(--color-turquoise);
  }

  @media (max-width: 991px) {
      .container-strict { padding: 0 20px; }
      .editorial-row {
          grid-template-columns: 1fr;
          gap: 40px;
