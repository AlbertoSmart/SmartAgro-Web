    ],
    support: ["Email: jvalence@navarra.es"]
  },
  {
    id: "pais-vasco",
    name: "País Vasco",
    flag: "https://upload.wikimedia.org/wikipedia/commons/2/2d/Flag_of_the_Basque_Country.svg",
