const { slug } = Astro.params;
const comm = communities.find(c => c.id === slug);

if (!comm) {
  return Astro.redirect('/404');
}
---

<Layout title={`CUE y normativa SIEX en ${comm.name}`}>
  <main class="community-page">
    <!-- HERO -->
    <section class="expert-hero-solid">
      <div class="container">
        <div class="hero-flex">
          <div class="hero-text">
            <span class="pre-title">DIRECTORIO REGIONAL SIEX</span>
            <h1>{comm.name}</h1>
            <p>
              Información técnica y enlaces oficiales para la gestión del Cuaderno Digital (CUE) cumpliendo con la normativa del SIEX en {comm.name}.
            </p>
          </div>
          <div class="hero-flag">
            <img src={comm.flag} alt={`Bandera de ${comm.name}`} />
          </div>
        </div>
      </div>
    </section>

    <!-- CONTENT -->
    <section class="community-details">
      <div class="container-strict">
        <div class="details-grid">
          <div class="main-info">
             <div class="info-card">
               <h2>Trámites y Requisitos Administritativos</h2>
               {comm.content.map((p: string) => (
                 <p>{p}</p>
               ))}
             </div>

             <div class="link-group">
               <h3>Enlaces de Acceso Directo</h3>
               <div class="links-stack">
                 {comm.links.map((link: any) => (
                   <a href={link.url} target="_blank" rel="noopener noreferrer" class="link-card">
                     <span class="label">{link.label}</span>
                     <span class="arrow">→</span>
                   </a>
                 ))}
               </div>
             </div>
          </div>

          <aside class="sidebar-info">
            <div class="support-card">
              <h3>Soporte Técnico Especializado</h3>
              <ul>
                {comm.support.map((item: string) => (
                   <li>{item}</li>
                ))}
              </ul>
            </div>

            <div class="cta-card">
              <h3>¿Necesitas ayuda técnica?</h3>
              <p>Nuestros ingenieros agrónomos te ayudan a digitalizar tu cuaderno en {comm.name}.</p>
              <a href="/contacto" class="btn-primary">Hablar con un Ingeniero</a>
            </div>
            
            <a href="/cuaderno/informacion-comunidades" class="back-link">← Volver al directorio completo</a>
          </aside>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .community-page {
    background: #ffffff;
    min-height: 100vh;
  }

  .container-strict {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 40px;
  }

  /* HERO */
  .expert-hero-solid {
    padding: 160px 0 100px;
    background: #0b1a14;
    color: white;
  }
  .hero-flex {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 60px;
  }
  .hero-text { flex: 1; }
  .hero-text h1 { font-size: 4rem; font-weight: 850; color: white; margin-bottom: 20px; }
  .hero-text .pre-title { font-size: 0.8rem; letter-spacing: 0.3em; color: var(--color-turquoise); font-weight: 700; margin-bottom: 20px; display: block; }
  .hero-text p { font-size: 1.2rem; color: rgba(255,255,255,0.7); line-height: 1.6; }
  
  .hero-flag {
    width: 250px;
    height: 160px;
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }
  .hero-flag img { width: 100%; height: 100%; object-fit: cover; }

  /* DETAILS */
  .community-details {
    padding: 100px 0;
  }
  .details-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 80px;
  }

  .info-card h2 { font-size: 1.8rem; color: #0b1a14; margin-bottom: 30px; font-weight: 800; }
  .info-card p { font-size: 1.1rem; color: #334155; line-height: 1.8; margin-bottom: 20px; }

  .link-group { margin-top: 60px; }
  .link-group h3 { font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.1em; color: #64748b; margin-bottom: 24px; font-weight: 700; }
  
  .links-stack { display: flex; flex-direction: column; gap: 15px; }
  .link-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 30px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .link-card .label { font-weight: 700; color: #0b1a14; font-size: 1.1rem; }
  .link-card .arrow { color: var(--color-turquoise); font-weight: 900; }
  .link-card:hover { 
    background: white;
    border-color: var(--color-turquoise);
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    transform: translateY(-2px);
  }

  /* SIDEBAR */
  .sidebar-info { display: flex; flex-direction: column; gap: 30px; }
  .support-card {
    background: #f1f5f9;
    padding: 30px;
    border-radius: 15px;
  }
  .support-card h3 { font-size: 0.9rem; font-weight: 800; color: #475569; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px; }
  .support-card ul { list-style: none; padding: 0; }
  .support-card li { font-size: 0.95rem; color: #334155; margin-bottom: 12px; position: relative; padding-left: 20px; }
  .support-card li::before { content: "•"; color: var(--color-turquoise); position: absolute; left: 0; font-weight: 900; }

  .cta-card {
    background: linear-gradient(135deg, #0b1a14 0%, #1a3a2e 100%);
    padding: 40px;
    border-radius: 15px;
    color: white;
  }
  .cta-card h3 { 
    font-size: 1.6rem; 
    font-weight: 850; 
    color: #ffffff !important; 
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }
  .cta-card p { 
    font-size: 1.1rem; 
    color: rgba(255,255,255,0.95) !important; 
    margin-bottom: 30px; 
    line-height: 1.6; 
  }
  .btn-primary {
    display: block;
    text-align: center;
    padding: 15px;
    background: var(--color-turquoise);
    color: #0b1a14;
    font-weight: 700;
    border-radius: 8px;
    text-decoration: none;
  }

  .back-link {
    font-weight: 700;
    color: #475569;
    text-decoration: none;
    font-size: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
  }
  .back-link:hover { color: var(--color-turquoise); }

  @media (max-width: 991px) {
    .hero-flex { flex-direction: column; text-align: center; }
    .hero-flag { margin: 0 auto; }
    .details-grid { grid-template-columns: 1fr; gap: 60px; }
  }

  @media (max-width: 768px) {
    .expert-hero-solid {
      padding: 120px 0 60px;
    }
    .hero-text h1 {
      font-size: 2.2rem;
    }
    .hero-text p {
      font-size: 1.1rem;
    }
    .hero-flag {
      width: 100%;
      max-width: 200px;
      height: auto;
      aspect-ratio: 3/2;
    }
    .community-details {
      padding: 60px 0;
    }
    .container-strict {
      padding: 0 24px;
    }
    .info-card h2 {
      font-size: 1.6rem;
    }
    .info-card p {
      font-size: 1rem;
    }
    .link-card {
      padding: 16px 20px;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
    .link-card .arrow {
      align-self: flex-end;
      margin-top: -30px;
    }
    .cta-card {
      padding: 30px 24px;
    }
    .cta-card h3 {
      font-size: 1.4rem;
    }
    .cta-card p {
      font-size: 1rem;
    }
    .main-info, .sidebar-info {
      min-width: 0;
      max-width: 100%;
    }
    p, h1, h2, h3, h4, span, li, a {
      word-break: break-word;
      hyphens: auto;
    }
  }
</style>
