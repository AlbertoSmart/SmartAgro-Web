---
import TestPage from "../layouts/TestPage.astro";
---

<TestPage
  title="Centro de Soporte – Cuaderno de Campo Digital"
  heading="Centro de Soporte y Ayuda"
  description="Encuentra tutoriales, guías técnicas y soporte especializado para maximizar el rendimiento de tu explotación agrícola."
  variant="ayudas"
>
  <div class="support-hub">
    <div class="support-categories">
      <div class="category-block glass">
        <h3>Primeros Pasos</h3>
        <ul class="support-links">
          <li><a href="#">Cómo instalar los sensores de campo</a></li>
          <li><a href="#">Configuración inicial de la plataforma</a></li>
          <li><a href="#">Vinculación de parcelas REA</a></li>
        </ul>
      </div>

      <div class="category-block glass">
        <h3>Gestión Digital</h3>
        <ul class="support-links">
          <li><a href="#">Generación del cuaderno CUE</a></li>
          <li><a href="#">Firma electrónica de documentos</a></li>
          <li><a href="#">Validación de productos fitosanitarios</a></li>
        </ul>
      </div>

      <div class="category-block glass">
        <h3>Tecnología e IA</h3>
        <ul class="support-links">
          <li><a href="#">Entrenamiento con Roboflow</a></li>
          <li><a href="#">Alertas de plagas YOLO en tiempo real</a></li>
          <li><a href="#">Mantenimiento de cámaras inteligentes</a></li>
        </ul>
      </div>
    </div>

    <div class="video-tutorials glass">
      <div class="video-header">
        <h2>Tutoriales en Vídeo</h2>
        <p>Aprende visualmente con nuestras guías rápidas.</p>
      </div>
      <div class="video-grid">
        <div class="video-miniature">
          <div class="play-icon">▶</div>
          <span>Instalación en 5 minutos</span>
        </div>
        <div class="video-miniature">
          <div class="play-icon">▶</div>
          <span>Uso de la App Móvil</span>
        </div>
        <div class="video-miniature">
          <div class="play-icon">▶</div>
          <span>Reporte SIEX paso a paso</span>
        </div>
      </div>
    </div>
  </div>

  <style>
    .support-hub {
      display: flex;
      flex-direction: column;
      gap: 48px;
      margin-top: -60px;
    }

    .support-categories {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 32px;
    }

    .category-block {
      background: white;
      padding: 40px;
      border-radius: 24px;
      border: 1px solid var(--color-gray-100);
    }

    .category-block h3 {
      font-size: 1.25rem;
      margin-bottom: 24px;
      color: var(--color-gray-900);
      position: relative;
      padding-bottom: 12px;
    }

    .category-block h3::after {
      content: "";
      position: absolute;
      bottom: 0;
      left: 0;
      width: 40px;
      height: 3px;
      background: var(--color-turquoise);
      border-radius: 2px;
    }

    .support-links {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .support-links a {
      color: var(--color-gray-600);
      text-decoration: none;
      font-size: 0.95rem;
      transition: all 0.2s ease;
      display: block;
    }

    .support-links a:hover {
      color: var(--color-turquoise-dark);
      transform: translateX(4px);
    }

    .video-tutorials {
      background: #f8fafc;
      padding: 60px;
      border-radius: 32px;
      border: 1px solid var(--color-gray-200);
    }

    .video-header {
      text-align: center;
      margin-bottom: 40px;
    }

    .video-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 24px;
    }

    .video-miniature {
      aspect-ratio: 16/9;
      background: #cbd5e1;
      border-radius: 12px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 700;
      gap: 12px;
      cursor: pointer;
      position: relative;
      transition: all 0.3s ease;
    }

    .video-miniature:hover {
      background: var(--color-gray-800);
    }

    .play-icon {
      width: 50px;
      height: 50px;
      background: var(--color-turquoise);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    }
  </style>
</TestPage>
