---
import Layout from "../layouts/Layout.astro";
import { getPosts } from "../lib/blog";

const posts = await getPosts();

const monthMap: Record<string, number> = {
  ENE: 0,
  FEB: 1,
  MAR: 2,
  ABR: 3,
  MAY: 4,
  JUN: 5,
  JUL: 6,
  AGO: 7,
  SEP: 8,
  OCT: 9,
  NOV: 10,
  DIC: 11,
};

function parseSpanishDate(date: string) {
  const [day, month, year] = date.trim().toUpperCase().split(/\s+/);
  const monthIndex = monthMap[month];

  if (!day || monthIndex === undefined || !year) {
    return new Date(0);
  }

  return new Date(Number(year), monthIndex, Number(day));
}

const sortedPosts = [...posts].sort(
  (a, b) => parseSpanishDate(a.date).getTime() - parseSpanishDate(b.date).getTime()
);

const totalPosts = sortedPosts.length;
const earliestPost = sortedPosts[0];
const latestPost = sortedPosts.at(-1);
const categoryNames = [...new Set(sortedPosts.map((post) => post.categoryName))];
---

<Layout title="Blog Tecnico Agronomico - Smart Fenix">
  <main class="blog-container">
    <header class="blog-hero">
      <div class="container wide">
        <div class="hero-shell">
          <div class="hero-copy">
            <span class="hero-eyebrow">Observatorio agronomico digital</span>
            <h1>Normativa, sensores e inteligencia aplicada al campo.</h1>
            <p class="hero-description">
              Una biblioteca tecnica pensada para agricultores y asesores que necesitan
              claridad, criterio y una lectura rapida del contexto regulatorio y
              tecnologico.
            </p>

            <div class="hero-metrics">
              <div class="hero-metric">
                <span class="hero-metric__label">Orden editorial</span>
                <strong>De lo mas antiguo a lo mas reciente</strong>
              </div>
              <div class="hero-metric">
                <span class="hero-metric__label">Publicaciones</span>
                <strong>{totalPosts} articulos tecnicos</strong>
              </div>
              <div class="hero-metric">
                <span class="hero-metric__label">Cobertura</span>
                <strong>{categoryNames.length} enfoques agronomicos</strong>
              </div>
            </div>
          </div>

          {latestPost && (
            <a href={`/blog/${latestPost.id}`} class="hero-featured">
              <span class="hero-featured__label">Ultima lectura incorporada</span>
              <h2>{latestPost.title}</h2>
              <p>{latestPost.excerpt}</p>
              <div class="hero-featured__meta">
                <span>{latestPost.categoryName}</span>
                <span>{latestPost.date}</span>
              </div>
            </a>
          )}
        </div>
      </div>
    </header>

    <div class="container wide blog-main-layout">
      <div class="blog-feed">
        <section class="feed-intro">
          <div>
            <span class="section-kicker">Cronologia editorial</span>
            <h2>Lecturas ordenadas para entender como evoluciona el cuaderno digital.</h2>
          </div>
          <p>
            El recorrido va desde las bases tecnicas y fisiologicas hasta los requisitos
            operativos y la capa de automatizacion con IA.
          </p>
        </section>

        <section class="posts-grid" aria-label="Articulos del blog">
          {sortedPosts.map((post, index) => (
            <article class="blog-card-clean">
              <a href={`/blog/${post.id}`} class="card-image">
                <img src={post.image} alt={post.title} />
              </a>

              <div class="card-body">
                <div class="card-topline">
                  <span class="card-order">#{String(index + 1).padStart(2, "0")}</span>
                  <span class="card-category">{post.categoryName}</span>
                </div>

                <h3 class="card-title">
                  <a href={`/blog/${post.id}`}>{post.title}</a>
                </h3>

                <p class="card-excerpt">{post.excerpt}</p>

                <div class="card-footer">
                  <span class="card-date">{post.date}</span>
                  <a href={`/blog/${post.id}`} class="read-more">Leer analisis</a>
                </div>
              </div>
            </article>
          ))}
        </section>
      </div>

      <aside class="blog-sidebar">
        <div class="sidebar-stack">
          <section class="sidebar-widget sidebar-widget--summary">
            <span class="sidebar-kicker">Mapa del blog</span>
            <h3>Panorama rapido</h3>

            <div class="sidebar-stat-grid">
              <div class="sidebar-stat">
                <strong>{totalPosts}</strong>
                <span>Articulos publicados</span>
              </div>
              <div class="sidebar-stat">
                <strong>{categoryNames.length}</strong>
                <span>Lineas tematicas</span>
              </div>
            </div>

            <div class="timeline-range">
              <span class="timeline-range__label">Rango temporal</span>
              <strong>{earliestPost?.date} -> {latestPost?.date}</strong>
            </div>
          </section>

          <section class="sidebar-widget">
            <span class="sidebar-kicker">Claves editoriales</span>
            <h3>Que vas a encontrar aqui</h3>
            <div class="sidebar-list">
              <div class="sidebar-list__item">
                <strong>Normativa util</strong>
                <p>Interpretaciones practicas para cumplir sin perder tiempo entre boletines.</p>
              </div>
              <div class="sidebar-list__item">
                <strong>Lectura de sensores</strong>
                <p>Contenido para traducir datos de suelo, clima y planta en decisiones reales.</p>
              </div>
              <div class="sidebar-list__item">
                <strong>Automatizacion</strong>
                <p>Procesos y herramientas para conectar el dato tecnico con la gestion diaria.</p>
              </div>
            </div>
          </section>

          <section class="sidebar-widget sidebar-widget--accent">
            <span class="sidebar-kicker">Servicio destacado</span>
            <h3>Trazabilidad GPS DARP</h3>
            <p class="sidebar-note">
              Certifica aplicaciones y transportes ante la administracion con informes de
              rutas, coberturas y evidencias listas para revisar.
            </p>
            <a href="/herramientas/trazabilidad" class="widget-link">Explorar servicio</a>
          </section>

          <section class="sidebar-widget sidebar-widget--status">
            <span class="sidebar-kicker">Seguimiento normativo</span>
            <h3>Estado del SIEX <span class="pulse-green"></span></h3>
            <p class="status-ok">Sistema operativo</p>
            <p class="sidebar-note">
              Proximo hito: registro mensual de fitosanitarios. Plazo de 30 dias tras la
              aplicacion.
            </p>
            <a href="https://www.fega.es" target="_blank" class="widget-link">Ir al portal FEGA</a>
          </section>
        </div>
      </aside>
    </div>
  </main>
</Layout>

<style>
  .blog-container {
    min-height: 100vh;
    color: #0f172a;
    background:
      radial-gradient(circle at top left, rgba(29, 185, 154, 0.12), transparent 28%),
      linear-gradient(180deg, #f4f7f6 0%, #ffffff 24%, #f8fbfa 100%);
  }

  .container.wide {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .blog-hero {
    position: relative;
    overflow: hidden;
    padding: 44px 0 28px !important;
    background:
      radial-gradient(circle at top right, rgba(29, 185, 154, 0.2), transparent 28%),
      linear-gradient(135deg, #08130f 0%, #0b1a14 58%, #153126 100%);
    color: #ffffff !important;
  }

  .blog-hero::after {
    content: "";
    position: absolute;
    inset: auto 0 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.25), transparent);
  }

  .hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 430px);
    gap: 36px;
    align-items: end;
  }

  .hero-copy {
    max-width: 760px;
  }

  .hero-eyebrow,
  .section-kicker,
  .sidebar-kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-eyebrow {
    color: rgba(255, 255, 255, 0.78);
    margin-bottom: 18px;
  }

  .hero-eyebrow::before,
  .section-kicker::before,
  .sidebar-kicker::before {
    content: "";
    width: 28px;
    height: 1px;
    background: currentColor;
    opacity: 0.75;
  }

  .blog-hero h1 {
    max-width: 11ch;
    margin: 0 0 18px;
    font-size: clamp(2.9rem, 5vw, 5.2rem);
    line-height: 0.96;
    letter-spacing: -0.04em;
    color: #ffffff;
  }

  .hero-description {
    max-width: 62ch;
    margin: 0 0 28px;
    font-size: 1.08rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.82);
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .hero-metric,
  .hero-featured,
  .sidebar-widget,
  .blog-card-clean {
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 20px 40px -26px rgba(15, 23, 42, 0.34);
  }

  .hero-metric {
    padding: 18px 18px 20px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .hero-metric__label {
    display: block;
    margin-bottom: 8px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
  }

  .hero-metric strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.35;
    color: #ffffff;
  }

  .hero-featured {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 26px;
    border-radius: 28px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.08));
    color: #ffffff;
    text-decoration: none;
    transition: transform 0.35s ease, border-color 0.35s ease, background 0.35s ease;
  }

  .hero-featured:hover {
    transform: translateY(-6px);
    border-color: rgba(29, 185, 154, 0.5);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.1));
    color: #ffffff !important;
  }

  .hero-featured__label {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.66);
  }

  .hero-featured h2 {
    margin: 0;
    font-size: 1.6rem;
    line-height: 1.15;
    color: #ffffff;
  }

  .hero-featured p {
    margin: 0;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.7;
  }

  .hero-featured__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: auto;
  }

  .hero-featured__meta span {
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    font-size: 0.77rem;
    font-weight: 700;
    color: #ffffff;
  }

  .blog-main-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 38px;
    padding: 46px 32px 72px;
    align-items: start;
  }

  .blog-feed {
    min-width: 0;
  }

  .feed-intro {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: end;
    margin-bottom: 30px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(15, 23, 42, 0.09);
  }

  .section-kicker {
    color: var(--color-turquoise-dark);
    margin-bottom: 12px;
  }

  .feed-intro h2 {
    max-width: 15ch;
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  .feed-intro p {
    max-width: 34ch;
    margin: 0;
    color: #475569;
    line-height: 1.75;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 28px;
  }

  .blog-card-clean {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    overflow: hidden;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.94);
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease,
      border-color 0.35s ease;
  }

  .blog-card-clean:hover {
    transform: translateY(-8px);
    border-color: rgba(29, 185, 154, 0.34);
    box-shadow: 0 28px 60px -32px rgba(15, 23, 42, 0.38);
  }

  .card-image {
    position: relative;
    display: block;
    height: 250px;
    overflow: hidden;
    background: #dfe8e5;
  }

  .card-image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 25%, rgba(11, 26, 20, 0.22) 100%);
    opacity: 0.9;
    pointer-events: none;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .blog-card-clean:hover .card-image img {
    transform: scale(1.06);
  }

  .card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 16px;
    padding: 26px;
  }

  .card-topline {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .card-order,
  .card-category,
  .card-date {
    display: inline-flex;
    align-items: center;
    padding: 8px 12px;
    border-radius: 999px;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .card-order {
    background: #0b1a14;
    color: #ffffff;
  }

  .card-category {
    background: rgba(29, 185, 154, 0.12);
    color: var(--color-turquoise-dark);
  }

  .card-title {
    margin: 0;
    font-size: 1.55rem;
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .card-title a {
    color: #0f172a;
    text-decoration: none;
  }

  .card-title a:hover {
    color: #0f172a;
  }

  .card-excerpt {
    margin: 0;
    color: #475569;
    line-height: 1.75;
    flex: 1;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    padding-top: 2px;
  }

  .card-date {
    background: #f1f5f9;
    color: #334155;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-turquoise-dark);
  }

  .read-more::after {
    content: ">";
    font-size: 0.95rem;
  }

  .blog-sidebar {
    min-width: 0;
  }

  .sidebar-stack {
    position: sticky;
    top: calc(var(--navbar-height) + 24px);
    display: grid;
    gap: 18px;
  }

  .sidebar-widget {
    padding: 24px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.92);
  }

  .sidebar-widget--summary {
    background:
      radial-gradient(circle at top right, rgba(29, 185, 154, 0.14), transparent 42%),
      linear-gradient(180deg, #ffffff 0%, #f8fbfa 100%);
  }

  .sidebar-widget--accent {
    background: linear-gradient(180deg, #0b1a14 0%, #11271f 100%);
    border-color: rgba(29, 185, 154, 0.22);
  }

  .sidebar-widget--accent h3,
  .sidebar-widget--accent .sidebar-kicker,
  .sidebar-widget--accent .sidebar-note,
  .sidebar-widget--accent .widget-link {
    color: #ffffff !important;
  }

  .sidebar-widget--accent .sidebar-kicker::before {
    background: rgba(255, 255, 255, 0.7);
  }

  .sidebar-widget--status {
    border-color: rgba(29, 185, 154, 0.18);
  }

  .sidebar-kicker {
    color: var(--color-turquoise-dark);
    margin-bottom: 12px;
  }

  .sidebar-widget h3 {
    margin: 0 0 16px;
    font-size: 1.3rem;
    line-height: 1.15;
  }

  .sidebar-stat-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 18px;
  }

  .sidebar-stat {
    padding: 14px;
    border-radius: 18px;
    background: #f8fafc;
  }

  .sidebar-stat strong {
    display: block;
    margin-bottom: 4px;
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: #0f172a;
  }

  .sidebar-stat span,
  .timeline-range__label {
    font-size: 0.8rem;
    color: #64748b;
  }

  .timeline-range {
    padding-top: 14px;
    border-top: 1px solid rgba(15, 23, 42, 0.08);
  }

  .timeline-range strong {
    display: block;
    margin-top: 6px;
    color: #0f172a;
    line-height: 1.5;
  }

  .sidebar-list {
    display: grid;
    gap: 14px;
  }

  .sidebar-list__item {
    padding: 14px 0 0;
    border-top: 1px solid rgba(15, 23, 42, 0.08);
  }

  .sidebar-list__item:first-child {
    padding-top: 0;
    border-top: none;
  }

  .sidebar-list__item strong {
    display: block;
    margin-bottom: 6px;
    color: #0f172a;
  }

  .sidebar-list__item p,
  .sidebar-note {
    margin: 0;
    color: #475569;
    line-height: 1.7;
  }

  .widget-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 18px;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-turquoise-dark) !important;
    text-decoration: none;
  }

  .widget-link::after {
    content: ">";
  }

  .pulse-green {
    width: 8px;
    height: 8px;
    display: inline-block;
    margin-left: 8px;
    border-radius: 50%;
    background: #2ecc71;
    box-shadow: 0 0 0 6px rgba(46, 204, 113, 0.16);
    vertical-align: middle;
  }

  .status-ok {
    margin: 0 0 8px;
    font-size: 0.88rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #198754;
  }

  @media (max-width: 1180px) {
    .hero-shell {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      max-width: none;
    }

    .blog-main-layout {
      grid-template-columns: 1fr;
    }

    .sidebar-stack {
      position: static;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }

    .feed-intro {
      flex-direction: column;
      align-items: flex-start;
    }

    .feed-intro h2,
    .feed-intro p {
      max-width: none;
    }

    .hero-metrics {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .container.wide {
      padding: 0 24px;
    }

    .blog-hero {
      padding: 22px 0 18px !important;
    }

    .blog-hero h1 {
      max-width: none;
      font-size: clamp(2.3rem, 11vw, 3.6rem);
    }

    .hero-description {
      font-size: 1rem;
    }

    .hero-featured,
    .sidebar-widget,
    .blog-card-clean {
      border-radius: 22px;
    }

    .blog-main-layout {
      padding: 32px 24px 52px;
      gap: 26px;
    }

    .card-image {
      height: 220px;
    }

    .card-body {
      padding: 22px;
    }

    .card-title {
      font-size: 1.35rem;
    }

    .card-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .sidebar-stack {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .container.wide {
      padding: 0 18px !important;
    }

    .blog-main-layout {
      padding: 28px 18px 48px;
    }

    .card-image {
      height: 200px;
    }
  }
</style>
