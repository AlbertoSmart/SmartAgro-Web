---
import TestPage from "../../layouts/TestPage.astro";
import FAQAccordion from "../../components/FAQAccordion.astro";
import { faqData } from "../../data/faqs";
---

<TestPage
    title="Cuaderno de Explotación para Técnicos – Cuaderno de Campo Digital"
    heading="Panel de Control para Técnicos y Asesores"
    description="Control total sobre múltiples explotaciones. Supervisión avanzada, validación de registros y reportes automáticos para ingenieros y asesores."
    variant="solutions"
    layoutType="mosaic"
    heroSectionClass="hero-tecnicos-offset"
    bodySectionClass="page-body--tecnicos"
    heroBackground="/images/Técnicos y Asesores.jpg"
    mosaicImages={[
        "/images/soluciones/data_dashboard_agri.png",
        "/images/soluciones/engineer_soil_sensors.png",
    ]}
>
    <div class="subpage-content">
        <!-- Section: Professional Features -->
        <section class="tech-features">
            <div class="tech-grid">
                <div class="tech-item glass">
                    <div class="tech-item__icon">
                        <svg
                            width="32"
                            height="32"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="#0fb5ae"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                            ></path><polyline points="9 22 9 12 15 12 15 22"
                            ></polyline></svg
                        >
                    </div>
                    <h3>Visión Multi-Finca</h3>
                    <p>
                        Accede a todas las explotaciones de tus clientes desde
                        una única pantalla. Filtra por estado de cumplimiento o
                        por zona geográfica.
                    </p>
                </div>
                <div class="tech-item glass">
                    <div class="tech-item__icon">
                        <svg
                            width="32"
                            height="32"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="#0fb5ae"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><polygon
                                points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"
                            ></polygon></svg
                        >
                    </div>
                    <h3>Validación en Lote</h3>
                    <p>
                        No revises registro a registro. Nuestro algoritmo valida
                        masivamente que todas las aplicaciones cumplen con el
                        registro Vademécum MAPA.
                    </p>
                </div>
                <div class="tech-item glass">
                    <div class="tech-item__icon">
                        <svg
                            width="32"
                            height="32"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="#0fb5ae"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"
                            ></path><path
                                d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"
                            ></path></svg
                        >
                    </div>
                    <h3>Firma Certificada</h3>
                    <p>
                        Firma digitalmente los cuadernos de explotación para su
                        presentación oficial sin necesidad de reuniones
                        presenciales.
                    </p>
                </div>
                <div class="tech-item glass">
                    <div class="tech-item__icon">
                        <svg
                            width="32"
                            height="32"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="#0fb5ae"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><line x1="18" y1="20" x2="18" y2="10"></line><line
                                x1="12"
                                y1="20"
                                x2="12"
                                y2="4"></line><line
                                x1="6"
                                y1="20"
                                x2="6"
                                y2="14"></line></svg
                        >
                    </div>
                    <h3>Reports de Valor</h3>
                    <p>
                        Genera informes de costes y rendimientos comparados para
                        ofrecer a tus clientes un asesoramiento de nivel
                        superior.
                    </p>
                </div>
            </div>
        </section>

        <!-- Section: Specific Services -->
        <section class="advisor-services">
            <h2>Profesionaliza tu Asesoría Agraria</h2>
            <div class="service-row">
                <div class="service-content">
                    <h3>Integración SIEX Directa</h3>
                    <p>
                        Nuestra plataforma está preparada para la comunicación
                        bidireccional con el sistema oficial de la
                        administración, reduciendo a cero la carga de datos
                        manual para el técnico.
                    </p>
                    <ul class="check-list">
                        <li>Sincronización automática de REA</li>
                        <li>Gestión de CUE (Cuaderno de Explotación)</li>
                        <li>Validación de planes de abonado</li>
                    </ul>
                </div>
                <!-- Mini demo box placeholder -->
                <div class="service-demo glass">
                    <div class="demo-header">Vista de Técnico</div>
                    <div class="demo-body">
                        <div class="demo-line">
                            Explotación A: <span class="status green"
                                >Validada</span
                            >
                        </div>
                        <div class="demo-line">
                            Explotación B: <span class="status yellow"
                                >1 Error</span
                            >
                        </div>
                        <div class="demo-line">
                            Explotación C: <span class="status green"
                                >Validada</span
                            >
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- FAQ Section for Techs -->
        <section class="faq-section" style="padding: 60px 0;">
            <h2 class="text-center" style="margin-bottom: 40px;">
                Consultas Técnicas
            </h2>
            <FAQAccordion items={faqData.tecnicos} />
        </section>

        <div class="highlight-box">
            <h3>¿Hablamos sobre tu equipo?</h3>
            <p>
                Pregunta por nuestros planes de marca blanca y acceso
                multi-usuario para equipos de ingenieros.
            </p>
            <a href="/contacto" class="cta-btn">Consultar Planes de Equipo</a>
        </div>
    </div>
</TestPage>

<style>
    :global(.page-hero.hero-tecnicos-offset) {
        min-height: 420px;
        padding-top: 12px !important;
        padding-bottom: 24px !important;
        overflow: hidden;
    }

    :global(.page-hero.hero-tecnicos-offset::before) {
        content: "";
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 82% 18%, rgba(29, 185, 154, 0.14), transparent 28%),
            linear-gradient(92deg, rgba(8, 18, 14, 0.44) 0%, rgba(8, 18, 14, 0.18) 44%, rgba(8, 18, 14, 0.46) 100%);
        pointer-events: none;
        z-index: 1;
    }

    :global(.hero-tecnicos-offset .page-hero__container) {
        z-index: 2;
    }

    :global(.hero-tecnicos-offset .hero-mosaic) {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(340px, 0.94fr);
        gap: 40px;
        align-items: center;
    }

    :global(.hero-tecnicos-offset .hero-mosaic__content) {
        width: min(100%, 700px);
        justify-self: start;
        padding: 40px 34px 30px;
        border-radius: 30px;
        background: rgba(7, 16, 13, 0.42);
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        box-shadow: 0 28px 80px -44px rgba(0, 0, 0, 0.42);
        box-sizing: border-box;
        overflow: hidden;
    }

    :global(.hero-tecnicos-offset .hero-mosaic__content::before) {
        content: "TECNICOS Y ASESORES";
        display: inline-flex;
        align-items: center;
        margin-bottom: 22px;
        padding: 7px 12px;
        border-radius: 999px;
        background: rgba(29, 185, 154, 0.14);
        border: 1px solid rgba(29, 185, 154, 0.24);
        color: #bff3e8;
        font-size: 0.74rem;
        font-weight: 800;
        letter-spacing: 0.14em;
    }

    :global(.hero-tecnicos-offset .hero-mosaic h1) {
        margin-top: 6px !important;
        margin-bottom: 18px;
        max-width: 100%;
        font-size: clamp(2.2rem, 4.4vw, 3.7rem);
        line-height: 1.02;
        letter-spacing: -0.06em;
        color: #ffffff !important;
        overflow-wrap: anywhere;
        word-break: break-word;
    }

    :global(.hero-tecnicos-offset .hero-mosaic__desc-row) {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 22px;
        align-items: start;
        margin-top: 0 !important;
    }

    :global(.hero-tecnicos-offset .hero-mosaic__desc-row p) {
        margin: 0 !important;
        max-width: 50ch;
        font-size: 1.04rem;
        line-height: 1.72;
        color: rgba(255, 255, 255, 0.88);
    }

    :global(.hero-tecnicos-offset .hero-cta) {
        justify-self: start;
        margin: 0 !important;
        padding: 14px 26px;
        border-radius: 16px;
    }

    :global(.hero-tecnicos-offset .hero-mosaic__images) {
        display: grid;
        grid-template-columns: 1fr 0.9fr;
        gap: 18px;
        align-items: stretch;
        min-height: 340px;
    }

    :global(.hero-tecnicos-offset .m-img) {
        position: relative;
        min-height: 340px;
        border-radius: 28px;
        overflow: hidden;
        background-color: #0b1a14;
        background-size: cover !important;
        background-position: center !important;
        box-shadow: 0 30px 70px -38px rgba(0, 0, 0, 0.44);
        border: none;
    }

    :global(.hero-tecnicos-offset .m-img::after) {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(7, 16, 13, 0.05), rgba(7, 16, 13, 0.34));
    }

    :global(.hero-tecnicos-offset .m-img--1) {
        transform: translateY(24px);
        background-position: 52% 46% !important;
    }

    :global(.hero-tecnicos-offset .m-img--2) {
        min-height: 280px;
        transform: translateY(-18px);
        background-position: 62% center !important;
    }

    :global(.page-body.page-body--tecnicos) {
        padding-top: 24px !important;
        padding-bottom: 2px !important;
        background:
            radial-gradient(circle at top right, rgba(29, 185, 154, 0.08), transparent 26%),
            linear-gradient(180deg, #f7faf9 0%, #ffffff 24%, #f6faf8 100%);
    }

    .tech-features {
        margin: 60px 0 100px;
    }

    .rounded-img {
        border-radius: 24px;
        width: 100%;
        height: auto;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    }

    .tech-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 24px;
    }

    .tech-item {
        padding: 40px 30px;
        border-radius: 20px;
        text-align: left;
        background: white;
        border: 1px solid rgba(0, 0, 0, 0.05);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .tech-item:hover {
        transform: translateY(-8px);
        border-color: var(--color-turquoise);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
    }

    .tech-item__icon {
        width: 56px;
        height: 56px;
        background: rgba(15, 181, 174, 0.1);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 24px;
        color: var(--color-turquoise-dark);
    }

    .tech-item h3 {
        font-size: 1.15rem;
        margin-bottom: 10px;
        color: var(--color-dark);
    }

    .advisor-services {
        padding: 60px 0;
        border-top: 1px solid var(--color-gray-100);
    }

    .service-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
        margin-top: 40px;
    }

    .check-list {
        list-style: none;
        padding: 0;
        margin-top: 20px;
    }

    .check-list li {
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.95rem;
    }

    .check-list li::before {
        content: "✓";
        color: var(--color-green);
        font-weight: 800;
    }

    .service-demo {
        padding: 24px;
        border-radius: 16px;
        border: 1px solid var(--color-gray-200);
        font-family: monospace;
    }

    .demo-header {
        font-size: 0.8rem;
        color: var(--color-gray-500);
        border-bottom: 1px solid var(--color-gray-200);
        padding-bottom: 10px;
        margin-bottom: 15px;
    }

    .status {
        font-weight: bold;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.75rem;
    }

    .status.green {
        background: #dcfce7;
        color: #166534;
    }
    .status.yellow {
        background: #fef9c3;
        color: #854d0e;
    }

    @media (max-width: 768px) {
        :global(.page-hero.hero-tecnicos-offset) {
            min-height: auto;
            padding-top: 0 !important;
            padding-bottom: 30px !important;
        }

        :global(.hero-tecnicos-offset .hero-mosaic) {
            grid-template-columns: 1fr;
            gap: 26px;
        }

        :global(.hero-tecnicos-offset .hero-mosaic__content) {
            padding: 24px 20px;
            width: 100%;
            text-align: center;
        }

        :global(.hero-tecnicos-offset .hero-mosaic__content::before) {
            margin-left: auto;
            margin-right: auto;
        }

        :global(.hero-tecnicos-offset .hero-mosaic h1) {
            max-width: none;
        }

        :global(.hero-tecnicos-offset .hero-mosaic__desc-row p) {
            max-width: none;
        }

        :global(.hero-tecnicos-offset .hero-cta) {
            justify-self: center;
        }

        :global(.hero-tecnicos-offset .hero-mosaic__images) {
            grid-template-columns: 1fr 1fr;
            min-height: auto;
        }

        :global(.hero-tecnicos-offset .m-img),
        :global(.hero-tecnicos-offset .m-img--2) {
            min-height: 210px;
            transform: none;
        }

        :global(.hero-tecnicos-offset .m-img--1) {
            background-position: center 44% !important;
        }

        :global(.hero-tecnicos-offset .m-img--2) {
            background-position: 58% center !important;
        }

        :global(.page-body.page-body--tecnicos) {
            padding-top: 16px !important;
            padding-bottom: 20px !important;
        }

        .service-row {
            grid-template-columns: 1fr;
            gap: 40px;
        }
        .tech-grid {
            grid-template-columns: 1fr;
        }
        .tech-item {
            text-align: center;
            align-items: center;
            padding: 30px 20px;
        }
        .tech-item__icon {
            margin-left: auto;
            margin-right: auto;
        }
    }
</style>

