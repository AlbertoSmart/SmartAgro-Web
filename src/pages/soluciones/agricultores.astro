---
import TestPage from "../../layouts/TestPage.astro";
import ROICalculator from "../../components/ROICalculator.astro";
import FAQAccordion from "../../components/FAQAccordion.astro";
import { faqData } from "../../data/faqs";
---

<TestPage
    title="Cuaderno de Campo para Agricultores – Ecosistema Digital Agrario"
    heading="Cuaderno de Campo para Agricultores"
    description="La herramienta definitiva para la gestión diaria de tu explotación. Digitaliza tus registros, controla tus insumos y cumple con la normativa SIEX de forma sencilla."
    variant="solutions"
    layoutType="mosaic"
    heroSectionClass="hero-agricultores-offset"
    heroBackground="/images/cuaderno de Campo para Agricultores.jpg"
  mosaicImages={["/images/soluciones/farmer_tablet_orchard.png", "/images/soluciones/agricultor_tech_fix.png"]}
>
    <div class="subpage-content">

        <!-- Section: Your Day to Day -->
        <section class="daily-flow">
            <h2>Tu día a día con Cuaderno Digital</h2>
            <div class="flow-grid">
                <div class="flow-step">
                    <div class="flow-step__number">1</div>
                    <h3>Toma de Datos Rápida</h3>
                    <p>Desde el tractor o a pie de campo, registra siembras y cosechas en segundos con nuestra interfaz adaptada a manos trabajadoras.</p>
                </div>
                <div class="flow-step">
                    <div class="flow-step__number">2</div>
                    <h3>Monitorización IA</h3>
                    <p>Nuestros sensores inteligentes detectan plagas y carencias de agua antes de que sean visibles al ojo, enviándote una alerta al móvil.</p>
                </div>
                <div class="flow-step">
                    <div class="flow-step__number">3</div>
                    <h3>Validación Instantánea</h3>
                    <p>El sistema verifica que los productos fitosanitarios aplicados están autorizados para ese cultivo, evitando errores fatales.</p>
                </div>
                <div class="flow-step">
                    <div class="flow-step__number">4</div>
                    <h3>Reporte SIEX</h3>
                    <p>Al final del mes, pulsa un botón y exporta toda tu actividad lista para ser presentada ante la administración oficial.</p>
                </div>
            </div>
        </section>

        <!-- ROI Calculator -->
        <ROICalculator />

        <!-- Section: Tangible Benefits -->
        <section class="benefits-section premium-benefits-box">
            <h2 class="text-white">Beneficios Reales para tu Bolsillo</h2>
            <div class="cards-grid">
                <div class="beneficio-card">
                    <span class="icon">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path></svg>
                    </span>
                    <h3>Ahorro de Agua</h3>
                    <p class="beneficio-card__highlight">Aplica riego solo cuando la planta lo necesita, optimizando hasta un 30% el consumo hídrico.</p>
                </div>
                <div class="beneficio-card">
                    <span class="icon">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"></path><path d="m8.5 8.5 7 7"></path></svg>
                    </span>
                    <h3>Menos Insumos</h3>
                    <p class="beneficio-card__highlight">Precisión en las dosis de fertilizante que reduce costes y mejora la salud del suelo.</p>
                </div>
                <div class="beneficio-card">
                    <span class="icon">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                    </span>
                    <h3>Paz Mental</h3>
                    <p class="beneficio-card__highlight">Olvídate del papeleo de última hora. Ten toda tu documentación siempre lista para una inspección.</p>
                </div>
            </div>
        </section>

        <!-- Feature List Re-styled -->
        <div class="tools-overview">
            <h2 class="text-center">Herramientas Incluidas</h2>
            <div class="cards-grid">
                <div class="feature-card">
                    <div class="feature-card__icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    </div>
                    <h3>Stock Inteligente</h3>
                    <p>Inventario actualizado de productos con avisos de caducidad y stock mínimo.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-card__icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
                    </div>
                    <h3>Trazabilidad</h3>
                    <p>Histórico completo desde la semilla hasta la carga del camión, accesible en un clic.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-card__icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    </div>
                    <h3>Mapas Satélite</h3>
                    <p>Visualización NDVI para detectar manchas de vigor y problemas de crecimiento antes de ir a la parcela.</p>
                </div>
            </div>
        </div>

        <!-- FAQ Section -->
        <section class="faq-section" style="padding: 60px 0;">
            <h2 class="text-center" style="margin-bottom: 40px;">Preguntas Frecuentes</h2>
            <FAQAccordion items={faqData.agricultores} />
        </section>

        <div class="highlight-box">
            <h3>¿Hablamos sobre tu finca?</h3>
            <p>Cada explotación es un mundo. Cuéntanos tu caso y te enseñaremos cómo adaptamos nuestra tecnología a tus cultivos.</p>
            <a href="/contacto" class="cta-btn">Agendar Consultoría Gratuita</a>
        </div>
    </div>
</TestPage>

<style>
    :global(.hero-agricultores-offset .hero-mosaic__content) {
        padding-top: 12px;
    }

    :global(.hero-agricultores-offset) {
        padding-bottom: 0 !important;
    }

    :global(.hero-agricultores-offset .hero-mosaic) {
        gap: 32px;
    }

    :global(.hero-agricultores-offset .hero-mosaic h1) {
        margin-top: -8px;
        margin-bottom: 14px;
    }

    :global(.hero-agricultores-offset .hero-mosaic__desc-row) {
        gap: 12px;
        align-items: flex-start;
        margin-top: -14px !important;
    }

    :global(.hero-agricultores-offset .hero-mosaic__desc-row p) {
        margin-top: -18px;
    }

    :global(.hero-agricultores-offset .hero-cta) {
        padding: 12px 24px;
        margin-top: 6px;
    }
    .daily-flow {
        padding: 60px 0 100px; /* More breathing room */
    }

    .rounded-img {
        border-radius: 24px;
        width: 100%;
        height: auto;
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    }

    .flow-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 30px;
        margin-top: 40px;
    }

    .flow-step {
        position: relative;
        padding: 40px 30px;
        background: white;
        border-radius: 20px;
        text-align: left;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        transition: transform 0.3s ease;
    }

    .flow-step:hover {
        transform: translateY(-5px);
        border-color: var(--color-turquoise);
    }

    .flow-step__number {
        position: absolute;
        top: -15px;
        left: 20px;
        width: 40px;
        height: 40px;
        background: var(--color-turquoise);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .flow-step h3 {
        margin-top: 10px;
        font-size: 1.15rem;
        margin-bottom: 12px;
    }

    .benefits-section {
        padding: 80px 40px;
        border-radius: 32px;
        margin: 80px 0;
        position: relative;
        overflow: hidden;
    }

    .premium-benefits-box {
        background: linear-gradient(145deg, #0B1A14 0%, #163127 100%);
        border: 1px solid rgba(29, 185, 154, 0.3);
        box-shadow: 0 40px 100px rgba(0,0,0,0.25);
    }

    .text-white { 
        color: white !important; 
        font-weight: 850;
        letter-spacing: -0.02em;
        margin-bottom: 48px !important;
        text-align: center;
    }

    .beneficio-card {
        padding: 40px 30px;
        text-align: center;
        background: rgba(255,255,255,0.04);
        border-radius: 24px;
        border: 1px solid rgba(255,255,255,0.08);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        backdrop-filter: blur(10px);
    }

    .beneficio-card h3,
    .beneficio-card p {
        color: white;
    }

    .beneficio-card__highlight {
        color: #e6f3ff !important;
    }

    .beneficio-card:hover {
        background: rgba(255,255,255,0.07);
        transform: translateY(-10px);
        border-color: rgba(29, 185, 154, 0.5);
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }

    .beneficio-card .icon {
        color: var(--color-turquoise);
        margin-bottom: 24px;
        display: inline-flex;
        padding: 15px;
        background: rgba(29, 185, 154, 0.1);
        border-radius: 16px;
        transition: all 0.3s ease;
    }

    .beneficio-card:hover .icon {
        transform: scale(1.1) rotate(5deg);
        background: rgba(29, 185, 154, 0.2);
        box-shadow: 0 0 20px rgba(29, 185, 154, 0.3);
    }

    @media (max-width: 768px) {
        .flow-grid { grid-template-columns: 1fr; }
        .benefits-section {
            padding: 40px 20px;
            margin: 40px 0;
        }
        .cards-grid {
            grid-template-columns: 1fr !important;
            gap: 20px !important;
        }
        .beneficio-card {
            padding: 30px 20px;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .beneficio-card .icon {
            margin-left: auto;
            margin-right: auto;
            margin-bottom: 20px;
        }
        .text-white {
            margin-bottom: 30px !important;
            font-size: 1.5rem;
        }
    }
</style>
