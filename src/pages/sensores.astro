---
import Layout from "../layouts/Layout.astro";

const searchParams = Astro.url.searchParams;
const category = searchParams.get("category")?.toLowerCase();

const sensorFamilies = [
  {
    id: "suelo",
    anchor: "section-suelo",
    number: "01",
    eyebrow: "Suelo y raiz",
    title: "Suelo y raiz: la capa que decide el rendimiento",
    summary:
      "Sensores para leer humedad, nutricion, oxigenacion y actividad biologica en el perfil del suelo antes de que el cultivo lo exprese.",
    highlight: "Ideal para riego de precision, fertirrigacion y seguimiento multicapa.",
    sensors: [
      {
        title: "Sensor Suelo Temp/Hum",
        description:
          "Deteccion por tecnologia FDR de humedad volumetrica y temperatura en el lecho de siembra.",
        href: "/sensores/suelo-humedad-temp",
        image: "/images/sensores/SensorTemperaturaHumedadSuelo.png",
        alt: "Sensor suelo temperatura y humedad",
      },
      {
        title: "Sensor pH Suelo",
        description:
          "Monitorizacion continua del pH para optimizar la disponibilidad de nutrientes minerales.",
        href: "/sensores/suelo-ph",
        image: "/images/sensores/SensorphTemperaturaSuelo.png",
        alt: "Sensor de pH de suelo",
      },
      {
        title: "pH Alta Precision",
        description:
          "Control electroquimico avanzado para suelos salinos, sustratos sensibles y mediciones criticas.",
        href: "/sensores/suelo-ph-precision",
        image: "/images/sensores/SensorDePhAltaPrecision.png",
        alt: "Sensor de pH de alta precision",
      },
      {
        title: "Sensor CO2 Tierra",
        description:
          "Analisis de respiracion radicular y actividad microbiana para evaluar el estado biologico del suelo.",
        href: "/sensores/suelo-co2",
        image: "/images/sensores/SensorCO2.png",
        alt: "Sensor de CO2 para suelo",
      },
      {
        title: "Sensor Oxigeno Suelo",
        description:
          "Medicion de difusion de oxigeno para prevenir asfixia radicular en suelos pesados o compactados.",
        href: "/sensores/suelo-oxigeno",
        image: "/images/sensores/SensorOxigenoSuelo.png",
        alt: "Sensor de oxigeno en suelo",
      },
      {
        title: "Sensor Tierra 8 en 1",
        description:
          "Lectura integrada de N, P, K, pH, CE, humedad, temperatura y salinidad en un solo nodo.",
        href: "/sensores/suelo-8en1",
        image: "/images/sensores/SensorSuelo8en1.png",
        alt: "Sensor de tierra 8 en 1",
      },
      {
        title: "Sensor Tubular Multicapa",
        description:
          "Sonda multinivel para interpretar el perfil hidrico completo hasta 120 cm de profundidad.",
        href: "/sensores/suelo-tubular",
        image: "/images/sensores/SensorTubularHumeadytemperaturaEnDistintasCapas.png",
        alt: "Sensor tubular multicapa",
      },
    ],
  },
  {
    id: "planta",
    anchor: "section-planta",
    number: "02",
    eyebrow: "Fisiologia vegetal",
    title: "Fisiologia de planta: escuchar al cultivo en tiempo real",
    summary:
      "Sensores instalados sobre tronco, fruto y hoja para detectar estres, crecimiento y momentos criticos con mucha mas anticipacion.",
    highlight: "Especialmente util para decisiones de riego, calibre y control sanitario.",
    sensors: [
      {
        title: "Dendrometro de Tronco",
        description:
          "Medicion micrometrica de las variaciones del diametro del tallo para detectar estres hidrico temprano.",
        href: "/sensores/planta-dendrometro-tronco",
        image: "/images/sensores/DendometroTronco.png",
        alt: "Dendrometro de tronco",
      },
      {
        title: "Dendrometro de Fruto",
        description:
          "Seguimiento continuo del crecimiento del fruto para estimar calibre y ritmo de desarrollo.",
        href: "/sensores/planta-dendrometro-fruto",
        image: "/images/sensores/dendometroFruto2.png",
        alt: "Dendrometro de fruto",
      },
      {
        title: "Sensor Temp. Hoja",
        description:
          "Termometria infrarroja para medir temperatura de canopia y calcular indice de estres hidrico.",
        href: "/sensores/planta-temp-hoja",
        image: "/images/sensores/SensorHojaChinosTemperaturayHumedad.png",
        alt: "Sensor de temperatura de hoja",
      },
      {
        title: "Sensor Hoja Humectacion",
        description:
          "Deteccion del tiempo de mojado foliar para modelos de plagas y riesgos criptogamicos.",
        href: "/sensores/planta-hoja-humectacion",
        image: "/images/sensores/SensorHojaChinosTemperaturayHumedad.png",
        alt: "Sensor de humectacion foliar",
      },
    ],
  },
  {
    id: "clima",
    anchor: "section-clima",
    number: "03",
    eyebrow: "Clima y riego",
    title: "Clima y riego: el contexto que activa cada decision",
    summary:
      "Equipos para monitorizar atmosfera, lluvia, radiacion y disponibilidad de agua con una lectura continua del entorno productivo.",
    highlight: "Base perfecta para automatizar alertas, prediccion y uso eficiente del agua.",
    sensors: [
      {
        title: "Estacion Meteorologica",
        description:
          "Nodo integrado con anemometro, piranometro, pluviometro y sensores de temperatura y humedad.",
        href: "/sensores/clima-estacion",
        image: "/images/sensores/EstacionMeteorologica.png",
        alt: "Estacion meteorologica",
      },
      {
        title: "Sensor Nivel de Agua",
        description:
          "Control hidrostatico de depositos, pozos y canales para gestionar el riego con mas precision.",
        href: "/sensores/agua-nivel",
        image: "/images/sensores/SensorNivelAgua.png",
        alt: "Sensor de nivel de agua",
      },
    ],
  },
];

const visibleFamilies = sensorFamilies.filter(
  (family) => !category || family.id === category,
);

const totalSensors = sensorFamilies.reduce(
  (count, family) => count + family.sensors.length,
  0,
);
---

<Layout title="Ecosistema de Sensores Inteligentes IoT">
  <main class="sensors-page">
    <section class="sensors-hero">
      <div class="container sensors-hero__grid">
        <div class="sensors-hero__content">
          <span class="sensors-hero__eyebrow">Hub de sensores inteligentes</span>
          <h1>Catálogo de sensores inteligentes para agricultura</h1>
          <p class="sensors-hero__lead">
            Organiza tus decisiones por capas: suelo, planta y clima. Cada familia
            de sensores aparece agrupada, explicada y preparada para que encuentres
            rapido lo que encaja con tu explotacion.
          </p>

          <div class="sensors-hero__actions">
            <a href="#familias" class="btn btn--turquoise sensors-hero__cta">
              Explorar sensores
            </a>
            <a href="#newsletter" class="sensors-hero__link">
              Hablar con un especialista
            </a>
          </div>
        </div>

        <aside class="sensors-hero__panel">
          <div class="hero-panel-card">
            <span class="hero-panel-card__label">Visión general</span>
            <ul class="hero-panel-card__stats">
              <li>
                <strong>{totalSensors}</strong>
                <span>sensores disponibles</span>
              </li>
              <li>
                <strong>3</strong>
                <span>familias de trabajo</span>
              </li>
              <li>
                <strong>24/7</strong>
                <span>lectura continua de campo</span>
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <section class="sensors-overview">
      <div class="container">
        <div class="overview-shell">
          <div class="overview-copy">
            <span class="section-chip">Como esta organizada la página</span>
            <h2>Una estructura mucho más ordenada para comparar mejor</h2>
            <p>
              Hemos separado el catálogo por función agronómica y no solo por
              producto. Así es más sencillo identificar que sensores te ayudan a
              observar el suelo, cuales leen directamente la planta y cuales
              aportan contexto atmosférico o hidrico.
            </p>
          </div>

          <div class="overview-highlights">
            <article class="overview-tile">
              <span>01</span>
              <h3>Lectura por familias</h3>
              <p>Bloques visuales diferenciados para orientarte sin esfuerzo.</p>
            </article>
            <article class="overview-tile">
              <span>02</span>
              <h3>Tarjetas mas limpias</h3>
              <p>Más aire, mejor jerarquia y llamadas a accion mucho mas claras.</p>
            </article>
            <article class="overview-tile">
              <span>03</span>
              <h3>Navegación directa</h3>
              <p>Acceso rápido a cada familia desde la parte superior.</p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="family-nav" id="familias">
      <div class="container family-nav__inner">
        {sensorFamilies.map((family) => (
          <a
            href={`#${family.anchor}`}
            class={`family-nav__pill ${category === family.id ? "is-active" : ""}`.trim()}
          >
            <span>{family.number}</span>
            <strong>{family.eyebrow}</strong>
          </a>
        ))}
      </div>
    </section>

    <section class="sensors-catalog">
      <div class="container">
        <div class="catalog-stack">
          {visibleFamilies.map((family) => (
            <section id={family.anchor} class="family-section">
              <div class="family-section__header">
                <div class="family-section__intro">
                  <span class="family-section__number">{family.number}</span>
                  <div>
                    <span class="section-chip">{family.eyebrow}</span>
                    <h2>{family.title}</h2>
                  </div>
                </div>

                <div class="family-section__summary">
                  <p>{family.summary}</p>
                  <div class="family-highlight">
                    <strong>Enfoque:</strong>
                    <span>{family.highlight}</span>
                  </div>
                </div>
              </div>

              <div class="sensor-grid">
                {family.sensors.map((sensor) => (
                  <article class="sensor-card">
                    <div class="sensor-card__media">
                      <img src={sensor.image} alt={sensor.alt} />
                    </div>

                    <div class="sensor-card__body">
                      <span class="sensor-card__tag">{family.eyebrow}</span>
                      <h3>{sensor.title}</h3>
                      <p>{sensor.description}</p>
                      <a href={sensor.href} class="sensor-card__link">
                        Ver ficha tecnica
                      </a>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .sensors-page {
    background:
      radial-gradient(circle at top left, rgba(29, 185, 154, 0.08), transparent 24%),
      linear-gradient(180deg, #eef6f3 0%, #ffffff 24%, #f7fbfa 100%);
    color: var(--color-slate-700);
  }

  .sensors-hero {
    position: relative;
    overflow: hidden;
    padding: 84px 0 44px;
    background:
      radial-gradient(circle at 85% 18%, rgba(29, 185, 154, 0.18), transparent 18%),
      radial-gradient(circle at 12% 16%, rgba(255, 255, 255, 0.14), transparent 16%),
      linear-gradient(135deg, #08130f 0%, #10231c 56%, #17362b 100%);
    color: white;
  }

  .sensors-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.75fr);
    gap: 36px;
    align-items: end;
  }

  .sensors-hero__content {
    max-width: 760px;
  }

  .sensors-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }

  .sensors-hero__eyebrow::before {
    content: "";
    width: 32px;
    height: 1px;
    background: currentColor;
  }

  .sensors-hero h1 {
    max-width: 13ch;
    margin: 0 0 22px;
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
    color: white;
  }

  .sensors-hero__lead {
    max-width: 60ch;
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.82);
  }

  .sensors-hero__actions {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 32px;
  }

  .sensors-hero__cta {
    margin: 0 !important;
    color: #07110d !important;
  }

  .sensors-hero__link {
    font-weight: 700;
    color: rgba(255, 255, 255, 0.86);
    text-decoration: underline;
    text-underline-offset: 6px;
  }

  .sensors-hero__panel {
    align-self: stretch;
  }

  .hero-panel-card {
    height: 100%;
    min-height: 100%;
    padding: 28px;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 28px 60px rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(12px);
  }

  .hero-panel-card__label {
    display: inline-block;
    margin-bottom: 18px;
    padding: 7px 12px;
    border-radius: 999px;
    background: rgba(29, 185, 154, 0.14);
    color: var(--color-turquoise);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-panel-card__stats {
    display: grid;
    gap: 16px;
  }

  .hero-panel-card__stats li {
    padding: 18px 18px 16px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .hero-panel-card__stats strong {
    display: block;
    margin-bottom: 4px;
    font-size: 1.8rem;
    line-height: 1;
    color: white;
    letter-spacing: -0.04em;
  }

  .hero-panel-card__stats span {
    color: rgba(255, 255, 255, 0.76);
    font-size: 0.95rem;
  }

  .sensors-overview {
    padding: 28px 0 24px;
  }

  .overview-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.95fr);
    gap: 30px;
    align-items: start;
    padding: 34px;
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(15, 23, 42, 0.06);
    box-shadow: 0 28px 56px -42px rgba(15, 23, 42, 0.24);
  }

  .section-chip {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 7px 12px;
    border-radius: 999px;
    background: rgba(29, 185, 154, 0.08);
    color: var(--color-turquoise-dark);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .overview-copy h2 {
    margin: 16px 0 14px;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  .overview-copy p {
    max-width: 62ch;
    font-size: 1.04rem;
    line-height: 1.8;
    color: var(--color-slate-700);
  }

  .overview-highlights {
    display: grid;
    gap: 16px;
  }

  .overview-tile {
    padding: 22px 22px 20px;
    border-radius: 24px;
    background: linear-gradient(180deg, #ffffff 0%, #f6faf8 100%);
    border: 1px solid rgba(15, 23, 42, 0.06);
  }

  .overview-tile span {
    display: inline-block;
    margin-bottom: 12px;
    font-size: 0.88rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    color: var(--color-turquoise);
  }

  .overview-tile h3 {
    margin: 0 0 8px;
    font-size: 1.15rem;
  }

  .overview-tile p {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.65;
    color: var(--color-slate-700);
  }

  .family-nav {
    padding: 10px 0 16px;
  }

  .family-nav__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .family-nav__pill {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 16px 34px -26px rgba(15, 23, 42, 0.22);
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .family-nav__pill span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(29, 185, 154, 0.1);
    color: var(--color-turquoise-dark);
    font-size: 0.8rem;
    font-weight: 900;
  }

  .family-nav__pill strong {
    color: var(--color-slate-900);
    font-size: 0.96rem;
  }

  .family-nav__pill:hover,
  .family-nav__pill.is-active {
    transform: translateY(-2px);
    border-color: rgba(29, 185, 154, 0.35);
    box-shadow: 0 20px 36px -26px rgba(29, 185, 154, 0.28);
  }

  .sensors-catalog {
    padding: 14px 0 80px;
  }

  .catalog-stack {
    display: grid;
    gap: 36px;
  }

  .family-section {
    padding: 34px;
    border-radius: 36px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(249, 252, 251, 0.98) 100%);
    border: 1px solid rgba(15, 23, 42, 0.06);
    box-shadow: 0 34px 72px -52px rgba(15, 23, 42, 0.28);
  }

  .family-section__header {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    gap: 28px;
    align-items: start;
    margin-bottom: 28px;
  }

  .family-section__intro {
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }

  .family-section__number {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 58px;
    height: 58px;
    border-radius: 18px;
    background: #0b1a14;
    color: white;
    font-size: 1rem;
    font-weight: 900;
    letter-spacing: 0.08em;
  }

  .family-section__intro h2 {
    margin: 14px 0 0;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.02;
    letter-spacing: -0.045em;
  }

  .family-section__summary {
    display: grid;
    gap: 16px;
  }

  .family-section__summary p {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.8;
  }

  .family-highlight {
    display: grid;
    gap: 6px;
    padding: 18px 18px 16px;
    border-radius: 22px;
    background: rgba(29, 185, 154, 0.07);
    border: 1px solid rgba(29, 185, 154, 0.14);
  }

  .family-highlight strong {
    color: var(--color-slate-900);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .family-highlight span {
    color: var(--color-slate-700);
    line-height: 1.7;
  }

  .sensor-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .sensor-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    overflow: hidden;
    border-radius: 26px;
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.07);
    box-shadow: 0 22px 50px -42px rgba(15, 23, 42, 0.32);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .sensor-card:hover {
    transform: translateY(-6px);
    border-color: rgba(29, 185, 154, 0.34);
    box-shadow: 0 28px 56px -38px rgba(15, 23, 42, 0.34);
  }

  .sensor-card__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(29, 185, 154, 0.14), transparent 26%),
      linear-gradient(180deg, #f6fbf9 0%, #edf5f2 100%);
  }

  .sensor-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .sensor-card:hover .sensor-card__media img {
    transform: scale(1.05);
  }

  .sensor-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 24px 24px 22px;
  }

  .sensor-card__tag {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 14px;
    padding: 7px 11px;
    border-radius: 999px;
    background: rgba(29, 185, 154, 0.08);
    color: var(--color-turquoise-dark);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sensor-card__body h3 {
    margin: 0 0 10px;
    font-size: 1.36rem;
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .sensor-card__body p {
    margin: 0;
    flex: 1;
    color: var(--color-slate-700);
    font-size: 0.98rem;
    line-height: 1.7;
  }

  .sensor-card__link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: fit-content;
    margin-top: 24px;
    padding: 14px 18px;
    border-radius: 16px;
    background: #0b1a14;
    color: white;
    font-size: 0.84rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sensor-card__link::after {
    content: ">";
    font-size: 0.95rem;
    line-height: 1;
  }

  .sensor-card__link:hover {
    color: #07110d !important;
    background: var(--color-turquoise);
  }

  @media (max-width: 1100px) {
    .sensors-hero__grid,
    .overview-shell,
    .family-section__header {
      grid-template-columns: 1fr;
    }

    .sensor-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .sensors-hero h1 {
      max-width: 11ch;
    }
  }

  @media (max-width: 768px) {
    .sensors-hero {
      padding: 54px 0 30px;
    }

    .sensors-hero__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .sensors-hero__link {
      text-align: center;
    }

    .overview-shell,
    .family-section {
      padding: 24px 20px;
    }

    .family-section__intro {
      flex-direction: column;
      gap: 14px;
    }

    .family-section__number {
      width: 52px;
      height: 52px;
      border-radius: 16px;
    }

    .sensor-grid {
      grid-template-columns: 1fr;
    }

    .family-nav__inner {
      display: grid;
      grid-template-columns: 1fr;
