---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import SensorCarousel from "../components/SensorCarousel.astro";

const soilSensors = [
  {
    name: "Sensor Suelo Temp/Hum",
    specs: "Optimización inmediata del consumo hídrico y costes energéticos.",
    image: "/images/sensores/SensorTemperaturaHumedadSuelo.png",
    category: "Suelo",
    href: "/sensores/suelo-humedad-temp",
  },
  {
    name: "Sensor pH de Suelo",
    specs:
      "Gestión eficiente de la nutrición vegetal y reducción de lixiviación.",
    image: "/images/sensores/SensorphTemperaturaSuelo.png",
    category: "Suelo",
    href: "/sensores/suelo-ph",
  },
  {
    name: "Sensor Suelo 8 en 1",
    specs:
      "Sonda multiparamétrica versátil para analítica avanzada en tiempo real.",
    image: "/images/sensores/SensorSuelo8en1.png",
    category: "Suelo",
    href: "/sensores/suelo-8en1",
  },
  {
    name: "Sensor Tubular Multicapa",
    specs:
      "Análisis de perfil hídrico para una gestión de riego de alta precisión.",
    image:
      "/images/sensores/SensorTubularHumeadytemperaturaEnDistintasCapas.png",
    category: "Suelo",
    href: "/sensores/suelo-tubular",
  },
  {
    name: "Sensor Oxígeno Suelo",
    specs: "Detección preventiva de hipoxia radicular y patógenos edáficos.",
    image: "/images/sensores/SensorOxigenoSuelo.png",
    category: "Suelo",
    href: "/sensores/suelo-oxigeno",
  },
];

const plantSensors = [
  {
    name: "Dendrómetro de Tronco",
    specs:
      "Monitorización continua de la dinámica hídrica y detección de estrés.",
    image: "/images/sensores/DendometroTronco.png",
    category: "Planta",
    href: "/sensores/planta-dendrometro-tronco",
  },
  {
    name: "Dendrómetro de Fruto",
    specs:
      "Optimización de la curva de crecimiento y determinación del punto de cosecha.",
    image: "/images/sensores/dendometroFruto2.png",
    category: "Planta",
    href: "/sensores/planta-dendrometro-fruto",
  },
  {
    name: "Sensor de Hoja Temp/Hum",
    specs: "Análisis técnico de riesgos fitosanitarios por humectación foliar.",
    image: "/images/sensores/SensorHojaChinosTemperaturayHumedad.png",
    category: "Planta",
    href: "/sensores/planta-hoja-humectacion",
  },
  {
    name: "Sensor Temperatura Hoja",
    specs: "Medición de estrés térmico mediante termometría infrarroja.",
    image: "/images/sensores/SensorHojaChinosTemperaturayHumedad.png",
    category: "Planta",
    href: "/sensores/planta-temp-hoja",
  },
];

const otherSensors = [
  {
    name: "Estación Meteorológica",
    specs: "Nodo integrado LoRaWAN para parametrización atmosférica completa.",
    image: "/images/sensores/EstacionMeteorologica.png",
    category: "Clima",
    href: "/sensores/clima-estacion",
  },
  {
    name: "Sensor Nivel de Agua",
    specs:
      "Control hidrostático de precisión para gestión de recursos hídricos.",
    image: "/images/sensores/SensorNivelAgua.png",
    category: "Riego",
    href: "/sensores/agua-nivel",
  },
];
---

<Layout title="Guía Técnica de Sensorización: Auditoría Agronómica">
  <main class="editorial-guide">
    <!-- HERO SECTION -->
    <section class="editorial-hero">
      <div class="container">
        <div class="hero-intro-card">
          <h1>Sensores<br />Agronómicos</h1>
          <details class="hero-info-card">
            <summary>
              <span>Ver información</span>
              <span class="hero-info-card__icon" aria-hidden="true"></span>
            </summary>
            <div class="hero-info-card__content">
              <p class="summary-block">
                Este documento técnico analiza las ventajas operativas y el
                impacto económico de la digitalización de precisión. Nuestra
                auditoría se centra en tres pilares fundamentales: dinámica
                edáfica, fisiología vegetal y parametrización climática.
              </p>
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- SECTION 1: SOIL (ZIG-ZAG) -->
    <section class="editorial-section white-section" style="padding-bottom: 0;">
      <div class="container">
        <div class="zig-zag-row">
          <div
            class="text-content manual-detail-box manual-detail-box--animated"
          >
            <h2>Sensores de inserción usados para el Control Total del Agua, Nutrientes y Raíz</h2>
            <div class="copy-pills">
              <p>
                Los <b>sensores de inserción</b> son dispositivos utilizados para medir la temperatura o el caudal en diversas aplicaciones industriales. Existen diferentes tipos de sensores de inserción, cada uno con características específicas que se adaptan a diferentes necesidades:
              </p>
              <p>
                <b>Sensores de temperatura de inserción:</b> Diseñados para medir temperaturas a lo largo de la longitud del sensor, son ideales para aplicaciones críticas en alimentos y metales.
              </p>
              <p>
                <b>Caudalímetros electromagnéticos:</b> Utilizados para medir el caudal en cañerías preexistentes (ya existían anteriormente), que ofrecen una alta relación calidad-precio y son compatibles con líquidos con conductividad eléctrica superior a 5-10 μS/cm. 
              </p>
              <p>
              <b>Termómetros de inserción:</b> Permiten medir la temperatura de alimentos y tienen una interfaz Bluetooth para comunicación con dispositivos móviles. 
              </p>
              <p>
                Para encontrar el sensor de inserción adecuado, es importante considerar el tipo de medición requerida, el rango de temperatura o caudal, y las condiciones de uso. Además, es recomendable consultar con <b>Smart Fenix</b> para obtener asesoramiento y garantizar la compatibilidad con otros dispositivos y sistemas.
              </p>
              <p>
                Finalmente, la monitorización del oxígeno detecta precozmente la
               <b>Hipoxia Radicular</b>.
              </p>
            </div>

            <ul class="tech-specs">
              <li>Optimización inmediata del consumo hídrico y energía.</li>
              <li>Aumento de la Eficiencia del Uso de Nutrientes (**NUE**).</li>
              <li>Control activo de salinidad y pH en tiempo real.</li>
              <li>Prevención de patógenos por exceso de humedad radicular.</li>
            </ul>
          </div>
          <div class="media-content media-content--soil">
            <div class="editorial-image-stack">
              <img
                src="/images/sensores/field_sensor_hero.jpg"
                alt="Visualización Dinámica Edáfica"
                class="editorial-image editorial-image-stack__primary"
              />
              <img
                src="/images/pexels-tomfisk-36030322%20(1).jpg"
                alt="Instalación técnica de sensores en campo"
                class="editorial-image editorial-image-stack__secondary"
              />
              <img
                src="/images/sensores/pexels-panditwiguna-13043993.jpg"
                alt="Detalle de sensorización y entorno de cultivo"
                class="editorial-image editorial-image-stack__tertiary"
              />
            </div>
          </div>
        </div>
      </div>

      <div class="carousel-section" style="padding-bottom: 20px;">
        <div class="container">
          <SensorCarousel
            sensors={soilSensors}
            title="Hardware de Monitorización de Suelo"
          />
        </div>
      </div>
    </section>

    <!-- SECTION 2: PLANT (ZIG-ZAG REVERSE) -->
    <section
      class="editorial-section grey-section"
      style="padding-top: 100px; padding-bottom: 0;"
    >
      <div class="container">
        <div class="zig-zag-row zig-zag-row--reverse">
          <div
            class="text-content manual-detail-box manual-detail-box--animated"
          >
            <h2>Importancia del estado fisiológico de la planta</h2>
            <div class="copy-pills">
              <p>
                La <b>fisiología vegetal</b> en la agricultura de precisión se enfoca en cómo las plantas ajustan sus procesos internos según su entorno. 
                En lugar de depender de estimaciones externas sobre condiciones del suelo o el clima, este enfoque avanzado necesita medir directamente cómo responde fisiológicamente el cultivo.
              </p>
              <p>
              En este contexto, los dendrómetros de tronco y fruto permiten registrar variaciones micrométricas en el diámetro de los órganos vegetales. A partir de estos datos se puede calcular el <b>MDS (Maximum Daily Shrinkage)</b>, o contracción máxima diaria, un parámetro importantísimo para evaluar el estado hídrico de la planta.
              </p>
              <p>
                El <b>MDS</b> es el indicador más sensible del estrés hídrico,
                detectando la caída de presión en el xilema antes de que se
                produzca un cierre estomático visible o daños irreversibles.
              </p>
              <p>
                En fruticultura, monitorizar la curva de expansión logarítmica
                es vital. Optimizar el tamaño final mediante gestión hídrica en
                fases críticas asegura la obtención de <b>Calibres Premium</b>.
              </p>
              <p>
                La temperatura foliar (<b>CWSI</b>) y el tiempo de <b>Mojado
                Foliar</b> son esenciales para la sanidad vegetal. Conocer la
                humectación exacta permite aplicar tratamientos preventivos solo
                cuando el riesgo existe.
              </p>
            </div>

            <ul class="tech-specs">
              <li>Indicador precoz de estrés hídrico mediante **MDS**.</li>
              <li>Maximización de rendimientos y calibres comerciales.</li>
              <li>Automatización de riego basada en demanda transpirativa.</li>
              <li>Reducción de coste en insumos fitosanitarios.</li>
            </ul>
          </div>
          <div class="media-content media-content--plant">
            <img
              src="/images/gregmontani-field-852242.jpg"
              alt="Cultivo monitorizado en campo"
              class="editorial-image editorial-image--plant-main"
            />
            <img
              src="/images/sensores/plant_sensor_hero.jpg"
              alt="Análisis Fisiológico"
              class="editorial-image editorial-image--plant-secondary"
            />
          </div>
        </div>
      </div>

      <div class="carousel-section" style="padding-bottom: 20px;">
        <div class="container">
          <SensorCarousel
            sensors={plantSensors}
            title="Hardware de Monitorización Fisiológica"
          />
        </div>
      </div>
    </section>

    <!-- SECTION 3: CLIMATE & OTHERS (ZIG-ZAG) -->
    <section class="editorial-section white-section" style="padding-bottom: 0;">
      <div class="container">
        <div class="zig-zag-row">
          <div
            class="text-content manual-detail-box manual-detail-box--animated"
          >
            <h2>Control Inteligente del Agua y el Clima en la Finca</h2>
            <div class="copy-pills">
              <p>
                La atmósfera dicta la demanda hídrica mediante la
                **Evapotranspiración (ET)**. Sin monitorización climática
                precisa, la gestión del riego carece de un marco de referencia
                sólido.
              </p>
              <p>
                Las estaciones IoT integran múltiples sensores para calcular
                automáticamente la **ETp (Penman-Monteith)**. Este dato es el
                valor negativo fundamental en el balance hídrico de la finca.
              </p>
              <p>
                La meteorología local determina el cálculo de horas-frío e
                **Integrales Térmicas (GDD)**. Estas predicciones permiten
                organizar la logística de cosecha y personal con semanas de
                antelación.
              </p>
              <p>
                La monitorización hidrostática asegura el control de recursos
                hídricos en depósitos y pozos. Evitar roturas de stock hídrico
                es crítico en periodos de máxima demanda evaporativa.
              </p>
              <p>
                La arquitectura de bajo consumo y comunicación **LoRaWAN**
                garantiza que los datos lleguen desde puntos remotos sin
                necesidad de infraestructuras complejas o costosas.
              </p>
            </div>

            <ul class="tech-specs">
              <li>Cálculo preciso de **ETp** para balance hídrico.</li>
              <li>Predicción de estadios fenológicos y riesgos de plagas.</li>
              <li>Control de inventario hídrico en depósitos y balsas.</li>
              <li>Conectividad remota de alta eficiencia via **LoRaWAN**.</li>
            </ul>
          </div>
          <div class="media-content media-content--plant">
            <img
              src="/images/soluciones/campo-dron-2.webp"
              alt="Monitorización con dron en campo"
              class="editorial-image editorial-image--plant-main"
            />
            <img
              src="/images/sensores/weather_sensor_hero.jpg"
              alt="Estación Meteorológica e Hidrostática"
              class="editorial-image editorial-image--plant-secondary"
            />
          </div>
        </div>

        <div class="carousel-section" style="padding-bottom: 20px;">
          <div class="container">
            <SensorCarousel
              sensors={otherSensors}
              title="Clima y Sistemas de Gestión de Recursos"
            />
          </div>
        </div>

        <div class="navigation-btn-container">
          <a href="/sensores" class="btn-catalog">Explorar Catálogo Completo</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .editorial-guide {
    background: #ffffff;
    color: #000000;
    padding-top: 80px;
    font-family:
      "Inter",
      system-ui,
      -apple-system,
      sans-serif;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    box-sizing: border-box;
  }

  /* HERO */
  .editorial-hero {
    padding: 56px 0 40px;
    background: #ffffff;
    text-align: center;
  }

  .hero-intro-card {
    max-width: 980px;
    margin: 0 auto;
    padding: 40px 52px 36px;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(
        circle at 12% 18%,
        rgba(29, 185, 154, 0.2),
        transparent 28%
      ),
      radial-gradient(
        circle at 86% 20%,
        rgba(125, 211, 252, 0.2),
        transparent 24%
      ),
      linear-gradient(140deg, #ffffff 0%, #f4fbf7 45%, #eef8ff 100%);
    border: 1px solid rgba(11, 26, 20, 0.1);
    border-radius: 32px;
    box-shadow:
      0 30px 80px rgba(11, 26, 20, 0.12),
      0 0 0 1px rgba(255, 255, 255, 0.7) inset;
    animation: heroCardReveal 1.1s cubic-bezier(0.16, 1, 0.3, 1) both;
    transition:
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.5s ease,
      border-color 0.5s ease;
  }

  .hero-intro-card::before {
    content: "";
    position: absolute;
    inset: -30% auto auto -10%;
    width: 46%;
    height: 160%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.12) 32%,
      rgba(255, 255, 255, 0.72) 50%,
      rgba(255, 255, 255, 0.14) 68%,
      transparent 100%
    );
    transform: rotate(14deg);
    opacity: 0.9;
    pointer-events: none;
    animation: heroCardSheen 6.5s ease-in-out infinite;
  }

  .hero-intro-card::after {
    content: "";
    position: absolute;
    inset: auto -8% -22% auto;
    width: 240px;
    height: 240px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(29, 185, 154, 0.22) 0%,
      rgba(29, 185, 154, 0.08) 42%,
      transparent 72%
    );
    filter: blur(6px);
    pointer-events: none;
    animation: heroCardPulse 7s ease-in-out infinite;
  }

  .hero-intro-card:hover {
    transform: translateY(-6px) scale(1.01);
    border-color: rgba(29, 185, 154, 0.24);
    box-shadow:
      0 42px 100px rgba(11, 26, 20, 0.16),
      0 0 0 1px rgba(255, 255, 255, 0.76) inset;
  }

  .hero-intro-card > * {
    position: relative;
    z-index: 1;
  }

  .editorial-hero h1 {
    font-size: 5rem;
    font-weight: 900;
    line-height: 1.1;
    max-width: 1100px;
    margin: 0 auto 40px;
    letter-spacing: -0.05em;
  }

  .summary-block {
    font-size: 1.4rem;
    line-height: 1.7;
    max-width: 800px;
    margin: 0 auto;
    color: #444444;
    font-weight: 400;
  }

  .hero-info-card {
    max-width: 820px;
    margin: 40px auto 0;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(11, 26, 20, 0.08);
    border-radius: 24px;
    overflow: hidden;
    text-align: left;
    backdrop-filter: blur(14px);
    box-shadow: 0 18px 40px rgba(11, 26, 20, 0.08);
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease,
      border-color 0.35s ease;
  }

  .hero-info-card:hover {
    transform: translateY(-2px);
    border-color: rgba(29, 185, 154, 0.2);
    box-shadow: 0 22px 44px rgba(11, 26, 20, 0.11);
  }

  .hero-info-card summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 24px 28px;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    color: #0b1a14;
  }

  .hero-info-card summary::-webkit-details-marker {
    display: none;
  }

  .hero-info-card__icon {
    width: 14px;
    height: 14px;
    border-right: 2px solid var(--color-turquoise);
    border-bottom: 2px solid var(--color-turquoise);
    transform: rotate(45deg);
    transition: transform 0.25s ease;
    flex-shrink: 0;
    margin-top: -6px;
  }

  .hero-info-card[open] .hero-info-card__icon {
    transform: rotate(-135deg);
    margin-top: 4px;
  }

  .hero-info-card__content {
    padding: 0 28px 28px;
    border-top: 1px solid rgba(11, 26, 20, 0.08);
  }

  .hero-info-card__content p {
    margin: 22px 0 0;
    max-width: none;
    color: #3f4c45;
  }

  @keyframes heroCardReveal {
    0% {
      opacity: 0;
      transform: perspective(1200px) rotateX(10deg) translateY(42px) scale(0.96);
      filter: blur(10px);
    }
    60% {
      opacity: 1;
      transform: perspective(1200px) rotateX(-1deg) translateY(-4px) scale(1.01);
      filter: blur(0);
    }
    100% {
      opacity: 1;
      transform: perspective(1200px) rotateX(0deg) translateY(0) scale(1);
      filter: blur(0);
    }
  }

  @keyframes heroCardSheen {
    0% {
      left: -28%;
      opacity: 0;
    }
    10% {
      opacity: 0.95;
    }
    38% {
      left: 108%;
      opacity: 0.85;
    }
    100% {
      left: 108%;
      opacity: 0;
    }
  }

  @keyframes heroCardPulse {
    0%,
    100% {
      transform: scale(0.92);
      opacity: 0.5;
    }
    50% {
      transform: scale(1.08);
      opacity: 0.95;
    }
  }

  /* ZIG-ZAG GRID */
  .editorial-section {
    padding: 160px 0;
    overflow: hidden;
  }

  .zig-zag-row {
    display: flex;
    gap: 80px;
    align-items: stretch;
    margin-bottom: 120px;
  }

  .zig-zag-row--reverse {
    flex-direction: row-reverse;
  }

  .text-content {
    flex: 1;
  }

  .text-content h2 {
    font-size: 2.8rem;
    font-weight: 900;
    margin-bottom: 32px;
    letter-spacing: -0.03em;
    line-height: 1.1;
    position: relative;
    padding-bottom: 24px;
  }

  .text-content h2::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 80px;
    height: 4px;
    background: var(--color-turquoise);
  }

  .copy-pills p {
    font-size: 1.15rem;
    line-height: 1.8;
    margin-bottom: 24px;
    color: #333333;
    max-width: 600px;
  }

  .tech-specs {
    margin-top: 40px;
    padding-left: 0;
    list-style: none;
  }

  .tech-specs li {
    font-size: 1.1rem;
    padding: 12px 0;
    border-bottom: 1px solid #f0f0f0;
    color: #555555;
    display: flex;
    align-items: center;
  }

  .tech-specs li::before {
    content: "→";
    margin-right: 12px;
    color: var(--color-turquoise);
    font-weight: 900;
  }

  .manual-detail-box {
    background: #f8f9fa;
    padding: 40px;
    border-radius: 12px;
    border: 1px solid #e9ecef;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: center;
  }

  .manual-detail-box--animated {
    position: relative;
    overflow: hidden;
    animation: manualBoxEntrance 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease,
      border-color 0.35s ease;
  }

  .manual-detail-box--animated:hover {
    transform: translateY(-6px);
    box-shadow: 0 22px 48px rgba(15, 23, 42, 0.1);
    border-color: rgba(29, 185, 154, 0.28);
  }

  .manual-detail-box--animated::before {
    content: "";
    position: absolute;
    inset: -20% auto -20% -35%;
    width: 42%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(29, 185, 154, 0.08) 45%,
      rgba(29, 185, 154, 0.2) 50%,
      rgba(29, 185, 154, 0.08) 55%,
      transparent 100%
    );
    transform: rotate(12deg);
    animation: manualBoxSheen 4.8s ease-in-out infinite;
    pointer-events: none;
  }

  .manual-detail-box--animated > * {
    position: relative;
    z-index: 1;
  }

  @keyframes manualBoxEntrance {
    from {
      opacity: 0;
      transform: translateY(28px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes manualBoxSheen {
    0% {
      left: -38%;
      opacity: 0;
    }
    12% {
      opacity: 1;
    }
    40% {
      left: 118%;
      opacity: 0.9;
    }
    100% {
      left: 118%;
      opacity: 0;
    }
  }

  .media-content {
    flex: 1;
    display: flex;
  }

  .media-content--soil {
    align-items: center;
  }

  .media-content--plant {
    flex-direction: column;
    gap: 16px;
    align-items: stretch;
  }

  .editorial-image-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .editorial-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
