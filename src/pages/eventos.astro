---
import TestPage from "../layouts/TestPage.astro";
---

<TestPage
  title="Eventos – Cuaderno de Campo Digital"
  heading="Impulsando la Formación Agraria"
  description="Calendario oficial de seminarios técnicos, talleres de campo y presentaciones sobre inteligencia artificial aplicada."
  variant="eventos"
>
  <div class="events-container">
    <div class="events-timeline">
      <div class="event-card glass">
        <div class="event-date">
          <span class="day">22</span>
          <span class="month">MAY</span>
        </div>
        <div class="event-details">
          <span class="event-type">Seminario Online</span>
          <h3>Planes de Abonado y Nutrición</h3>
          <p>
            Aprende a generar planes de fertilización automatizados cumpliendo
            con la normativa de nitratos.
          </p>
          <div class="event-meta">
            <span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline; margin-right:4px; vertical-align:middle;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> 10:00 - 12:00
            </span>
            <span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline; margin-right:4px; vertical-align:middle;"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg> Zoom Webinar
            </span>
          </div>
          <a href="/contacto" class="event-btn">Inscribirse</a>
        </div>
      </div>

      <div class="event-card glass">
        <div class="event-date">
          <span class="day">15</span>
          <span class="month">JUN</span>
        </div>
        <div class="event-details">
          <span class="event-type">Taller de Campo</span>
          <h3>Instalación de Sensores IoT</h3>
          <p>
            Demostración práctica de despliegue de cámaras y sensores de humedad
            en finca real.
          </p>
          <div class="event-meta">
            <span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline; margin-right:4px; vertical-align:middle;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> 09:30 - 14:00
            </span>
            <span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline; margin-right:4px; vertical-align:middle;"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg> Jaén, España
            </span>
          </div>
          <a href="/contacto" class="event-btn">Reservar Plaza</a>
        </div>
      </div>

      <div class="event-card glass secondary">
        <div class="event-date">
          <span class="day">08</span>
          <span class="month">JUL</span>
        </div>
        <div class="event-details">
          <h3>Presentación YOLOv11 en Agritech</h3>
          <p>
            Evento exclusivo para técnicos sobre la integración de modelos de IA
            en sensores de bajo consumo.
          </p>
          <div class="event-meta">
            <span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline; margin-right:4px; vertical-align:middle;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> 18:00
            </span>
            <span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline; margin-right:4px; vertical-align:middle;"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg> Madrid - IFEMA
            </span>
          </div>
          <a href="/contacto" class="event-btn">Solicitar Invitación</a>
        </div>
      </div>
    </div>
  </div>

  <style>
    .events-container {
      margin-top: -60px;
      display: flex;
      justify-content: flex-start;
    }

    .events-timeline {
      display: flex;
      flex-direction: column;
      gap: 24px;
      max-width: 900px;
      margin: 0;
    }

    .event-card {
      background: white;
      border-radius: 24px;
      display: flex;
      overflow: hidden;
      border: 1px solid var(--color-gray-100);
      transition: all 0.3s ease;
    }

    .event-card:hover {
      transform: scale(1.02);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
    }

    .event-date {
      background: var(--color-turquoise);
      color: white;
      padding: 30px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-width: 140px;
    }

    .event-date .day {
      font-size: 2.5rem;
      font-weight: 800;
      line-height: 1;
    }

    .event-date .month {
      font-size: 1rem;
      font-weight: 700;
      opacity: 0.9;
    }

    .event-details {
      padding: 32px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .event-type {
      font-size: 0.75rem;
      font-weight: 800;
      text-transform: uppercase;
      color: var(--color-turquoise-dark);
      letter-spacing: 0.05em;
    }

    .event-details h3 {
      font-size: 1.5rem;
      color: var(--color-gray-900);
      margin: 0;
    }

    .event-details p {
      color: var(--color-gray-600);
      font-size: 1rem;
      line-height: 1.5;
    }

    .event-meta {
      display: flex;
      gap: 20px;
      margin: 8px 0;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--color-gray-400);
    }

    .event-btn {
      align-self: flex-start;
      padding: 10px 24px;
      background: var(--color-gray-50);
      color: var(--color-gray-900);
      text-decoration: none;
      border-radius: 100px;
      font-weight: 700;
      font-size: 0.9rem;
      margin-top: 12px;
      transition: all 0.2s ease;
      border: 1px solid var(--color-gray-200);
    }

    .event-btn:hover {
      background: var(--color-turquoise);
      color: white;
      border-color: var(--color-turquoise);
    }

    .event-card.secondary .event-date {
      background: var(--color-dark);
    }

    @media (max-width: 600px) {
      .event-card {
        flex-direction: column;
      }
      .event-date {
        padding: 20px;
        flex-direction: row;
        gap: 12px;
        min-width: auto;
      }
    }
  </style>
</TestPage>
