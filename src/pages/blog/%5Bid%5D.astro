---
import Layout from "../../layouts/Layout.astro";
import { getPostById } from "../../lib/blog";

const { id } = Astro.params;
const post = await getPostById(id as string);

if (!post) {
    return Astro.redirect('/blog');
}

// Convert line breaks to paragraphs for professional formatting
const paragraphs = post.content.split('\n\n');
---

<Layout title={`${post.title} - Blog Técnico Smart Fenix`}>
  <main class="article-page">
    <header class="article-hero">
      <div class="hero-bg" style={`background-image: url(${post.image})`}></div>
      <div class="container wide">
        <div class="hero-content">
          <nav class="breadcrumb">
            <a href="/blog">Blog</a> / <span class="current-cat">{post.categoryName}</span>
          </nav>
          <h1 class="article-title">{post.title}</h1>
          <div class="article-meta">
            <span class="meta-item author">Por <strong>{post.author || "Smart Fenix"}</strong></span>
            <span class="meta-item date">{post.date}</span>
          </div>
        </div>
      </div>
    </header>

    <div class="container article-layout">
      <div class="article-main section-padding">
        <article class="pro-content">
          {paragraphs.map(p => (
            <p>{p}</p>
          ))}
        </article>

        <section class="cta-banner">
          <div class="cta-inner">
             <h3>¿Necesitas asesoramiento técnico personalizado?</h3>
             <p>Nuestro equipo de ingenieros te ayuda a implementar estas tecnologías en tu finca.</p>
             <a href="/contacto" class="btn-turquoise">Hablar con un Experto</a>
          </div>
        </section>
      </div>

      <aside class="article-sidebar section-padding">
        <div class="sidebar-widget">
          <h4>Categoría: {post.categoryName}</h4>
          <p class="sidebar-info">{post.excerpt}</p>
        </div>

        <div class="sidebar-sticky">
           <h4>Información Adicional</h4>
           <p>Este artículo forma parte de nuestra base de conocimientos técnicos para la agricultura 4.0.</p>
           <a href="/guia-sensores" class="sidebar-link">Guía de Sensores →</a>
           <a href="/soluciones/tecnicos" class="sidebar-link">Soluciones para Técnicos →</a>
        </div>
      </aside>
    </div>
  </main>
</Layout>

<style>
  .article-page {
    background: #FFFFFF;
  }

  .article-hero {
    position: relative;
    padding: 180px 0 100px;
    color: white;
    background: #0B1A14;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    opacity: 0.3;
    filter: grayscale(20%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
  }

  .breadcrumb {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-turquoise);
    margin-bottom: 25px;
  }

  .breadcrumb a { color: white; text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .current-cat { color: var(--color-turquoise); opacity: 0.8; }

  .article-title {
    font-size: 3.5rem;
    font-weight: 850;
    line-height: 1.1;
    margin-bottom: 30px;
    letter-spacing: -0.02em;
  }

  .article-meta {
    display: flex;
    gap: 25px;
    font-size: 1rem;
    color: rgba(255,255,255,0.7);
  }

  .meta-item strong { color: white; }

  .article-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 80px;
  }

  .pro-content {
    font-size: 1.25rem;
    line-height: 1.8;
    color: #334155;
  }

  .pro-content p {
    margin-bottom: 30px;
  }

  .cta-banner {
    margin-top: 80px;
    padding: 60px;
    background: #f8fafc;
    border-radius: 32px;
    border: 1px solid #e2e8f0;
  }

  .cta-inner h3 { font-size: 1.8rem; font-weight: 800; color: #0b1a14; margin-bottom: 15px; }
  .cta-inner p { margin-bottom: 25px; color: #64748b; font-size: 1.1rem; }

  .btn-turquoise {
    display: inline-block;
    background: var(--color-turquoise);
    color: white;
    padding: 16px 32px;
    border-radius: 12px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-turquoise:hover {
    background: var(--color-turquoise-dark);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(29, 185, 154, 0.2);
  }

  .sidebar-widget {
    background: #f8fafc;
    padding: 30px;
    border-radius: 20px;
    margin-bottom: 40px;
    border-left: 4px solid var(--color-turquoise);
  }

  .sidebar-widget h4 { margin-bottom: 15px; font-size: 1.1rem; font-weight: 800; }
  .sidebar-info { font-size: 0.95rem; color: #64748b; line-height: 1.6; }

  .sidebar-sticky {
    position: sticky;
    top: 120px;
  }

  .sidebar-sticky h4 { margin-bottom: 20px; font-size: 1.1rem; font-weight: 800; }
  .sidebar-link {
    display: block;
    padding: 12px 0;
    color: #475569;
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid #f1f5f9;
    transition: color 0.3s ease;
  }

  .sidebar-link:hover { color: var(--color-turquoise); }

  @media (max-width: 1024px) {
    .article-layout { grid-template-columns: 1fr; gap: 40px; }
    .article-title { font-size: 2.2rem; }
    .article-hero { padding: 140px 0 60px; }
    .cta-banner { padding: 30px; }
  }
</style>
