---
import Layout from "../../layouts/Layout.astro";
import { getPostById } from "../../lib/blog";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/404');
}

const post = await getPostById(id);

if (!post) {
  return Astro.redirect('/404');
}
---

<Layout title={`${post.title} - Smart Fenix Blog Técnico`}>
  <main class="blog-article-page">
    <div class="article-hero" style={`background-image: linear-gradient(to bottom, rgba(11, 26, 20, 0.8), #0B1A14), url(${post.image});`}>
      <div class="container narrow hero-content">
        <a href="/blog" class="back-to-blog">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Volver al Blog
        </a>
        <div class="article-header">
          <span class="article-category">{post.categoryName || 'General'}</span>
          <h1 class="article-title">{post.title}</h1>
          <div class="article-meta">
            <div class="meta-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span>{post.author || 'Equipo Técnico Smart Fénix'}</span>
            </div>
            <div class="meta-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>{post.date}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="container narrow article-layout">
      <article class="main-content">
        <div class="content-body" set:html={post.content}>
        </div>

        <div class="article-footer">
          <div class="share-section">
            <p>¿Te ha servido este artículo? Compártelo:</p>
            <div class="share-buttons">
              <button class="share-btn" aria-label="Share on LinkedIn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              </button>
              <button class="share-btn" aria-label="Share on Twitter">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
              </button>
            </div>
          </div>
          <div class="next-steps-card">
              <h3>¿Necesitas asesoramiento técnico?</h3>
              <p>Nuestros ingenieros expertos están a tu disposición para optimizar la rentabilidad de tu explotación.</p>
              <a href="/contacto" class="btn--turquoise">Contactar con Ingeniería</a>
          </div>
        </div>
      </article>

      <aside class="article-sidebar">
        <div class="sidebar-info-box">
          <h4>Ficha Técnica</h4>
          <ul class="technical-stats">
            <li>
              <span class="stat-label">Ámbito:</span>
              <span class="stat-value">{post.categoryName}</span>
            </li>
            <li>
              <span class="stat-label">Referencia:</span>
              <span class="stat-value">SF-{post.id.slice(0,4).toUpperCase()}</span>
            </li>
            <li>
              <span class="stat-label">Soporte:</span>
              <span class="stat-value">Digital</span>
            </li>
          </ul>
        </div>
      </aside>
    </div>
  </main>
</Layout>

<style is:global>
  .blog-article-page {
    background: #ffffff;
    min-height: 100vh;
  }

  /* HERO SECTION */
  .article-hero {
    height: 70vh;
    min-height: 500px;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    position: relative;
    color: white;
    overflow: hidden;
  }

  .article-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(11, 26, 20, 0.4), rgba(11, 26, 20, 0.95));
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    animation: fadeInUp 0.8s ease-out;
  }

  .back-to-blog {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-turquoise);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    margin-bottom: 40px;
    transition: all 0.3s;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .back-to-blog:hover {
    color: white;
    transform: translateX(-5px);
  }

  .article-category {
    text-transform: uppercase;
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    color: var(--color-turquoise);
    margin-bottom: 20px;
    display: inline-block;
    padding: 6px 16px;
    background: rgba(29, 185, 154, 0.1);
    border: 1px solid rgba(29, 185, 154, 0.3);
    border-radius: 4px;
    backdrop-filter: blur(4px);
  }

  .article-title {
    font-size: clamp(2.2rem, 6vw, 4rem);
    font-weight: 850;
    line-height: 1.05;
    margin-bottom: 40px;
    letter-spacing: -0.03em;
    max-width: 1000px;
    color: #ffffff !important;
    text-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 32px;
    font-weight: 600;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.9);
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .meta-item svg {
    color: var(--color-turquoise);
  }

  /* MAIN LAYOUT */
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 100px;
    padding-top: 100px;
    padding-bottom: 120px;
  }

  /* SIDEBAR SPECIFICS */
  .sidebar-info-box {
    background: #f8fafc;
    padding: 32px;
    border-radius: 12px;
    position: sticky;
    top: 100px;
    border: 1px solid #eeeeee;
  }

  .sidebar-info-box h4 {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 800;
    margin-bottom: 24px;
    color: #0B1A14;
  }

  .technical-stats {
    padding: 0;
    list-style: none;
  }

  .technical-stats li {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  
  .technical-stats li::before {
    content: none !important; /* Override global arrow for sidebar stats */
  }

  .stat-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #666666;
  }

  .stat-value {
    font-size: 0.85rem;
    font-weight: 700;
    color: #0B1A14;
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .article-layout {
      grid-template-columns: 1fr;
      gap: 60px;
    }
    .article-sidebar { order: -1; }
    .sidebar-info-box { position: static; }
  }

  @media (max-width: 768px) {
    .article-hero { height: 450px; padding-bottom: 40px; }
    .article-title { font-size: 2.2rem; }
    .article-meta { flex-direction: column; gap: 16px; }
    /* REMOVED share-section stack override to keep them in row */
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
